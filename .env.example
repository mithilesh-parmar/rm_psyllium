# Google Analytics 4 — get from analytics.google.com > Admin > Data Streams > your stream > Measurement ID
# Format: G-XXXXXXXXXX
PUBLIC_GA4_ID=

# Microsoft Clarity — get from clarity.microsoft.com > your project > Settings > Overview
# Format: 10-character alphanumeric string (e.g. abc1234xyz)
PUBLIC_CLARITY_ID=

# Calendly or booking page URL (optional)
PUBLIC_BOOKING_URL=
