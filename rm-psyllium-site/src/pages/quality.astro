---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const certifications = [
  { name: 'ISO 9001:2015', description: 'Quality Management System', icon: 'quality' },
  { name: 'FSSC 22000', description: 'Food Safety System Certification', icon: 'safety' },
  { name: 'USDA Organic', description: 'Certified Organic by USDA', icon: 'organic' },
  { name: 'EU Organic', description: 'European Organic Certification', icon: 'organic' },
  { name: 'GMP Certified', description: 'Good Manufacturing Practices', icon: 'gmp' },
  { name: 'Halal', description: 'Halal Certified', icon: 'halal' },
  { name: 'Kosher', description: 'Kosher Certified', icon: 'kosher' },
  { name: 'Non-GMO', description: 'Non-GMO Project Verified', icon: 'nongmo' }
];

const qualitySteps = [
  { step: 1, title: 'Raw Material Inspection', description: 'Every seed lot is tested for purity, moisture, and foreign matter upon arrival.' },
  { step: 2, title: 'Cleaning & Sorting', description: 'Multi-stage cleaning removes impurities and ensures uniform quality.' },
  { step: 3, title: 'Processing', description: 'Controlled husking and grinding under GMP conditions.' },
  { step: 4, title: 'Laboratory Testing', description: '14-point quality analysis including fiber content, microbiology, and contaminants.' },
  { step: 5, title: 'Packaging', description: 'Food-grade packaging in controlled environment to prevent contamination.' },
  { step: 6, title: 'Final Release', description: 'Certificate of Analysis generated before shipment release.' }
];

const labCapabilities = [
  'Fiber Content Analysis',
  'Moisture Determination',
  'Microbiological Testing',
  'Heavy Metals Screening',
  'Pesticide Residue Analysis',
  'Particle Size Distribution',
  'Viscosity Testing',
  'Organoleptic Evaluation'
];
---

<BaseLayout title="Quality & Compliance - RM Psyllium">
  <Header currentPath="/quality" />
  
  <main>
    <section class="page-header">
      <div class="container">
        <h1>Quality & Compliance</h1>
        <p class="page-subtitle">
          Uncompromising standards backed by certified systems and advanced laboratory capabilities
        </p>
      </div>
    </section>
    
    <section class="section">
      <div class="container">
        <div class="quality-intro">
          <div class="quality-content">
            <h2>Our Quality Promise</h2>
            <p>
              At RM Psyllium, quality is not just a department—it's embedded in every step 
              of our operation. From farm selection to final shipment, we maintain rigorous 
              controls that exceed international standards.
            </p>
            <p>
              Our state-of-the-art processing facility in Gujarat operates under FSSC 22000 
              and GMP guidelines, with an in-house NABL-accredited laboratory ensuring every 
              batch meets specifications before release.
            </p>
          </div>
          <div class="quality-stats">
            <div class="stat-card">
              <div class="stat-number">14</div>
              <div class="stat-label">Quality Checkpoints</div>
            </div>
            <div class="stat-card">
              <div class="stat-number">100%</div>
              <div class="stat-label">Batch Traceability</div>
            </div>
            <div class="stat-card">
              <div class="stat-number">8+</div>
              <div class="stat-label">International Certifications</div>
            </div>
          </div>
        </div>
      </div>
    </section>
    
    <section class="section-sm certifications-section">
      <div class="container">
        <div class="section-header text-center">
          <h2>Certifications & Accreditations</h2>
          <p class="section-subtitle">
            Globally recognized standards for quality, safety, and compliance
          </p>
        </div>
        
        <div class="grid grid-4">
          {certifications.map((cert) => (
            <div class="cert-card card">
              <div class="cert-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <circle cx="12" cy="8" r="7"/>
                  <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/>
                </svg>
              </div>
              <h3>{cert.name}</h3>
              <p>{cert.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
    
    <section class="section process-section">
      <div class="container">
        <div class="section-header text-center">
          <h2>Quality Control Process</h2>
          <p class="section-subtitle">
            Six critical stages ensure consistent, specification-compliant products
          </p>
        </div>
        
        <div class="process-timeline">
          {qualitySteps.map((step, index) => (
            <div class="process-step">
              <div class="step-marker">{step.step}</div>
              <div class="step-content">
                <h3>{step.title}</h3>
                <p>{step.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
    
    <section class="section-sm lab-section">
      <div class="container">
        <div class="lab-grid">
          <div class="lab-content">
            <h2>In-House Laboratory Capabilities</h2>
            <p>
              Our fully equipped quality control laboratory performs comprehensive testing 
              on every production batch. With advanced instrumentation and trained analysts, 
              we ensure rapid turnaround and accurate results.
            </p>
            <ul class="lab-list">
              {labCapabilities.map((capability) => (
                <li>
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  {capability}
                </li>
              ))}
            </ul>
            <a href="/contact" class="btn btn-primary mt-lg">Request COA Sample</a>
          </div>
          <div class="lab-image-placeholder">
            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
              <path d="M9 3H15V9H9V3Z"/>
              <path d="M6 9H18V21H6V9Z"/>
              <line x1="12" y1="13" x2="12" y2="17"/>
              <line x1="10" y1="15" x2="14" y2="15"/>
            </svg>
          </div>
        </div>
      </div>
    </section>
    
    <section class="section traceability-section">
      <div class="container">
        <div class="traceability-card card">
          <div class="traceability-content">
            <h2>Complete Traceability</h2>
            <p>
              Every RM Psyllium shipment comes with complete documentation tracing back to 
              the source. Our digital tracking system maintains records of:
            </p>
            <ul class="traceability-list">
              <li>Farm origin and harvest date</li>
              <li>Raw material test reports</li>
              <li>Processing batch records</li>
              <li>Quality control certificates</li>
              <li>Packaging and storage conditions</li>
              <li>Shipment documentation</li>
            </ul>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>

<style>
  .page-header {
    padding: var(--space-4xl) 0 var(--space-2xl);
    background: linear-gradient(135deg, var(--color-bg-primary) 0%, var(--color-bg-tertiary) 100%);
    text-align: center;
  }
  
  .page-subtitle {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
    max-width: 720px;
    margin: var(--space-md) auto 0;
  }
  
  .quality-intro {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--space-3xl);
    align-items: center;
  }
  
  @media (max-width: 1024px) {
    .quality-intro {
      grid-template-columns: 1fr;
    }
  }
  
  .quality-content h2 {
    margin-bottom: var(--space-lg);
  }
  
  .quality-content p {
    margin-bottom: var(--space-md);
  }
  
  .quality-stats {
    display: grid;
    gap: var(--space-lg);
  }
  
  .stat-card {
    padding: var(--space-xl);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border-light);
    border-radius: 4px;
    text-align: center;
  }
  
  .stat-number {
    font-size: 3rem;
    font-weight: 700;
    color: var(--color-accent-primary);
    line-height: 1;
    margin-bottom: var(--space-sm);
  }
  
  .stat-label {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    font-weight: 500;
  }
  
  .certifications-section {
    background: var(--color-bg-tertiary);
  }
  
  .cert-card {
    text-align: center;
  }
  
  .cert-icon {
    width: 64px;
    height: 64px;
    margin: 0 auto var(--space-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-accent-light);
    border-radius: 8px;
    color: var(--color-accent-primary);
  }
  
  .cert-card h3 {
    font-size: 1rem;
    margin-bottom: var(--space-xs);
  }
  
  .cert-card p {
    font-size: 0.875rem;
    margin: 0;
  }
  
  .process-section {
    background: var(--color-bg-secondary);
  }
  
  .process-timeline {
    max-width: 960px;
    margin: 0 auto;
    position: relative;
  }
  
  .process-timeline::before {
    content: '';
    position: absolute;
    left: 40px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-border-light);
  }
  
  .process-step {
    display: flex;
    gap: var(--space-xl);
    padding: var(--space-lg) 0;
    position: relative;
  }
  
  .step-marker {
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-accent-primary);
    color: #FFFFFF;
    font-size: 1.5rem;
    font-weight: 700;
    border-radius: 50%;
    flex-shrink: 0;
    z-index: 1;
  }
  
  .step-content {
    padding-top: var(--space-md);
  }
  
  .step-content h3 {
    margin-bottom: var(--space-sm);
  }
  
  .step-content p {
    margin: 0;
    max-width: 640px;
  }
  
  .lab-section {
    background: var(--color-bg-tertiary);
  }
  
  .lab-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    align-items: center;
  }
  
  @media (max-width: 1024px) {
    .lab-grid {
      grid-template-columns: 1fr;
    }
  }
  
  .lab-content h2 {
    margin-bottom: var(--space-lg);
  }
  
  .lab-list {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
    margin-top: var(--space-lg);
  }
  
  @media (max-width: 768px) {
    .lab-list {
      grid-template-columns: 1fr;
    }
  }
  
  .lab-list li {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
  }
  
  .lab-list svg {
    color: var(--color-accent-primary);
    flex-shrink: 0;
  }
  
  .lab-image-placeholder {
    width: 100%;
    aspect-ratio: 4/3;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border-light);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent-primary);
  }
  
  .traceability-card {
    background: linear-gradient(135deg, var(--color-accent-primary) 0%, var(--color-accent-hover) 100%);
    color: #FFFFFF;
  }
  
  .traceability-content h2 {
    color: #FFFFFF;
    margin-bottom: var(--space-md);
  }
  
  .traceability-content p {
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: var(--space-lg);
  }
  
  .traceability-list {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-sm);
  }
  
  @media (max-width: 768px) {
    .traceability-list {
      grid-template-columns: 1fr;
    }
  }
  
  .traceability-list li {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.9);
  }
  
  .traceability-list li::before {
    content: '✓';
    color: #FFFFFF;
    font-weight: 700;
  }
</style>
