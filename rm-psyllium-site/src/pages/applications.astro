---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const applications = [
  {
    industry: 'Food & Beverage',
    slug: 'food-beverage',
    description: 'Psyllium fiber for bakery, cereals, snacks, and functional beverages.',
    benefits: ['Texture improvement', 'Shelf-life extension', 'Clean label fiber enrichment']
  },
  {
    industry: 'Nutraceutical',
    slug: 'nutraceutical',
    description: 'High-purity psyllium for dietary supplements and digestive health products.',
    benefits: ['Digestive health support', 'Heart health claims', 'Weight management']
  },
  {
    industry: 'Pharmaceutical',
    slug: 'pharma',
    description: 'GMP-grade psyllium for OTC laxatives and therapeutic formulations.',
    benefits: ['Pharmacopoeia compliance', 'Consistent viscosity', 'Tablet binding properties']
  },
  {
    industry: 'Wellness',
    slug: 'wellness',
    description: 'Natural fiber solutions for wellness brands and lifestyle products.',
    benefits: ['Plant-based positioning', 'Gut microbiome support', 'Daily wellness routines']
  },
  {
    industry: 'Organic & Clean Label',
    slug: 'organic',
    description: 'Certified organic psyllium for natural and organic product lines.',
    benefits: ['USDA/EU Organic certified', 'Non-GMO verified', 'Minimal processing']
  },
  {
    industry: 'Animal Nutrition',
    slug: 'animal-nutrition',
    description: 'Fiber-rich ingredients for livestock and pet food applications.',
    benefits: ['Digestive health', 'Feed efficiency', 'Cost-effective fiber source']
  }
];
---

<BaseLayout title="Applications - RM Psyllium">
  <Header currentPath="/applications" />
  
  <main>
    <section class="page-header">
      <div class="container">
        <h1>Industry Applications</h1>
        <p class="page-subtitle">
          Versatile psyllium solutions engineered for specific market requirements
        </p>
      </div>
    </section>
    
    <section class="section">
      <div class="container">
        <div class="applications-grid">
          {applications.map((app) => (
            <article class="application-card card">
              <div class="app-header">
                <h2>{app.industry}</h2>
                <p>{app.description}</p>
              </div>
              
              <div class="app-benefits">
                <h3>Key Benefits</h3>
                <ul>
                  {app.benefits.map((benefit) => (
                    <li>
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="20 6 9 17 4 12"/>
                      </svg>
                      {benefit}
                    </li>
                  ))}
                </ul>
              </div>
              
              <a href="/contact" class="btn btn-outline">Request Application Notes</a>
            </article>
          ))}
        </div>
      </div>
    </section>
    
    <section class="section-sm cta-section">
      <div class="container">
        <div class="cta-card">
          <div class="cta-content">
            <h2>Technical Support for Your Application</h2>
            <p>
              Our application scientists can help you optimize psyllium selection, 
              dosage, and processing parameters for your specific formulation.
            </p>
            <a href="/contact" class="btn btn-primary">Speak with a Specialist</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>

<style>
  .page-header {
    padding: var(--space-4xl) 0 var(--space-2xl);
    background: linear-gradient(135deg, var(--color-bg-primary) 0%, var(--color-bg-tertiary) 100%);
    text-align: center;
  }
  
  .page-subtitle {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
    max-width: 640px;
    margin: var(--space-md) auto 0;
  }
  
  .applications-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
  }
  
  @media (max-width: 1024px) {
    .applications-grid {
      grid-template-columns: 1fr;
    }
  }
  
  .application-card {
    display: flex;
    flex-direction: column;
  }
  
  .app-header {
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border-light);
    margin-bottom: var(--space-lg);
  }
  
  .app-header h2 {
    margin-bottom: var(--space-sm);
  }
  
  .app-header p {
    margin: 0;
    font-size: 0.9375rem;
  }
  
  .app-benefits {
    flex-grow: 1;
    margin-bottom: var(--space-lg);
  }
  
  .app-benefits h3 {
    font-size: 0.9375rem;
    margin-bottom: var(--space-md);
    color: var(--color-text-secondary);
  }
  
  .app-benefits ul {
    list-style: none;
  }
  
  .app-benefits li {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    padding: var(--space-xs) 0;
  }
  
  .app-benefits svg {
    color: var(--color-accent-primary);
    flex-shrink: 0;
  }
  
  .cta-card {
    background: linear-gradient(135deg, var(--color-accent-primary) 0%, var(--color-accent-hover) 100%);
    border-radius: 8px;
    padding: var(--space-3xl);
    text-align: center;
  }
  
  .cta-content {
    max-width: 640px;
    margin: 0 auto;
  }
  
  .cta-content h2 {
    color: #FFFFFF;
    margin-bottom: var(--space-md);
  }
  
  .cta-content p {
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: var(--space-xl);
  }
</style>
