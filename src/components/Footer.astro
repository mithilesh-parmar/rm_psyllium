---
import { copy, getLanguage } from '../data/site';
const year = new Date().getFullYear();
const lang = getLanguage(Astro.params.lang);
const t = copy[lang];

---

<footer class="footer">
  <div class="footer-grid">
    <div class="footer-brand-col">
      <a class="footer-brand" href={`/${lang}/`} aria-label="RM Psyllium home">
        <img src="/assets/logo-footer.webp" alt="RM Psyllium" class="footer-logo" width="120" height="120" />
      </a>
      <p>{t.footerBrandDesc}</p>
      <div class="footer-contact">
        <a href="mailto:export@rmpsyllium.com">export@rmpsyllium.com</a>
        <a href="https://wa.me/918949817791" target="_blank" rel="noopener">+91 89498 17791</a>
      </div>
    </div>

    <div>
      <h2>{t.navProducts}</h2>
      <nav aria-label={t.navProducts}>
        <a href={`/${lang}/products/psyllium-husk/`}>Psyllium Husk</a>
        <a href={`/${lang}/products/psyllium-husk-powder/`}>Husk Powder</a>
        <a href={`/${lang}/products/psyllium-seeds/`}>Psyllium Seeds</a>
        <a href={`/${lang}/products/psyllium-khakha-powder/`}>Khakha Powder</a>
        <a href={`/${lang}/products/organic-psyllium/`}>Organic Psyllium</a>
        <a href={`/${lang}/products/psyllium-cattle-feed/`}>Cattle Feed</a>
      </nav>
    </div>

    <div>
      <h2>{t.footerApplications}</h2>
      <nav aria-label={t.footerApplications}>
        <a href={`/${lang}/industries/pharma-nutraceutical/`}>{t.footerPharma}</a>
        <a href={`/${lang}/industries/food-beverage-bakery/`}>{t.footerFood}</a>
        <a href={`/${lang}/industries/animal-feed/`}>{t.footerAnimalFeed}</a>
        <a href={`/${lang}/industries/industrial-personal-care/`}>{t.footerIndustrial}</a>
      </nav>
    </div>

    <div>
      <h2>{t.footerResources}</h2>
      <nav aria-label={t.footerResources}>
        <a href={`/${lang}/about/`}>{t.navAbout}</a>
        <a href={`/${lang}/blog/`}>{t.navBlog}</a>
        <a href={`/${lang}/quality/`}>{t.navQuality}</a>
        <a href={`/${lang}/faq/`}>{t.navFaq}</a>
      </nav>
    </div>

    <div>
      <h2>{t.navContact}</h2>
      <nav aria-label={t.navContact}>
        <a href="https://wa.me/918949817791" target="_blank" rel="noopener">{t.contactWaBtn}</a>
        <a href="mailto:export@rmpsyllium.com">{t.contactEmailBtn}</a>
        <a href={`/${lang}/contact/`}>{t.footerRequestQuote}</a>
        <a href={`/${lang}/contact/`}>{t.footerSampleRequest}</a>
      </nav>
    </div>
  </div>

  <div class="footer-wordmark">RM Psyllium</div>

  <div class="footer-bottom">
    <span>© <span id="footer-year">{year}</span> RM PSYLLIUM LLP · SIDDHPUR · GUJARAT · INDIA</span>
    <span>PATAN ROAD, KHALI, CHAR RASTA, NEDRA, SIDDHPUR, GUJARAT 384151</span>
  </div>
</footer>

<script>
  const el = document.getElementById('footer-year');
  if (el) el.textContent = new Date().getFullYear().toString();
</script>

<style>
  .footer {
    border-top: 1px solid var(--rule);
    background: var(--surface);
    color: var(--ink);
    padding: 72px 64px 32px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.8fr repeat(4, 1fr);
    gap: 48px;
  }

  /* brand */
  .footer-brand {
    display: inline-block;
    text-decoration: none;
  }

  .footer-logo {
    width: 110px;
    height: auto;
    object-fit: contain;
  }

  .footer-brand-col p {
    max-width: 280px;
    margin: 18px 0 0;
    color: var(--body-muted);
    font-size: 13px;
    line-height: 1.65;
  }

  .footer-code {
    margin-top: 14px;
    color: var(--muted);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 16px;
  }

  .footer-contact a {
    color: var(--ink);
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
  }

  .footer-contact a:hover {
    color: var(--accent);
  }

  /* columns */
  .footer h2 {
    margin: 0;
    color: var(--muted);
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .footer nav {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 18px;
  }

  .footer nav a {
    position: relative;
    width: fit-content;
    color: var(--ink);
    font-size: 13px;
    font-weight: 400;
    text-decoration: none;
  }

  .footer nav a::after {
    content: '';
    position: absolute;
    right: 0;
    bottom: -2px;
    left: 0;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s;
  }

  .footer nav a:hover::after {
    transform: scaleX(1);
  }

  /* wordmark */
  .footer-wordmark {
    margin-top: 72px;
    overflow: clip;
    border-top: 1px solid var(--rule);
    padding-top: 36px;
    color: var(--rule);
    font-family: var(--font-display);
    font-size: clamp(4rem, 12vw, 11rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 0.88;
    white-space: nowrap;
    user-select: none;
  }

  /* bottom bar */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 20px;
    border-top: 1px solid var(--rule);
    padding-top: 18px;
    color: var(--muted);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.06em;
  }

  @media (max-width: 1200px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr 1fr;
    }

    .footer-brand-col {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 760px) {
    .footer {
      padding: 56px 24px 28px;
    }

    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }

    .footer-brand-col {
      grid-column: 1 / -1;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 6px;
    }
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
