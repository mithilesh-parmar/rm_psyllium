---
import { getLanguage, languages } from '../data/site';

const lang = getLanguage(Astro.params.lang);
---
<header class="site-header">
  <a class="brand" href={`/${lang}/`} aria-label="RM Psyllium home">
    <span class="brand-mark" aria-hidden="true">RM</span>
    <span>
      <strong>RM Psyllium</strong>
      <small>Unjha · Gujarat · Est 2024</small>
    </span>
  </a>

  <input class="nav-toggle" id="nav-toggle" type="checkbox" aria-label="Open navigation" />
  <label class="nav-button" for="nav-toggle" aria-hidden="true">
    <span></span>
    <span></span>
    <span></span>
  </label>

  <nav class="site-nav" aria-label="Primary navigation">
    <a href={`/${lang}/products/`}>Products</a>
    <a href={`/${lang}/quality/`}>Quality</a>
    <a href={`/${lang}/insights/`}>Buyer Guides</a>
    <a href={`/${lang}/faq/`}>FAQ</a>
    <a href={`/${lang}/contact/`}>Contact</a>
    <div class="language-switcher" aria-label="Language switcher">
      {languages.map((language) => (
        <a class:list={{ active: language.code === lang }} href={`/${language.code}/`}>
          {language.code.toUpperCase()}
        </a>
      ))}
    </div>
    <a class="nav-cta" href="/#talk" data-track="quote_click">Get Quote <span aria-hidden="true"></span></a>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    height: 80px;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid rgba(26, 28, 24, 0.1);
    background: rgba(255, 255, 255, 0.92);
    padding: 0 56px;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    will-change: transform;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
  }

  .brand-mark {
    display: grid;
    width: 38px;
    height: 38px;
    place-items: center;
    border: 1px solid var(--ink);
    border-radius: 50%;
    color: var(--ink);
    font-family: var(--font-display);
    font-size: 1.18rem;
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.02em;
    text-transform: lowercase;
  }

  .brand strong,
  .brand small {
    display: block;
  }

  .brand strong {
    font-family: var(--font-display);
    font-size: 1.38rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1;
    text-transform: none;
  }

  .brand small {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.56rem;
    letter-spacing: 0.22em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 2rem;
    color: var(--ink);
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    text-transform: none;
  }

  .site-nav a:hover {
    color: var(--accent);
  }

  .language-switcher {
    display: flex;
    gap: 0.15rem;
    gap: 0.25rem;
    border-left: 1px solid var(--rule);
    padding-left: 0.25rem;
  }

  .language-switcher a {
    display: grid;
    min-width: 34px;
    min-height: 34px;
    place-items: center;
    border: 1px solid transparent;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.16em;
  }

  .language-switcher a.active {
    border-color: var(--rule);
    color: var(--ink);
  }

  .nav-cta {
    display: inline-flex;
    min-height: 40px;
    align-items: center;
    gap: 0.5rem;
    border: 0;
    border-radius: 999px;
    background: var(--ink);
    color: #fff !important;
    padding: 0 1.25rem;
  }

  .nav-cta span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: header-pulse 1.8s ease-in-out infinite;
  }

  .nav-toggle,
  .nav-button {
    display: none;
  }

  @media (max-width: 980px) {
    .site-header {
      padding: 0 1rem;
    }

    .nav-button {
      display: grid;
      width: 44px;
      height: 44px;
      place-content: center;
      gap: 5px;
      border: 1px solid var(--rule);
      border-radius: 999px;
      cursor: pointer;
    }

    .nav-button span {
      display: block;
      width: 20px;
      height: 2px;
      background: var(--dark);
    }

    .site-nav {
      position: absolute;
      inset: 80px 1rem auto 1rem;
      display: none;
      flex-direction: column;
      align-items: stretch;
      border: 1px solid var(--rule);
      border-radius: 0;
      background: #fff;
      padding: 0.9rem;
      box-shadow: 0 24px 70px rgba(27, 27, 25, 0.12);
    }

    .site-nav a {
      min-height: 44px;
      padding: 0.75rem;
    }

    .language-switcher {
      justify-content: flex-start;
      flex-wrap: wrap;
    }

    .nav-toggle:checked ~ .site-nav {
      display: flex;
    }
  }

  @keyframes header-pulse {
    0%, 100% { transform: scale(1); opacity: 0.9; }
    50% { transform: scale(1.06); opacity: 1; }
  }
</style>
