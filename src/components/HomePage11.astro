---
import { getLanguage, products, type LanguageCode } from '../data/site';

export interface Props {
  lang?: LanguageCode;
}

const lang = getLanguage(Astro.props.lang || Astro.params.lang);

const trustItems = ['COA with each shipment', 'FSSAI facility', 'Halal documents available', 'Kosher documents available', 'Organic lots on request', 'USP / EP parameter support', 'Origin certificate', 'Phyto support', 'Fumigation support', 'FOB / CIF shipments'];

const chapters = [
  {
    no: 'I',
    title: 'The seed',
    sub: 'Plantago ovata',
    body: 'Psyllium is sourced from the Gujarat and Rajasthan growing belt, close to Unjha and the export supply chain buyers already know. Each lot starts with origin and intake records.',
    stat: '120 days',
    label: 'seed to harvest',
    tone: 'sage'
  },
  {
    no: 'II',
    title: 'The land',
    sub: 'Banaskantha · Patan · Mehsana',
    body: '4,500 acres under farmer contract across Banaskantha, Patan, and Mehsana. Direct sourcing gives buyers better traceability, cleaner raw material, and fewer brokerage layers.',
    stat: '1,200+',
    label: 'contracted farmers',
    tone: 'warm'
  },
  {
    no: 'III',
    title: 'The mill',
    sub: 'GIDC Phase II, Unjha',
    body: 'A 4.2-acre facility commissioned in 2024 with cleaning, milling, grading, lab checks, and packing handled on one site. Buyers get grade, mesh, and lot documents before shipment.',
    stat: '12,000 MT',
    label: 'annual capacity',
    tone: 'sage'
  },
  {
    no: 'IV',
    title: 'The world',
    sub: 'Thirty-eight countries · one operator',
    body: 'FOB Mundra and CIF shipments available. Export support includes COA, packing list, certificate of origin, phyto, fumigation, and shipment paperwork aligned to the buyer market.',
    stat: '38',
    label: 'export markets',
    tone: 'warm'
  }
];

const machines = [
  { code: 'M01', name: 'Roller mill line 02', mfr: 'Buhler · Switzerland', specs: [['Throughput', '500 kg/hr'], ['Gap control', 'PLC +/-5um'], ['Wear life', '8,000 hr']], note: 'Controls mesh consistency across bulk lots. No chemical bleaching or acid de-husking.', tone: 'paper' },
  { code: 'M02', name: 'Air classifier', mfr: 'Hosokawa · Germany', specs: [['Cut size', '25-150um'], ['Capacity', '800 kg/hr'], ['Yield', '99.4%']], note: 'Separates husk and powder grades for buyer-selected mesh and application requirements.', tone: 'paper' },
  { code: 'M03', name: 'NIR spectrometer', mfr: 'FOSS NIRS DS2500', specs: [['Wavelength', '400-2500 nm'], ['Scan time', '8 sec'], ['Library', '12,400 spectra']], note: 'Checks sub-batches so lot quality can be reviewed before export packing.', tone: 'sage' },
  { code: 'M04', name: 'HPLC bench', mfr: 'Agilent 1260 Infinity II', specs: [['Columns', '4 x Zorbax'], ['Detection', 'UV-DAD + RID'], ['Run time', '11 min']], note: 'Supports purity, ash, and swelling-volume review for technical buyers.', tone: 'sage' },
  { code: 'M05', name: 'Magnetic separator', mfr: 'Eriez · India', specs: [['Field strength', '12,000 G'], ['Throughput', '2 MT/hr'], ['Catch', '< 50 um Fe']], note: 'Removes ferrous contamination before milling and supports cleaner COA results.', tone: 'paper' },
  { code: 'M06', name: 'De-stoner + sieve', mfr: 'Cimbria · Denmark', specs: [['Capacity', '3 MT/hr'], ['Foreign matter', '< 0.5%'], ['Sieve decks', '5']], note: 'Removes field debris and oversized material before grading.', tone: 'paper' },
  { code: 'M07', name: 'Storage silos x 8', mfr: 'GSI · India', specs: [['Capacity', '8,400 MT'], ['Aeration', 'Active 24/7'], ['Sensors', 'Temp + RH per silo']], note: 'Separate storage by grade and mesh reduces cross-mixing risk before packing.', tone: 'warm' },
  { code: 'M08', name: 'Big-bag filler', mfr: 'Spiroflow · UK', specs: [['Speed', '24 bags/hr'], ['Accuracy', '+/-0.1%'], ['Bag sizes', '500 / 1,000 kg']], note: 'Supports 25kg bags, 500kg bags, and 1,000kg bulk packing for export buyers.', tone: 'warm' }
];

const stages = ['Seed', 'Clean', 'Condition', 'Mill', 'Grade', 'NIR', 'Lab', 'Pack', 'Ship'];

const processSteps = [
  ['Sourcing', 'Seed is sourced from contracted growers across Banaskantha, Patan, and Mehsana with origin records kept by lot.'],
  ['Pre-clean', 'Magnetic separation, de-stoner, and sieve cleaning reduce foreign matter before milling.'],
  ['Conditioning', 'Controlled conditioning prepares seed for husk separation while protecting functional performance.'],
  ['Milling', 'Roller mills separate husk without chemical bleaching or acid treatment.'],
  ['Grading', 'Air classification and sieving produce 30 / 40 / 60 / 80 / 100 mesh options for buyer applications.'],
  ['NIR check', 'Sub-batches are scanned and reviewed before lab and packing release.'],
  ['Lab review', 'Purity, swelling volume, moisture, ash, microbiology, and heavy-metal parameters can be documented.'],
  ['Packing', 'Food-grade 25kg bags, 500kg bags, 1,000kg bags, and private-label packing options are available.'],
  ['Documentation', 'COA, origin certificate, phyto, fumigation, MSDS, allergen statement, and packing list can be shared before shipment.']
];

const productRows = [
  { code: 'PSH-99', name: 'Husk · 99%', use: 'Pharma · clinical · USP/EP', mesh: '30 / 40', accent: true },
  { code: 'PSH-98', name: 'Husk · 98%', use: 'Premium nutraceutical', mesh: '40 / 60' },
  { code: 'PSH-95', name: 'Husk · 95%', use: 'General supplement & food', mesh: '40 / 60 / 80' },
  { code: 'PSH-85', name: 'Husk · 85%', use: 'Bulk food & industrial fibre', mesh: '40 / 60 / 80' },
  { code: 'PHP-98', name: 'Husk Powder · 98%', use: 'Pharma drink mixes, fine bakery', mesh: '80 / 100' },
  { code: 'PHP-95', name: 'Husk Powder · 95%', use: 'Drink mixes, bakery, fibre', mesh: '80 / 100 / 200' },
  { code: 'PHP-85', name: 'Husk Powder · 85%', use: 'Cost-effective bulk fibre', mesh: '80 / 100 / 200' },
  { code: 'PSD-WH', name: 'Whole Seed', use: 'Pet food, milling, sowing', mesh: '-' },
  { code: 'PSI-IN', name: 'Industrial Powder', use: 'Drilling mud, paint binders', mesh: '60 / 80' },
  { code: 'PCF-CT', name: 'Cattle Feed', use: 'Dairy & livestock nutrition', mesh: 'Granular' },
  { code: 'PSP-RX', name: 'Pharma Grade', use: 'OTC laxatives, formulations', mesh: '30 / 40', accent: true },
  { code: 'PSF-FD', name: 'Food Grade', use: 'Cereal, bakery, gluten-free', mesh: '40 / 60' },
  { code: 'PSO-OR', name: 'Organic Range', use: 'USDA / EU pending', mesh: '40 / 60 / 80' }
];

const coaRows = [
  ['Purity (husk)', '>= 99.0%', '99.4%'],
  ['Swelling volume', '>= 45 ml/g', '47.2 ml/g'],
  ['Moisture', '<= 10%', '8.1%'],
  ['Total ash', '<= 3.0%', '2.4%'],
  ['Heavy metals (total)', '<= 10 ppm', '2.1 ppm'],
  ['Salmonella / 25g', 'Absent', 'Absent'],
  ['E. coli / 10g', 'Absent', 'Absent'],
  ['Aflatoxin total', '<= 4 ppb', '< 0.5 ppb'],
  ['Pesticide (EU MRL)', 'Conforms', 'Conforms'],
  ['Extraneous matter', '<= 0.5%', '0.18%']
];

const lessons = [
  { tag: 'PSYLLIUM 101', title: 'What is psyllium husk?', desc: 'The seed coat of Plantago ovata. Mostly soluble fibre. When it meets water, it forms a clear gel - the property that drives both pharma and food applications.', read: '4 min' },
  { tag: 'BUYING GUIDE', title: 'Purity grades, decoded', desc: '95%, 98%, 99% - what those numbers actually mean, why pharma needs 99% and food rarely does.', read: '6 min' },
  { tag: 'BUYING GUIDE', title: 'Mesh size, decoded', desc: 'Why a 40-mesh husk gels faster than a 60-mesh, and why a drink-mix formulator wants 80 mesh while a tablet press wants 30.', read: '5 min' },
  { tag: 'COMPLIANCE', title: 'USP vs. EP vs. IP', desc: 'Three pharmacopoeias, three methods, three slightly different swelling-volume targets. How we test against all three for every pharma-grade lot.', read: '7 min' },
  { tag: 'INDUSTRY', title: 'Why prices move', desc: 'Psyllium is monsoon-dependent. We index long-term contracts to a 3-year rolling average so your costing stays sane.', read: '5 min' },
  { tag: 'LOGISTICS', title: 'Mundra to anywhere, by the day', desc: 'How long FOB takes, what fumigation involves, when to ask for EUR.1, and why you should never agree to loose container stuffing.', read: '8 min' }
];
---

<div class="variant-g-home">
  <section class="g-hero" id="top">
    <div class="g-glow" aria-hidden="true"></div>
    <div class="g-hero-grid">
      <div class="g-hero-copy reveal">
        <div class="g-badge"><span></span>Bulk psyllium exporter · Gujarat, India</div>
        <h1>Bulk psyllium<br /><em>husk, powder</em><br />and seed exports.</h1>
        <p>
          Source psyllium husk, husk powder, seeds, khakha powder, and cattle feed with buyer-specific grade, mesh, packing, COA, and export documentation.
        </p>
        <div class="g-actions">
          <a class="g-btn g-btn-dark" href="#talk">Request bulk quote <span aria-hidden="true">→</span></a>
          <a class="g-btn g-btn-ghost" href="/playbook-rm-psyllium.pdf">Download product specs</a>
          <a class="g-text-link" href="#products">View grades and mesh</a>
        </div>
      </div>

      <div class="g-hero-media reveal">
        <figure>
          <img src="https://images.unsplash.com/photo-1500382017468-9049fed747ef?auto=format&fit=crop&w=1200&q=80" alt="Golden grain fields at dawn" loading="eager" decoding="async" />
          <figcaption>Banaskantha · harvest at dawn</figcaption>
        </figure>
        <aside class="g-how-card">
          <div class="g-card-head"><span><i></i>HOW IT WORKS</span><small>3 steps</small></div>
          <strong>From enquiry to <em>first container.</em></strong>
          <ol>
            <li><span>01</span><p><b>Spec</b><small>grade · mesh · volume · port</small></p></li>
            <li><span>02</span><p><b>Sample</b><small>250g sample and COA review</small></p></li>
            <li><span>03</span><p><b>Quote</b><small>FOB / CIF options and lead time</small></p></li>
          </ol>
          <a href="#talk">Send your buying requirement <span>→</span></a>
        </aside>
      </div>
    </div>
  </section>

  <section class="g-trust" aria-label="Compliance stack">
    <div class="g-trust-head">
      <span>Buyer documents</span><i></i><span>Shared by lot and destination market</span>
    </div>
    <div class="g-marquee">
      {[...trustItems, ...trustItems, ...trustItems].map((item) => <span>{item}<b>✦</b></span>)}
    </div>
  </section>

  <section class="g-section g-white" id="story">
    <div class="g-section-line"><span>Supply base</span><i></i></div>
    <h2 class="g-heading">Direct sourcing,<br />controlled milling, and <em>export documents.</em></h2>
    <div class="g-chapters">
      {chapters.map((chapter, index) => (
        <article class="g-chapter reveal">
          <div>
            <span class="g-roman">{chapter.no}</span>
            <small>0{index + 1} / 04</small>
          </div>
          <div>
            <h3>{chapter.title}</h3>
            <span>{chapter.sub}</span>
            <p>{chapter.body}</p>
            <div class="g-stat"><strong>{chapter.stat}</strong><small>{chapter.label}</small></div>
          </div>
          <div class:list={['g-placeholder', `tone-${chapter.tone}`]}><span>Chapter {index + 1} · {chapter.title.toLowerCase()}</span></div>
        </article>
      ))}
    </div>
  </section>

  <section class="g-section g-paper" id="facility">
    <div class="g-section-line"><span>Facility</span><i></i></div>
    <div class="g-split-head">
      <h2 class="g-heading">One site for<br />cleaning, milling, <em>testing</em> and packing.</h2>
      <p>
        Buyers need consistent grade, mesh, packing, and documents. Our line is built to keep raw material, processing, lab review, and export packing tied to the same lot.
      </p>
    </div>
    <div class="g-machines">
      {machines.map((machine, index) => (
        <article class:list={['g-machine', 'reveal', index % 2 ? 'is-reversed' : '']}>
          <div class:list={['g-placeholder', 'g-machine-art', `tone-${machine.tone}`]}><span>{machine.code} · {machine.name.toLowerCase()}</span><b>{machine.code}</b></div>
          <div class="g-machine-copy">
            <div class="g-machine-step"><strong>0{index + 1}</strong><span>Step {index + 1} of {machines.length}</span></div>
            <h3>{machine.name}</h3>
            <small>{machine.mfr}</small>
            <p>{machine.note}</p>
            <div class="g-specs">
              {machine.specs.map(([label, value]) => (
                <span><small>{label}</small><b>{value}</b></span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
    <div class="g-tour">
      <div><strong>Need technical review?</strong><p>Send grade, mesh, monthly volume, packaging, and destination port. We will respond with matching product options.</p></div>
      <a class="g-btn g-btn-sage" href="#talk">Request technical quote</a>
    </div>
  </section>

  <section class="g-section g-white" id="process">
    <div class="g-section-line"><span>The process</span><i></i><span>9 steps · one export lot</span></div>
    <h2 class="g-heading">From <em>seed</em><br />to export-ready packing.</h2>
    <div class="g-flow-card reveal">
      <div class="g-flow-head"><span>Process flow</span><small>9 stages · lot-level review</small></div>
      <div class="g-phase-grid">
        <div><b>Seed</b><span>Whole · cleaned · conditioned</span></div>
        <div><b>Split</b><span>Husk ↔ kernel</span></div>
        <div><b>Husk</b><span>Graded · NIR-tested · lab-validated</span></div>
        <div><b>Packed</b><span>Shipped</span></div>
      </div>
      <div class="g-flow-line">
        {stages.map((stage, index) => (
          <div class="g-stage" style={`--i:${index}`}>
            <span>0{index + 1}</span>
            <b>{stage}</b>
          </div>
        ))}
      </div>
      <div class="g-flow-caption"><span><i class="warm"></i>seed material</span><span><i class="sage"></i>graded husk</span><span>cycle · 9s</span></div>
    </div>
    <div class="g-timeline">
      {processSteps.map(([title, desc], index) => (
        <article class="g-row reveal">
          <span class="g-dot"></span>
          <div><small>STEP 0{index + 1}</small><strong>{title}</strong></div>
          <p>{desc}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="g-section g-cream" id="products">
    <div class="g-section-line"><span>Products</span><i></i><span>Grades, mesh, packing, and private label on request</span></div>
    <div class="g-split-head">
      <h2 class="g-heading">Psyllium products<br />for bulk <em>buyers.</em></h2>
      <p>
        Choose whole husk, husk powder, seeds, khakha powder, cattle feed, organic lots, and private-label packing. We align purity, mesh, documents, and shipping terms before quote.
      </p>
    </div>
    <div class="g-product-table">
      {productRows.map((product, index) => (
        <a class="g-product-row g-row reveal" href={`/${lang}/products/${products[index % products.length].slug}/`}>
          <span>{product.code}</span>
          <strong>{product.name}{product.accent && <small>FLAGSHIP</small>}</strong>
          <p>{product.use}</p>
          <em>MESH · {product.mesh}</em>
          <b aria-hidden="true">→</b>
        </a>
      ))}
    </div>
  </section>

  <section class="g-section g-white" id="quality">
    <div class="g-section-line"><span>Quality</span><i></i><span>COA and export documents by shipment</span></div>
    <div class="g-quality-grid">
      <div class="reveal">
        <h2 class="g-heading">Documents<br />buyers need<br /><em>before shipment.</em></h2>
        <p>Each approved shipment can include COA, packing list, certificate of origin, phytosanitary certificate, fumigation certificate, MSDS, allergen statement, and lot details.</p>
        <div class="g-actions"><a class="g-btn g-btn-sage" href="/compliance/">Review documents →</a><a class="g-text-link" href="/en/insights/husk-vs-powder-buyer-guide/">Choose husk vs powder</a></div>
      </div>
      <div class="g-coa reveal">
        <header><div><small>COA · SAMPLE</small><strong>Lot RM-26-0512 · Husk 99%</strong></div><span>● PASS</span></header>
        <div class="g-coa-head"><span>Parameter</span><span>Spec</span><span>Result</span></div>
        {coaRows.map(([parameter, spec, result]) => (
          <div class="g-coa-row"><span>{parameter}</span><span>{spec}</span><strong>{result}</strong></div>
        ))}
        <footer><span>+ 37 more parameters on the full COA</span><span>SGS Ref · GJ-26-0512-A</span></footer>
      </div>
    </div>
  </section>

  <section class="g-section g-paper" id="education">
    <div class="g-section-line"><span>Buyer guides</span><i></i><span>Specs, grades, mesh, and logistics</span></div>
    <div class="g-split-head">
      <h2 class="g-heading">Choose the right<br />grade, mesh, and <em>packing.</em></h2>
      <p>
        Use these guides to compare husk vs powder, purity grades, mesh size, testing parameters, and export paperwork before you request samples or pricing.
      </p>
    </div>
    <div class="g-lessons">
      {lessons.map((lesson) => (
        <a class="g-card reveal" href="/en/insights/husk-vs-powder-buyer-guide/">
          <div><span>{lesson.tag}</span><small>{lesson.read}</small></div>
          <h3>{lesson.title}</h3>
          <p>{lesson.desc}</p>
          <b>Read the brief →</b>
        </a>
      ))}
    </div>
  </section>

  <section class="g-numbers">
    <div class="g-section-line"><span>Supply capacity</span><i></i><span>For bulk procurement review</span></div>
    <div class="g-number-grid">
      <div><strong>12,000</strong><span>MT</span><p>Annual milling capacity</p></div>
      <div><strong>4,500</strong><span>acres</span><p>Under farmer contract</p></div>
      <div><strong>38</strong><span>mkt</span><p>Export destinations</p></div>
      <div><strong>47</strong><span>tests</span><p>Per shipment COA</p></div>
    </div>
  </section>

  <section class="g-section g-cream">
    <div class="g-section-line"><span>Export team</span><i></i></div>
    <div class="g-founder">
      <div class="g-placeholder tone-warm"><span>Founder · Ramji Mehta · Unjha</span></div>
      <div class="reveal">
        <blockquote>
          "Tell us the grade, mesh, packing, monthly volume, and destination port. We will confirm what fits, what documents are available, and how quickly samples can move."
        </blockquote>
        <cite>- RM Psyllium export desk · Unjha, Gujarat</cite>
        <div class="g-history">
          {[
            ['1983', 'Mehta family begins trading psyllium at Unjha APMC'],
            ['1989', 'First container exported to West Germany'],
            ['2007', 'Banaskantha farmer-contract programme begins'],
            ['2019', 'In-house NIR & HPLC lab commissioned'],
            ['2024', 'RM Psyllium facility opens - 12,000 MT/yr'],
            ['2026', 'Direct relationships in 38 export markets']
          ].map(([year, event]) => <><span>{year}</span><p>{event}</p></>)}
        </div>
      </div>
    </div>
  </section>

  <section class="g-section g-white" id="talk">
    <div class="g-contact-grid">
      <div class="reveal">
        <div class="g-section-line"><span>Talk</span><i></i></div>
        <h2 class="g-heading">Request a<br /><em>bulk quote.</em></h2>
        <p>Send product, grade, mesh, monthly volume, destination port, and packing requirement. We will reply with availability, sample options, documents, and indicative pricing.</p>
        <div class="g-contact-links">
          <a class="g-row" href="/#talk"><span><strong>Request quote and samples</strong><small>grade · mesh · volume · destination</small></span><b>→</b></a>
          <a class="g-row" href="mailto:export@rmpsyllium.com"><span><strong>Email export@rmpsyllium.com</strong><small>send spec sheet or purchase requirement</small></span><b>→</b></a>
          <a class="g-row" href="https://wa.me/912767333444"><span><strong>WhatsApp +91 2767 333 444</strong><small>share product, volume, and port</small></span><b>→</b></a>
        </div>
      </div>
      <form class="g-quote reveal" name="spec-builder" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/thank-you?intent=spec">
        <input type="hidden" name="form-name" value="spec-builder" />
        <p hidden><label>Bot: <input name="bot-field" /></label></p>
        <header><span>Request a quote</span><small>● export desk</small></header>
        <div class="g-form-grid">
          {['Name', 'Company', 'Country', 'Email', 'Phone (or WhatsApp)', 'Volume per month (MT)'].map((field) => (
            <label><span>{field}</span><input name={field.toLowerCase().replaceAll(' ', '-').replaceAll('(', '').replaceAll(')', '')} required={field === 'Name' || field === 'Email'} /></label>
          ))}
        </div>
        <label class="g-product-interest">
          <span>Product interest</span>
          <select name="product" required>
            {productRows.map((product) => <option value={product.code}>{product.name}</option>)}
          </select>
        </label>
        <label>
          <span>Spec, port, or document needs</span>
          <textarea name="message" rows="3"></textarea>
        </label>
        <button class="g-btn g-btn-dark" type="submit">Send buying requirement <span>→</span></button>
        <p>Prefer email? export@rmpsyllium.com</p>
      </form>
    </div>
  </section>
</div>

<style>
  .variant-g-home {
    --g-white: #ffffff;
    --g-paper: #fafaf7;
    --g-cream: #f5f3ec;
    --g-cream-deep: #ece9df;
    --g-ink: #1a1c18;
    --g-soft: #4a4f44;
    --g-mute: #7a7e72;
    --g-rule: rgba(26, 28, 24, 0.1);
    --g-rule-soft: rgba(26, 28, 24, 0.05);
    --g-sage: #5f7044;
    --g-sage-deep: #42542c;
    --g-sage-pale: #dfe4cf;
    --g-warm: #b8753a;
    --g-warm-pale: #f1dfc8;
    background: var(--g-white);
    color: var(--g-ink);
    font-family: var(--font-body);
    overflow-wrap: anywhere;
    overflow-x: clip;
  }

  .g-hero,
  .g-section,
  .g-numbers {
    padding: clamp(5.5rem, 9vw, 8.75rem) 64px;
  }

  .g-hero {
    position: relative;
    overflow: clip;
    background: var(--g-white);
    padding-top: 64px;
    padding-bottom: 96px;
  }

  .g-glow {
    position: absolute;
    top: -20%;
    right: -15%;
    width: 700px;
    height: 700px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--g-sage-pale) 0%, transparent 70%);
    opacity: 0.55;
    animation: g-drift 22s ease-in-out infinite;
    pointer-events: none;
  }

  .g-hero-grid,
  .g-quality-grid,
  .g-contact-grid,
  .g-founder,
  .g-split-head {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(340px, 1fr);
    gap: clamp(3rem, 5vw, 5rem);
    align-items: end;
  }

  .g-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    width: fit-content;
    border: 1px solid var(--g-sage-pale);
    border-radius: 999px;
    background: rgba(223, 228, 207, 0.3);
    padding: 7px 14px;
    color: var(--g-sage);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .g-badge span,
  .g-card-head i {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--g-sage);
    animation: g-pulse 1.8s ease-in-out infinite;
  }

  .g-hero h1,
  .g-heading {
    margin: 0;
    color: var(--g-ink);
    font-family: var(--font-display);
    font-size: clamp(4.4rem, 8.6vw, 7.75rem);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 0.96;
    text-wrap: balance;
  }

  .g-hero h1 {
    margin-top: 28px;
  }

  .variant-g-home em {
    color: var(--g-sage);
    font-style: italic;
  }

  .g-hero p,
  .g-split-head p,
  .g-quality-grid p,
  .g-contact-grid p {
    max-width: 540px;
    margin: 28px 0 0;
    color: var(--g-soft);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.6;
  }

  .g-hero p {
    margin-top: 36px;
    font-size: 19px;
    line-height: 1.55;
  }

  .g-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 14px;
    margin-top: 36px;
  }

  .g-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    border: 1px solid transparent;
    border-radius: 999px;
    padding: 14px 24px;
    font-size: 14px;
    font-weight: 500;
    line-height: 1;
    text-decoration: none;
    transition: transform 0.25s cubic-bezier(.2, .7, .3, 1), box-shadow 0.25s, background 0.2s;
  }

  .g-btn:hover,
  .g-card:hover,
  .g-machine-art:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 40px -22px rgba(26, 28, 24, 0.25);
  }

  .g-btn-dark {
    background: var(--g-ink);
    color: var(--g-white);
  }

  .g-btn-ghost {
    border-color: var(--g-rule);
    background: transparent;
    color: var(--g-ink);
  }

  .g-btn-sage {
    background: var(--g-sage);
    color: var(--g-white);
  }

  .g-text-link {
    position: relative;
    color: var(--g-ink);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
  }

  .g-text-link::after,
  .g-card b::after {
    content: "";
    position: absolute;
    right: 0;
    bottom: -3px;
    left: 0;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s cubic-bezier(.2, .7, .3, 1);
  }

  .g-text-link:hover::after,
  .g-card:hover b::after {
    transform: scaleX(1);
  }

  .g-hero-media {
    position: relative;
  }

  .g-hero-media figure {
    position: relative;
    margin: 0;
    aspect-ratio: 4 / 5;
    overflow: clip;
    background: var(--g-sage-pale);
  }

  .g-hero-media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .g-hero-media figcaption,
  .g-placeholder span {
    position: absolute;
    left: 16px;
    bottom: 14px;
    color: rgba(255, 255, 255, 0.92);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.4);
    text-transform: uppercase;
  }

  .g-how-card {
    position: absolute;
    bottom: -32px;
    left: -32px;
    width: 320px;
    border: 1px solid var(--g-rule);
    background: var(--g-white);
    padding: 22px 24px 20px;
    box-shadow: 0 12px 28px -16px rgba(26, 28, 24, 0.18);
  }

  .g-card-head,
  .g-flow-head,
  .g-coa header,
  .g-quote header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .g-card-head span,
  .g-card-head small,
  .g-flow-head span,
  .g-flow-head small,
  .g-quote header,
  .g-section-line {
    color: var(--g-mute);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .g-card-head span {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--g-sage);
  }

  .g-how-card > strong {
    display: block;
    margin-top: 16px;
    color: var(--g-ink);
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 500;
    letter-spacing: -0.015em;
    line-height: 1.05;
  }

  .g-how-card ol {
    display: grid;
    gap: 14px;
    margin: 18px 0 0;
    padding: 0;
    list-style: none;
  }

  .g-how-card li {
    display: flex;
    align-items: baseline;
    gap: 14px;
  }

  .g-how-card li > span {
    min-width: 22px;
    color: var(--g-sage);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
  }

  .g-how-card p {
    margin: 0;
  }

  .g-how-card b {
    display: block;
    color: var(--g-ink);
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 500;
  }

  .g-how-card small {
    display: block;
    margin-top: 2px;
    color: var(--g-mute);
    font-size: 12px;
  }

  .g-how-card > a {
    display: flex;
    justify-content: space-between;
    margin-top: 18px;
    border-radius: 999px;
    background: var(--g-ink);
    padding: 11px 16px;
    color: var(--g-white);
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
  }

  .g-trust {
    overflow: clip;
    border-top: 1px solid var(--g-rule);
    border-bottom: 1px solid var(--g-rule);
    background: var(--g-cream);
    padding: 32px 0;
  }

  .g-trust-head {
    display: flex;
    align-items: center;
    gap: 56px;
    margin-bottom: 20px;
    padding: 0 56px;
    color: var(--g-mute);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .g-trust-head i,
  .g-section-line i {
    height: 1px;
    max-width: 480px;
    flex: 1;
    background: var(--g-rule);
  }

  .g-marquee {
    display: flex;
    width: max-content;
    white-space: nowrap;
    animation: g-marquee 48s linear infinite;
  }

  .g-marquee span {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    padding-right: 56px;
    color: var(--g-ink);
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 400;
    letter-spacing: -0.01em;
  }

  .g-marquee b {
    color: var(--g-sage);
    font-size: 14px;
  }

  .g-white {
    background: var(--g-white);
  }

  .g-paper {
    background: var(--g-paper);
  }

  .g-cream {
    background: var(--g-cream);
  }

  .g-section-line {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 32px;
    color: var(--g-sage);
  }

  .g-section-line span:last-child:not(:first-child) {
    color: var(--g-mute);
  }

  .g-section > .g-heading {
    max-width: 1100px;
    margin-bottom: 80px;
    font-size: clamp(3.8rem, 6vw, 5rem);
    line-height: 0.98;
  }

  .g-chapters,
  .g-machines {
    display: flex;
    flex-direction: column;
  }

  .g-chapter {
    display: grid;
    grid-template-columns: 120px minmax(0, 1fr) minmax(320px, 1.1fr);
    gap: 56px;
    align-items: start;
    border-top: 1px solid var(--g-rule);
    padding: 40px 0;
  }

  .g-chapter:last-child,
  .g-machine:last-child {
    border-bottom: 1px solid var(--g-rule);
  }

  .g-roman,
  .g-machine-step strong {
    display: block;
    color: var(--g-sage);
    font-family: var(--font-display);
    font-size: 56px;
    font-style: italic;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .g-chapter small,
  .g-machine-step span,
  .g-chapter > div:nth-child(2) > span,
  .g-machine-copy > small,
  .g-specs small,
  .g-timeline small,
  .g-product-row em,
  .g-product-row > span {
    display: block;
    color: var(--g-mute);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .g-chapter h3,
  .g-machine h3 {
    margin: 0;
    color: var(--g-ink);
    font-family: var(--font-display);
    font-size: clamp(2.7rem, 4.6vw, 3.5rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.05;
  }

  .g-chapter p,
  .g-machine p {
    margin: 20px 0 0;
    color: var(--g-soft);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.6;
  }

  .g-stat {
    display: flex;
    align-items: baseline;
    gap: 14px;
    margin-top: 24px;
  }

  .g-stat strong {
    color: var(--g-ink);
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 500;
    letter-spacing: -0.02em;
  }

  .g-placeholder {
    position: relative;
    width: 100%;
    aspect-ratio: 5 / 4;
    overflow: clip;
    background-color: var(--g-cream);
    background-image: repeating-linear-gradient(135deg, rgba(26, 28, 24, 0.06) 0 1px, transparent 1px 18px);
  }

  .g-placeholder span {
    color: rgba(26, 28, 24, 0.55);
    text-shadow: none;
  }

  .tone-sage {
    background-color: var(--g-sage-pale);
    background-image: repeating-linear-gradient(135deg, rgba(66, 84, 44, 0.18) 0 1px, transparent 1px 18px);
  }

  .tone-warm {
    background-color: var(--g-warm-pale);
    background-image: repeating-linear-gradient(135deg, rgba(184, 117, 58, 0.22) 0 1px, transparent 1px 18px);
  }

  .tone-paper {
    background-color: var(--g-paper);
    background-image: repeating-linear-gradient(135deg, rgba(26, 28, 24, 0.05) 0 1px, transparent 1px 18px);
  }

  .g-split-head {
    margin-bottom: 56px;
  }

  .g-split-head .g-heading {
    font-size: clamp(3.8rem, 6vw, 5rem);
    line-height: 0.98;
  }

  .g-split-head p {
    margin: 0;
  }

  .g-machine {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    border-top: 1px solid var(--g-rule);
    padding: 56px 0;
  }

  .g-machine.is-reversed .g-machine-art {
    order: 2;
  }

  .g-machine.is-reversed .g-machine-copy {
    order: 1;
  }

  .g-machine-art {
    transition: transform 0.4s cubic-bezier(.2, .7, .3, 1), box-shadow 0.4s;
  }

  .g-machine-art b {
    position: absolute;
    top: 14px;
    left: 14px;
    background: rgba(26, 28, 24, 0.78);
    padding: 5px 10px;
    color: var(--g-white);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.2em;
  }

  .g-machine-step {
    display: flex;
    align-items: baseline;
    gap: 18px;
    margin-bottom: 14px;
  }

  .g-machine-copy > small {
    margin-top: 12px;
    color: var(--g-sage);
  }

  .g-specs {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin-top: 28px;
    border-top: 1px solid var(--g-rule);
    padding-top: 18px;
  }

  .g-specs span {
    border-left: 1px solid var(--g-rule-soft);
    padding: 0 20px;
  }

  .g-specs span:first-child {
    border-left: 0;
    padding-left: 0;
  }

  .g-specs b {
    display: block;
    margin-top: 6px;
    color: var(--g-ink);
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.015em;
  }

  .g-tour {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    margin-top: 80px;
    border: 1px solid var(--g-rule);
    background: var(--g-white);
    padding: 32px 36px;
  }

  .g-tour strong {
    color: var(--g-ink);
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 500;
    letter-spacing: -0.015em;
  }

  .g-tour p {
    margin: 6px 0 0;
    color: var(--g-mute);
    font-size: 14px;
  }

  .g-flow-card,
  .g-coa,
  .g-quote {
    border: 1px solid var(--g-rule);
    background: var(--g-white);
  }

  .g-flow-card {
    margin-bottom: 96px;
    padding: 56px 48px 40px;
    overflow: clip;
  }

  .g-phase-grid {
    display: grid;
    grid-template-columns: 3fr 1fr 3fr 2fr;
    margin: 36px 0 24px;
  }

  .g-phase-grid div {
    border-right: 1px solid var(--g-rule-soft);
    background: var(--g-sage-pale);
    padding: 14px 18px;
  }

  .g-phase-grid div:nth-child(1) {
    background: var(--g-warm-pale);
  }

  .g-phase-grid div:nth-child(2) {
    background: var(--g-cream);
  }

  .g-phase-grid div:nth-child(4) {
    border-right: 0;
    background: var(--g-cream-deep);
  }

  .g-phase-grid b,
  .g-phase-grid span {
    display: block;
    font-size: 12px;
  }

  .g-phase-grid b {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .g-flow-line {
    position: relative;
    display: grid;
    grid-template-columns: repeat(9, 1fr);
    gap: 0;
    min-width: 720px;
    padding: 0 24px 40px;
  }

  .g-flow-line::before,
  .g-flow-line::after {
    content: "";
    position: absolute;
    top: 30px;
    right: 4%;
    left: 4%;
    height: 2px;
    border-radius: 2px;
  }

  .g-flow-line::before {
    background: var(--g-rule-soft);
  }

  .g-flow-line::after {
    background: linear-gradient(90deg, var(--g-warm), var(--g-sage), var(--g-ink));
    opacity: 0.45;
  }

  .g-stage {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    flex-direction: column;
    gap: 12px;
  }

  .g-stage span {
    display: grid;
    width: 60px;
    height: 60px;
    place-items: center;
    border: 1.5px solid var(--g-rule);
    border-radius: 50%;
    background: var(--g-white);
    color: var(--g-sage);
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    animation: g-stage-glow 9s ease-in-out infinite;
    animation-delay: calc(var(--i) * 1s - 0.2s);
  }

  .g-stage b {
    color: var(--g-ink);
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .g-flow-caption {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    border-top: 1px solid var(--g-rule-soft);
    padding-top: 24px;
    color: var(--g-mute);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
  }

  .g-flow-caption span {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .g-flow-caption i {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .g-flow-caption .warm {
    background: var(--g-warm);
  }

  .g-flow-caption .sage {
    background: var(--g-sage);
  }

  .g-timeline {
    position: relative;
    max-width: 980px;
    margin-inline: auto;
  }

  .g-timeline::before {
    content: "";
    position: absolute;
    top: 12px;
    bottom: 12px;
    left: 26px;
    width: 1px;
    background: var(--g-rule);
  }

  .g-row {
    transition: background 0.2s;
  }

  .g-row:hover {
    background: rgba(95, 112, 68, 0.05);
  }

  .g-timeline article {
    position: relative;
    display: grid;
    grid-template-columns: 54px 110px 1fr;
    gap: 28px;
    align-items: start;
    border-top: 1px solid var(--g-rule-soft);
    padding: 28px 24px 28px 0;
  }

  .g-timeline article:first-child {
    border-top: 0;
  }

  .g-dot {
    position: relative;
    z-index: 2;
    display: block;
    width: 14px;
    height: 14px;
    margin: 10px auto 0;
    border: 2px solid var(--g-sage);
    border-radius: 50%;
    background: var(--g-white);
    box-shadow: 0 0 0 6px var(--g-white);
  }

  .g-timeline strong {
    display: block;
    color: var(--g-ink);
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.05;
  }

  .g-timeline p {
    margin: 8px 0 0;
    max-width: 640px;
    color: var(--g-soft);
    font-size: 16px;
    line-height: 1.6;
  }

  .g-product-table {
    border: 1px solid var(--g-rule);
    background: var(--g-white);
  }

  .g-product-row {
    display: grid;
    grid-template-columns: 110px 1.6fr 1.6fr 1fr 50px;
    gap: 24px;
    align-items: center;
    border-top: 1px solid var(--g-rule-soft);
    padding: 24px 28px;
    color: var(--g-ink);
    text-decoration: none;
  }

  .g-product-row:first-child {
    border-top: 0;
  }

  .g-product-row > span {
    color: var(--g-sage);
  }

  .g-product-row strong {
    display: flex;
    align-items: baseline;
    gap: 12px;
    color: var(--g-ink);
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 500;
    letter-spacing: -0.015em;
    line-height: 1.05;
  }

  .g-product-row strong small {
    border-radius: 4px;
    background: var(--g-warm-pale);
    padding: 3px 8px;
    color: var(--g-warm);
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 400;
    letter-spacing: 0.16em;
  }

  .g-product-row p {
    margin: 0;
    color: var(--g-soft);
    font-size: 14px;
  }

  .g-product-row b {
    color: var(--g-sage);
    font-size: 18px;
    font-weight: 400;
    text-align: right;
    opacity: 0;
    transition: transform 0.25s, opacity 0.25s;
  }

  .g-product-row:hover b,
  .g-contact-links a:hover b {
    transform: translateX(6px);
    opacity: 1;
  }

  .g-quality-grid {
    align-items: start;
  }

  .g-quality-grid .g-heading {
    font-size: clamp(3.8rem, 6vw, 5rem);
  }

  .g-coa {
    background: var(--g-paper);
    padding: 24px 28px;
  }

  .g-coa header {
    border-bottom: 1px solid var(--g-rule);
    padding-bottom: 16px;
  }

  .g-coa header small,
  .g-coa-head,
  .g-coa footer {
    color: var(--g-mute);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .g-coa header strong {
    display: block;
    margin-top: 4px;
    color: var(--g-ink);
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.01em;
    text-transform: none;
  }

  .g-coa header > span {
    border-radius: 999px;
    background: var(--g-sage);
    padding: 6px 12px;
    color: var(--g-white);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.18em;
  }

  .g-coa-head,
  .g-coa-row {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 16px;
  }

  .g-coa-head {
    padding: 14px 0 8px;
  }

  .g-coa-row {
    border-top: 1px solid var(--g-rule-soft);
    padding: 11px 0;
    font-family: var(--font-mono);
    font-size: 12px;
  }

  .g-coa-row span:first-child {
    color: var(--g-ink);
  }

  .g-coa-row span:nth-child(2) {
    color: var(--g-mute);
  }

  .g-coa-row strong {
    color: var(--g-sage-deep);
    font-weight: 500;
  }

  .g-coa footer {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    margin-top: 16px;
    border-top: 1px solid var(--g-rule);
    padding-top: 14px;
    font-size: 11px;
    text-transform: none;
  }

  .g-lessons {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .g-card {
