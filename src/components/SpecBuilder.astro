---
import { copy, getLanguage, industries, products, regions } from '../data/site';

const bookingUrl = import.meta.env.PUBLIC_BOOKING_URL || '';
const lang = getLanguage(Astro.params.lang);
const c = copy[lang];
---
<form
  name="spec-builder"
  method="POST"
  data-netlify="true"
  netlify-honeypot="bot-field"
  action="/thank-you?intent=spec"
  class="spec-form"
  data-booking-url={bookingUrl}
>
  <input type="hidden" name="form-name" value="spec-builder" />
  <p hidden><label>Bot: <input name="bot-field" /></label></p>

  <div class="form-head">
    <span class="kicker">{c.specTitle}</span>
    <strong>Tell us what you need. We will reply with specs, documents, and shipment options.</strong>
  </div>

  <label>
    <span>Product</span>
    <select class="field-control" name="product" required>
      {products.map((product) => <option value={product.slug}>{product.name}</option>)}
    </select>
  </label>

  <div class="two">
    <label>
      <span>Grade</span>
      <select class="field-control" name="grade" required>
        <optgroup label="Husk / Powder">
          <option value="99-200m">99% / 200 mesh</option>
          <option value="98-100m">98% / 100 mesh</option>
          <option value="95-80m">95% / 80 mesh</option>
          <option value="85-40m">85% / 40–60 mesh</option>
        </optgroup>
        <optgroup label="Khakha / Feed">
          <option value="feed-grade-a">Feed Grade A (30–40% fibre)</option>
          <option value="feed-grade-b">Feed Grade B (25–30% fibre)</option>
        </optgroup>
        <optgroup label="Industrial">
          <option value="standard-industrial">Standard Industrial</option>
          <option value="premium-industrial">Premium Industrial</option>
          <option value="pet-food-grade">Pet Food Grade</option>
        </optgroup>
        <optgroup label="Cattle Feed">
          <option value="sagar-gola">Sagar Gola (block)</option>
          <option value="sagar-lali">Sagar Lali (loose)</option>
        </optgroup>
        <optgroup label="Seeds">
          <option value="sortex">Sortex (99%)</option>
          <option value="standard-seed">Standard (98%)</option>
        </optgroup>
      </select>
    </label>

    <label>
      <span>Region</span>
      <select class="field-control" name="region" required>
        {regions.map((region) => <option value={region.slug}>{region.name}</option>)}
      </select>
    </label>
  </div>

  <label>
    <span>Application</span>
    <select class="field-control" name="industry" required>
      {industries.map((industry) => <option value={industry.slug}>{industry.name}</option>)}
    </select>
  </label>

  <label>
    <span>Mesh Size <strong id="mesh-display">80 mesh</strong></span>
    <input class="range" type="range" name="mesh" min="20" max="100" step="20" value="80" />
  </label>

  <label>
    <span>Packaging</span>
    <select class="field-control" name="packaging">
      <option value="10kg">10kg Bags</option>
      <option value="15kg">15kg Bags</option>
      <option value="25kg">25kg Bags</option>
      <option value="50kg">50kg Bags</option>
      <option value="1000kg">1000kg Jumbo</option>
    </select>
  </label>

  <input type="hidden" name="language" value={lang} />
  <button type="submit" class="btn btn-primary">Request Quote & Sample Options</button>
</form>
<script src="/scripts/spec-builder.js" defer></script>

<style>
  .spec-form {
    display: grid;
    gap: 1rem;
  }

  .form-head {
    display: grid;
    gap: 0.45rem;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 1.1rem;
  }

  .form-head strong {
    color: var(--ink);
    font-family: var(--font-display);
    font-size: 1.55rem;
    font-weight: 300;
    line-height: 1.12;
  }

  .two {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.8rem;
  }

  label {
    display: grid;
    gap: 0.45rem;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  label span {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  label strong {
    color: var(--accent);
    font-size: 0.62rem;
    font-weight: 400;
  }

  .range {
    width: 100%;
    accent-color: var(--accent);
  }

  button {
    width: 100%;
    border: 0;
    cursor: pointer;
  }

  @media (max-width: 560px) {
    .two {
      grid-template-columns: 1fr;
    }
  }
</style>
