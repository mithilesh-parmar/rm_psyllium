---
---
<section class="hero">
  <div class="hero-media" aria-hidden="true">
    <img src="/assets/hero-processing.svg" width="1600" height="900" alt="" loading="eager" decoding="async" />
  </div>
  <div class="container hero-grid">
    <div class="hero-copy">
      <h1>Bulk Psyllium Husk Supply from Gujarat, India</h1>
      <p>Request husk, powder, seed, and feed options with grade, mesh, packing, COA, and export documents matched to your buying requirement.</p>
      <div class="hero-actions" aria-label="Primary actions">
        <a class="btn btn-primary" href="#talk" data-track="hero_book_click">Request Bulk Quote</a>
        <a class="btn btn-secondary" href="/resources/playbook/" data-track="hero_playbook_click">Download Import Checklist</a>
      </div>
      <div class="trust-row" aria-label="Buyer document support">
        <span>COA</span>
        <span>Origin Certificate</span>
        <span>Phyto Support</span>
        <span>FSSAI</span>
        <span>HALAL Available</span>
        <span>KOSHER Available</span>
      </div>
    </div>
    <div class="hero-card panel" aria-label="Procurement summary">
      <img src="/assets/product-bag.svg" width="900" height="900" alt="RM Psyllium psyllium export packaging" />
      <div>
      <strong>Export lots by buyer requirement</strong>
      <span>Purity, mesh, packaging, and documents aligned before quote.</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    min-height: calc(100vh - 72px);
    overflow: clip;
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.96) 0%, rgba(255, 255, 255, 0.86) 52%, rgba(246, 248, 244, 0.68) 100%);
  }

  .hero-media {
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0.22;
  }

  .hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-grid {
    display: grid;
    min-height: calc(100vh - 72px);
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.68fr);
    align-items: center;
    gap: 4rem;
    padding: 5.5rem 0 4rem;
  }

  .hero-copy h1 {
    max-width: 760px;
    margin: 0;
    font-size: clamp(3rem, 8vw, 5.8rem);
    font-weight: 850;
    letter-spacing: 0;
    line-height: 0.96;
  }

  .hero-copy p {
    max-width: 640px;
    margin: 1.5rem 0 0;
    color: #405b68;
    font-size: clamp(1.08rem, 2vw, 1.35rem);
    line-height: 1.55;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .trust-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 2rem;
  }

  .trust-row span {
    border: 1px solid rgba(47, 111, 78, 0.22);
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.82);
    padding: 0.45rem 0.62rem;
    color: #2f6f4e;
    font-size: 0.78rem;
    font-weight: 800;
  }

  .hero-card {
    overflow: clip;
  }

  .hero-card img {
    display: block;
    aspect-ratio: 1;
    width: 100%;
    object-fit: cover;
    background: #f6f8f4;
  }

  .hero-card div {
    padding: 1.25rem;
  }

  .hero-card strong,
  .hero-card span {
    display: block;
  }

  .hero-card span {
    margin-top: 0.35rem;
    color: #54707e;
    line-height: 1.45;
  }

  @media (max-width: 920px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding-top: 4rem;
    }

    .hero-card {
      max-width: 420px;
    }
  }

  @media (max-width: 560px) {
    .hero-copy h1 {
      font-size: 2.65rem;
    }

    .hero-actions .btn {
      width: 100%;
    }
  }
</style>
