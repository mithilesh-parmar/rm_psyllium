---
const bookingUrl = import.meta.env.PUBLIC_BOOKING_URL || '';
---
<section id="book" class="booking panel">
  <div>
    <p class="eyebrow">Sourcing Call</p>
    <h2>{bookingUrl ? 'Book a 15-minute sourcing call' : 'Booking link coming soon'}</h2>
    <p>
      {bookingUrl
        ? 'Choose a time and bring your target grade, mesh, packaging, monthly volume, and destination market.'
        : 'Calendly is intentionally parked until the final booking URL is available. Spec form submissions still capture buyer intent and route to the thank-you page.'}
    </p>
  </div>
  {bookingUrl ? (
    <iframe
      title="Book a sourcing call"
      src={bookingUrl}
      loading="lazy"
      width="100%"
      height="630"
    ></iframe>
  ) : (
    <div class="booking-placeholder" aria-label="Booking placeholder">
      <strong>Placeholder schedule</strong>
      <span>15 min procurement fit call</span>
      <span>Spec alignment and export readiness</span>
      <a class="btn btn-primary" href="mailto:sourcing@rmpsyllium.com?subject=RM%20Psyllium%20Sourcing%20Call" data-track="email_booking_click">Email Sourcing Team</a>
    </div>
  )}
</section>

<style>
  .booking {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 2rem;
    padding: 2rem;
  }

  h2 {
    margin: 0.4rem 0 0.8rem;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.05;
  }

  p:not(.eyebrow) {
    color: #54707e;
    line-height: 1.6;
  }

  iframe {
    min-height: 630px;
    border: 1px solid #dfe6dc;
    border-radius: 8px;
    background: #f6f8f4;
  }

  .booking-placeholder {
    display: grid;
    min-height: 380px;
    align-content: center;
    gap: 0.8rem;
    border: 1px dashed #b5c4bc;
    border-radius: 8px;
    background: #f6f8f4;
    padding: 2rem;
  }

  .booking-placeholder strong {
    font-size: 1.35rem;
  }

  .booking-placeholder span {
    color: #54707e;
  }

  .booking-placeholder .btn {
    width: fit-content;
    margin-top: 0.8rem;
  }

  @media (max-width: 860px) {
    .booking {
      grid-template-columns: 1fr;
      padding: 1.25rem;
    }
  }
</style>
