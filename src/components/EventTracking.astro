---
const gaId = import.meta.env.PUBLIC_GA4_ID || '';
const clarityId = import.meta.env.PUBLIC_CLARITY_ID || '';
---
{gaId && <script is:inline src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`} defer></script>}
{(gaId || clarityId) && (
  <script
    is:inline
    src="/scripts/analytics.js"
    data-ga-id={gaId}
    data-clarity-id={clarityId}
    defer
  ></script>
)}
