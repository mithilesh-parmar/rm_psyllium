---
const items = [
  ['COA Review', 'Purity, mesh, moisture, ash, swelling volume, microbiology, and heavy-metal parameters shared for buyer review.'],
  ['Food Safety', 'Facility, allergen, microbiology, and handling documents available for food, supplement, and pharma buyers.'],
  ['Halal & Kosher', 'Halal and Kosher documents can be shared where the current lot and buyer market require them.'],
  ['Traceability', 'Lot-level origin, processing, packing, and shipment records aligned to export review.'],
  ['Specification Control', 'Grade, mesh, moisture, swell volume, and packing requirements confirmed before quote.'],
  ['Export Documents', 'Commercial invoice, packing list, COA, origin certificate, phyto, and fumigation support for export orders.']
];
---
<div class="compliance-grid">
  {items.map(([title, text]) => (
    <article>
      <span aria-hidden="true"></span>
      <h3>{title}</h3>
      <p>{text}</p>
    </article>
  ))}
</div>

<style>
  .compliance-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  article {
    border: 1px solid var(--rule, rgba(26,28,24,0.1));
    border-radius: 8px;
    background: #ffffff;
    padding: 24px;
    transition: box-shadow 0.2s;
  }

  article:hover {
    box-shadow: 0 8px 24px -12px rgba(26,28,24,0.15);
  }

  span {
    display: block;
    width: 28px;
    height: 4px;
    border-radius: 99px;
    background: var(--accent, #4a6630);
  }

  h3 {
    margin: 14px 0 8px;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--ink, #1a1c18);
  }

  p {
    margin: 0;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: var(--body-muted, #4a4f44);
    line-height: 1.65;
  }

  @media (max-width: 860px) {
    .compliance-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .compliance-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
