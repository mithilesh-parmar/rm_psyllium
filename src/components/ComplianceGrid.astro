---
import { copy, getLanguage } from '../data/site';
const lang = getLanguage(Astro.params.lang);
const t = copy[lang];
const items: [string, string][] = [
  [t.cgItem1Title, t.cgItem1Desc],
  [t.cgItem2Title, t.cgItem2Desc],
  [t.cgItem3Title, t.cgItem3Desc],
  [t.cgItem4Title, t.cgItem4Desc],
  [t.cgItem5Title, t.cgItem5Desc],
  [t.cgItem6Title, t.cgItem6Desc],
];
---
<div class="compliance-grid">
  {items.map(([title, text]) => (
    <article>
      <span aria-hidden="true"></span>
      <h3>{title}</h3>
      <p>{text}</p>
    </article>
  ))}
</div>

<style>
  .compliance-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  article {
    border: 1px solid var(--rule, rgba(26,28,24,0.1));
    border-radius: 8px;
    background: #ffffff;
    padding: 24px;
    transition: box-shadow 0.2s;
  }

  article:hover {
    box-shadow: 0 8px 24px -12px rgba(26,28,24,0.15);
  }

  span {
    display: block;
    width: 28px;
    height: 4px;
    border-radius: 99px;
    background: var(--accent, #4a6630);
  }

  h3 {
    margin: 14px 0 8px;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--ink, #1a1c18);
  }

  p {
    margin: 0;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: var(--body-muted, #4a4f44);
    line-height: 1.65;
  }

  @media (max-width: 860px) {
    .compliance-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .compliance-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
