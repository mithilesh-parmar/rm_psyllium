---
export interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  noindex?: boolean;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  canonical,
  image = '/assets/generated/facility-bags-gujarat.webp',
  noindex = false,
  structuredData
} = Astro.props;

const origin = Astro.site ? Astro.site.origin : Astro.url.origin;
const pathname = Astro.url.pathname;
const absoluteImage = new URL(image, origin).href;

// Supported languages in rmpsyllium.com
const langCodes = ['en', 'ar', 'zh', 'nl', 'fr', 'de', 'it', 'pt', 'ru', 'es'];

// Helper to determine if a page has multilingual equivalents
const isTranslatedPath = (path: string) => {
  if (path === '/' || path === '') return true;
  const parts = path.split('/').filter(Boolean);
  if (parts.length > 0 && langCodes.includes(parts[0])) {
    return true;
  }
  // Special case: /about is translated (will render English version of /en/about/)
  if (parts.length === 1 && parts[0] === 'about') {
    return true;
  }
  return false;
};

// Generate clean canonical and alternate hreflang tags
const cleanCanonical = canonical || new URL(pathname, origin).href;

let hreflangs: { code: string; href: string }[] = [];
let xDefault: string | null = null;

if (isTranslatedPath(pathname)) {
  const parts = pathname.split('/').filter(Boolean);
  let subPath = '';
  
  if (parts.length > 0) {
    if (langCodes.includes(parts[0])) {
      subPath = parts.slice(1).join('/');
    } else {
      subPath = parts.join('/');
    }
  }
  
  const cleanSubPath = subPath ? `${subPath}/` : '';
  
  hreflangs = langCodes.map((code) => ({
    code,
    href: `${origin}/${code}/${cleanSubPath}`
  }));
  
  xDefault = `${origin}/en/${cleanSubPath}`;
}
---
<title>{title}</title>
<meta name="description" content={description} />
<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
<link rel="canonical" href={cleanCanonical} />
{hreflangs.map((hl) => (
  <link rel="alternate" hreflang={hl.code} href={hl.href} />
))}
{xDefault && (
  <link rel="alternate" hreflang="x-default" href={xDefault} />
)}
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={absoluteImage} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={absoluteImage} />
{structuredData && (
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
)}
