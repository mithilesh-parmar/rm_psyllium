---
import { insights } from '../data/site';

const lang = Astro.params.lang || 'en';
---
<div class="insight-grid">
  {insights.map((post, index) => (
    <a class:list={['insight-card', { lead: index === 0 }]} href={`/${lang}/insights/${post.slug}/`}>
      <span>{post.audience}</span>
      <h3>{post.title}</h3>
      <p>{post.summary}</p>
      <time datetime={post.date}>{post.date}</time>
    </a>
  ))}
</div>

<style>
  .insight-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 1rem;
  }

  .insight-card {
    display: grid;
    min-height: 220px;
    align-content: start;
    gap: 0.9rem;
    border: 1px solid rgba(16, 35, 63, 0.1);
    border-radius: 28px;
    background: #fffdf7;
    padding: 1.35rem;
  }

  .insight-card.lead {
    grid-row: span 2;
    min-height: 460px;
    align-content: end;
    background:
      radial-gradient(circle at 80% 15%, rgba(201, 138, 46, 0.24), transparent 16rem),
      linear-gradient(135deg, #dff1e6, #fffdf7);
  }

  .insight-card span {
    color: #2d6a4f;
    font-size: 0.76rem;
    font-weight: 840;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h3 {
    margin: 0;
    font-size: clamp(1.28rem, 2.5vw, 2.15rem);
    line-height: 1.08;
  }

  p {
    margin: 0;
    color: #64748b;
    line-height: 1.55;
  }

  time {
    margin-top: auto;
    color: #8f4f32;
    font-size: 0.84rem;
    font-weight: 760;
  }

  @media (max-width: 860px) {
    .insight-grid {
      grid-template-columns: 1fr;
    }

    .insight-card.lead {
      min-height: 300px;
    }
  }
</style>
