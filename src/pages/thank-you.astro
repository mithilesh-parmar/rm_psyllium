---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Thank You | RM Psyllium"
  description="Thank you for contacting RM Psyllium."
  noindex={true}
>
  <section class="section thanks">
    <div class="container thanks-panel panel">
      <p class="eyebrow">Received</p>
      <h1>Got it. The export desk will review your request.</h1>
      <p>
        We'll review your requirement and come back with grade availability, pricing, document needs, lead time, and sample options.
      </p>
      <div class="actions">
        <a class="btn btn-primary" href="/">Back to Homepage</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .thanks {
    min-height: 62vh;
    background: #f6f8f4;
  }

  .thanks-panel {
    max-width: 760px;
    padding: 2rem;
  }

  h1 {
    margin: 0.45rem 0 1rem;
    font-size: clamp(2.4rem, 6vw, 4.4rem);
    line-height: 1.04;
  }

  p:not(.eyebrow) {
    color: #54707e;
    line-height: 1.62;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }
</style>
