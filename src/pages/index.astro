---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomePage from '../components/HomePage.astro';
import { products } from '../data/site';

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'RM Psyllium',
    url: 'https://rmpsyllium.com',
    email: 'export@rmpsyllium.com',
    telephone: '+918949817791',
    foundingDate: '2024',
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Patan Road, Khali, Char Rasta, Nedra',
      addressLocality: 'Siddhpur',
      addressRegion: 'Gujarat',
      postalCode: '384151',
      addressCountry: 'IN'
    },
    geo: {
      '@type': 'GeoCoordinates',
      latitude: 23.8076,
      longitude: 72.3936
    },
    numberOfEmployees: { '@type': 'QuantitativeValue', value: 50 },
    areaServed: 'International',
    sameAs: [
      'https://www.linkedin.com/company/rm-psyllium/',
      'https://www.instagram.com/rm_psyllium/',
      'https://x.com/rm_psyllium'
    ]
  },
  {
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    name: 'RM Psyllium',
    description: 'Psyllium husk manufacturer and exporter from Gujarat, India. Supplying pharma, supplement, and food manufacturers. Grade delivered, COA before dispatch.',
    url: 'https://rmpsyllium.com',
    telephone: '+918949817791',
    email: 'export@rmpsyllium.com',
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Patan Road, Khali, Char Rasta, Nedra',
      addressLocality: 'Siddhpur',
      addressRegion: 'Gujarat',
      postalCode: '384151',
      addressCountry: 'IN'
    },
    geo: {
      '@type': 'GeoCoordinates',
      latitude: 23.8076,
      longitude: 72.3936
    },
    openingHoursSpecification: {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'],
      opens: '09:00',
      closes: '18:00'
    }
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: 'What is the minimum order quantity for psyllium husk?', acceptedAnswer: { '@type': 'Answer', text: '1 kg sample packs are available for all listed grades. Commercial lot size is reviewed after grade, mesh, packing, testing, document, and destination requirements are clear.' } },
      { '@type': 'Question', name: 'What purity grades do you offer for psyllium husk?', acceptedAnswer: { '@type': 'Answer', text: 'We offer 85%, 95%, 98%, and 99% purity grades for psyllium husk. COA wording should reference buyer-specified standards only where tested lot results support them.' } },
      { '@type': 'Question', name: 'What mesh sizes are available?', acceptedAnswer: { '@type': 'Answer', text: 'We offer 30, 40, 60, 80, 100, and 200 mesh options.' } },
      { '@type': 'Question', name: 'Do you provide COA and export documentation?', acceptedAnswer: { '@type': 'Answer', text: 'Buyers can review a sample COA, product specification, origin details, packing options, and destination document checklist before purchase order. Lot-specific testing can be arranged where required by the buyer specification.' } },
      { '@type': 'Question', name: 'What is the lead time from order to shipment?', acceptedAnswer: { '@type': 'Answer', text: 'Lead time is planned after product availability, packing, lab testing, document requirements, and destination are reviewed.' } },
      { '@type': 'Question', name: 'Can I get a sample before placing a bulk order?', acceptedAnswer: { '@type': 'Answer', text: 'Yes. 1 kg sample packs are available for all listed grades. Share your target grade, mesh, destination, and required documents so we can confirm sample availability and COA review options before dispatch.' } },
      { '@type': 'Question', name: 'What ports do you ship from?', acceptedAnswer: { '@type': 'Answer', text: 'We ship primarily from Mundra port (Gujarat), 120km from our facility. Kandla and Nhava Sheva (Mumbai) are also available.' } }
    ]
  },
  {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'How to source psyllium husk from India',
    description: 'Step-by-step process for importing bulk psyllium husk from an Indian manufacturer.',
    step: [
      { '@type': 'HowToStep', name: 'Source', text: 'Seed sourced from contracted growers across Banaskantha, Patan, and Mehsana with origin records per lot.' },
      { '@type': 'HowToStep', name: 'Clean', text: 'Magnetic separation, de-stoner, and sieve cleaning reduce foreign matter before milling.' },
      { '@type': 'HowToStep', name: 'Mill', text: 'Roller mills separate husk without chemical bleaching or acid treatment. PLC-controlled gap for mesh consistency.' },
      { '@type': 'HowToStep', name: 'Test', text: 'NIR scan + HPLC lab review. Purity, swelling volume, moisture, ash, microbiology, and heavy metals documented.' },
      { '@type': 'HowToStep', name: 'Ship', text: 'Food-grade packing, export documents, and FOB Mundra or CIF to your port. Documents shared before dispatch.' }
    ]
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    itemListElement: products.map((product, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: product.name,
      url: `https://rmpsyllium.com/en/products/${product.slug}/`
    }))
  }
];
---

<BaseLayout
  title="Psyllium Husk Manufacturer India | Bulk Export · RM Psyllium"
  description="Bulk psyllium husk, powder, and seeds from Siddhpur, Gujarat. Custom grade, mesh, packing, sample review, and buyer documentation for pharma, food, feed, and industrial buyers. FOB Mundra or CIF reviewed by destination."
  structuredData={structuredData}
>
  <HomePage lang="en" />
</BaseLayout>
