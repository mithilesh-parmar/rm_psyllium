---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomePage from '../components/HomePage.astro';
import { products } from '../data/site';

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'RM Psyllium',
    url: 'https://rmpsyllium.com',
    email: 'export@rmpsyllium.com',
    telephone: '+918949817791',
    foundingDate: '2024',
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Patan Road, Khali, Char Rasta, Nedra',
      addressLocality: 'Siddhpur',
      addressRegion: 'Gujarat',
      postalCode: '384151',
      addressCountry: 'IN'
    },
    geo: {
      '@type': 'GeoCoordinates',
      latitude: 23.8076,
      longitude: 72.3936
    },
    numberOfEmployees: { '@type': 'QuantitativeValue', value: 50 },
    areaServed: 'International',
    sameAs: []
  },
  {
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    name: 'RM Psyllium',
    description: 'Psyllium husk manufacturer and exporter from Gujarat, India. Supplying pharma, supplement, and food manufacturers. Grade delivered, COA before dispatch.',
    url: 'https://rmpsyllium.com',
    telephone: '+918949817791',
    email: 'export@rmpsyllium.com',
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Patan Road, Khali, Char Rasta, Nedra',
      addressLocality: 'Siddhpur',
      addressRegion: 'Gujarat',
      postalCode: '384151',
      addressCountry: 'IN'
    },
    geo: {
      '@type': 'GeoCoordinates',
      latitude: 23.8076,
      longitude: 72.3936
    },
    openingHoursSpecification: {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'],
      opens: '09:00',
      closes: '18:00'
    }
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: 'What is the minimum order quantity for psyllium husk?', acceptedAnswer: { '@type': 'Answer', text: 'No minimum order. We supply from 1 KG samples for lab testing, 5 KG trial batches, up to full container loads (18–20 MT). Order any quantity.' } },
      { '@type': 'Question', name: 'What purity grades do you offer for psyllium husk?', acceptedAnswer: { '@type': 'Answer', text: 'We offer 85%, 95%, 98%, and 99% purity grades for psyllium husk. 99% is pharmaceutical-grade (USP/EP compliant).' } },
      { '@type': 'Question', name: 'What mesh sizes are available?', acceptedAnswer: { '@type': 'Answer', text: 'We offer 30, 40, 60, 80, 100, and 200 mesh options.' } },
      { '@type': 'Question', name: 'Do you provide COA and export documentation?', acceptedAnswer: { '@type': 'Answer', text: 'Yes. Every shipment includes a Certificate of Analysis (COA) with 47 test parameters, certificate of origin, phytosanitary certificate, fumigation certificate, MSDS, allergen statement, and packing list.' } },
      { '@type': 'Question', name: 'What is the lead time from order to shipment?', acceptedAnswer: { '@type': 'Answer', text: '7 days from order confirmation to shipment. Samples can be dispatched within 5 working days. We ship FOB Mundra port or CIF to your destination port.' } },
      { '@type': 'Question', name: 'Can I get a sample before placing a bulk order?', acceptedAnswer: { '@type': 'Answer', text: 'Yes. We provide 250g samples with a COA for quality evaluation. Samples are dispatched within 5 working days via courier.' } },
      { '@type': 'Question', name: 'What ports do you ship from?', acceptedAnswer: { '@type': 'Answer', text: 'We ship primarily from Mundra port (Gujarat), 120km from our facility. Kandla and Nhava Sheva (Mumbai) are also available.' } },
      { '@type': 'Question', name: 'What certifications does RM Psyllium hold?', acceptedAnswer: { '@type': 'Answer', text: 'Our facility operations, registrations, and international compliance audits are currently in progress. We prioritize transparency and regulatory compliance for all global export markets. Please contact our export desk directly for the latest updates, compliance timelines, and specific audit requirements for your destination country.' } }
    ]
  },
  {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'How to source psyllium husk from India',
    description: 'Step-by-step process for importing bulk psyllium husk from an Indian manufacturer.',
    step: [
      { '@type': 'HowToStep', name: 'Source', text: 'Seed sourced from contracted growers across Banaskantha, Patan, and Mehsana with origin records per lot.' },
      { '@type': 'HowToStep', name: 'Clean', text: 'Magnetic separation, de-stoner, and sieve cleaning reduce foreign matter before milling.' },
      { '@type': 'HowToStep', name: 'Mill', text: 'Roller mills separate husk without chemical bleaching or acid treatment. PLC-controlled gap for mesh consistency.' },
      { '@type': 'HowToStep', name: 'Test', text: 'NIR scan + HPLC lab review. Purity, swelling volume, moisture, ash, microbiology, and heavy metals documented.' },
      { '@type': 'HowToStep', name: 'Ship', text: 'Food-grade packing, export documents, and FOB Mundra or CIF to your port. Documents shared before dispatch.' }
    ]
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    itemListElement: products.map((product, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: product.name,
      url: `https://rmpsyllium.com/en/products/${product.slug}/`
    }))
  }
];
---

<BaseLayout
  title="Psyllium Husk Manufacturer India | Bulk Export · RM Psyllium"
  description="Bulk psyllium husk, powder, and seeds from Siddhpur, Gujarat. 2,000 MT annual capacity. No minimum order — supply from 1 KG samples to full containers. Custom grade, mesh, and packing for pharma, food, feed, and industrial buyers. FOB Mundra or CIF."
  structuredData={structuredData}
>
  <HomePage lang="en" />
</BaseLayout>
