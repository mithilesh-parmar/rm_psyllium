---
import BaseLayout from '../layouts/BaseLayout.astro';
import InsightGrid from '../components/InsightGrid.astro';
import LanguageGateway from '../components/LanguageGateway.astro';
import RouteCards from '../components/RouteCards.astro';
import SpecBuilder from '../components/SpecBuilder.astro';
import { products } from '../data/site';

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'RM Psyllium',
    url: 'https://rmpsyllium.com',
    email: 'sourcing@rmpsyllium.com'
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    itemListElement: products.map((product, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: product.name,
      url: `https://rmpsyllium.com/en/products/${product.slug}/`
    }))
  }
];
---
<BaseLayout
  title="RM Psyllium | Premium Psyllium Ingredients for Global Brands"
  description="Clean, traceable psyllium husk, powder, seeds, organic psyllium, khakha powder, and cattle feed for global buyers."
  structuredData={structuredData}
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="kicker">Export-ready psyllium ingredients</span>
        <h1 class="display">Premium psyllium supply for global brands.</h1>
        <p class="lead">
          Clean, traceable psyllium husk, powder, seed, organic, and feed-grade ingredients
          for buyers who need reliable specs and export documentation.
        </p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="#spec">Request Quote</a>
          <a class="btn btn-secondary" href="/en/products/psyllium-husk-powder/">Explore Products</a>
        </div>
      </div>

      <div class="product-stage" aria-label="RM Psyllium product preview">
        <div class="stage-bg"></div>
        <img src="/assets/product-bag.svg" width="900" height="900" alt="RM Psyllium product packaging placeholder" />
        <div class="floating-note top">
          <strong>99%</strong>
          <span>Purity options</span>
        </div>
        <div class="floating-note bottom">
          <strong>20-100</strong>
          <span>Mesh range</span>
        </div>
      </div>
    </div>
  </section>

  <section class="logo-strip">
    <div class="container strip-inner">
      <span>Organic programs</span>
      <span>Food safety</span>
      <span>Traceable lots</span>
      <span>Halal / Kosher</span>
      <span>COA ready</span>
      <span>Global exports</span>
    </div>
  </section>

  <section class="section intro">
    <div class="container intro-grid">
      <div>
        <span class="kicker">Welcome to RM Psyllium</span>
        <h2 class="title-xl">From seed to shipment, we stay close to one ingredient.</h2>
      </div>
      <p class="lead">
        Psyllium is not a side category for us. It is the work: sourcing, processing,
        grading, documentation, and helping manufacturers choose the format that fits their product.
      </p>
    </div>
  </section>

  <section class="story-section">
    <div class="container story-grid">
      <div class="story-image">
        <img src="/assets/factory-walkthrough.svg" width="1200" height="800" alt="Psyllium processing facility placeholder" loading="lazy" decoding="async" />
      </div>
      <div class="story-copy">
        <span class="kicker">We sow. You formulate.</span>
        <h2>If psyllium is involved, we want to be useful before the first quote.</h2>
        <p>
          Psyllium is a technical ingredient. Mesh, purity, swell volume, microbiology,
          packaging, and regulatory documents all affect whether it works in your product.
          This site is structured to move those questions forward before sampling starts.
        </p>
        <a class="text-link" href="/en/products/psyllium-husk/">Explore psyllium range</a>
      </div>
    </div>
  </section>

  <section class="numbers-section">
    <div class="container number-grid">
      <div>
        <strong>6</strong>
        <span>product families</span>
      </div>
      <div>
        <strong>20-100</strong>
        <span>mesh range</span>
      </div>
      <div>
        <strong>5</strong>
        <span>priority buyer regions</span>
      </div>
      <div>
        <strong>365</strong>
        <span>days focused on psyllium</span>
      </div>
    </div>
  </section>

  <section class="section routes" id="routes">
    <div class="container">
      <RouteCards />
    </div>
  </section>

  <section class="quality-section">
    <div class="container quality-grid">
      <div>
        <span class="kicker">Quality standard</span>
        <h2 class="title-xl">No shortcuts on specs, safety, or traceability.</h2>
      </div>
      <div class="quality-list">
        <article>
          <strong>Micro safety</strong>
          <p>Buyer-ready discussion around salmonella, E. coli, heavy metals, and lot-level COA review.</p>
        </article>
        <article>
          <strong>Process control</strong>
          <p>Purity, mesh, moisture, ash, and swell volume are treated as commercial requirements, not afterthoughts.</p>
        </article>
        <article>
          <strong>Export documentation</strong>
          <p>Organic, halal, kosher, origin, packing, and shipment documents can be aligned around each market.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="standards-section">
    <div class="container standards-grid">
      <article>
        <span>01</span>
        <h3>Ingredient mastery</h3>
        <p>We keep the product story narrow so the specification conversation can go deeper.</p>
      </article>
      <article>
        <span>02</span>
        <h3>Global buyer language</h3>
        <p>Product, region, and application pages help procurement teams land in the right place fast.</p>
      </article>
      <article>
        <span>03</span>
        <h3>Food safety first</h3>
        <p>Every serious conversation starts with microbiology, traceability, packing, and export paperwork.</p>
      </article>
      <article>
        <span>04</span>
        <h3>Process discipline</h3>
        <p>From mesh to swell volume, the details decide whether psyllium performs in the final product.</p>
      </article>
    </div>
  </section>

  <section class="facility-section">
    <div class="container facility-head">
      <span class="kicker">Inside the supply chain</span>
      <h2 class="title-lg">The buyer journey should feel as organized as the factory floor.</h2>
    </div>
    <div class="container facility-grid">
      <figure>
        <img src="/assets/compliance-lab.svg" width="1200" height="760" alt="Quality lab placeholder" loading="lazy" decoding="async" />
        <figcaption>Quality documentation and lab-style review before commercial handoff.</figcaption>
      </figure>
      <figure>
        <img src="/assets/hero-processing.svg" width="1600" height="900" alt="Processing line placeholder" loading="lazy" decoding="async" />
        <figcaption>Processing, grading, and packing paths matched to buyer application.</figcaption>
      </figure>
      <figure>
        <img src="/assets/playbook-preview.svg" width="1200" height="720" alt="Import playbook placeholder" loading="lazy" decoding="async" />
        <figcaption>Import playbooks and product pages support procurement teams before the call.</figcaption>
      </figure>
    </div>
  </section>

  <section class="future-section">
    <div class="container future-grid">
      <div>
        <span class="kicker">Looking ahead</span>
        <h2 class="title-xl">Cleaner supply chains need clearer ingredient partners.</h2>
      </div>
      <div class="future-tabs">
        <article>
          <h3>Evolution</h3>
          <p>More buyer journeys, more regional pages, and more application-specific product guidance.</p>
        </article>
        <article>
          <h3>Mastery</h3>
          <p>Deeper education around psyllium science, processing, mesh behavior, and formulation fit.</p>
        </article>
        <article>
          <h3>Responsibility</h3>
          <p>Verified certificates, traceability, and sustainability content should become first-class pages.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section split-band" id="spec">
    <div class="container split-grid">
      <div>
        <span class="kicker">Fast quote path</span>
        <h2 class="title-xl">A cleaner way to ask for specs.</h2>
        <p class="lead">
          Capture product, region, application, grade, mesh, and pack size without burying buyers in a long form.
        </p>
      </div>
      <div class="panel spec-panel">
        <SpecBuilder />
      </div>
    </div>
  </section>

  <section class="section languages">
    <div class="container section-head">
      <span class="kicker">Localized entry points</span>
      <h2 class="title-lg">Start in the buyer’s language.</h2>
    </div>
    <div class="container">
      <LanguageGateway />
    </div>
  </section>

  <section class="section insights-band">
    <div class="container section-head">
      <span class="kicker">Insights</span>
      <h2 class="title-lg">Useful pages for real buyer questions.</h2>
    </div>
    <div class="container">
      <InsightGrid />
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    min-height: calc(100vh - 76px);
    padding: 5.5rem 0 4rem;
    display: grid;
    align-items: center;
  }

  .hero-grid,
  .intro-grid,
  .split-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(340px, 0.78fr);
    align-items: center;
    gap: 4rem;
  }

  .hero-copy {
    display: grid;
    gap: 1.45rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .product-stage {
    position: relative;
    min-height: 560px;
    display: grid;
    place-items: center;
  }

  .stage-bg {
    position: absolute;
    inset: 8% 4% 2%;
    border-radius: 42px;
    background:
      linear-gradient(135deg, rgba(223, 241, 230, 0.95), rgba(255, 253, 247, 0.72)),
      radial-gradient(circle at 70% 25%, rgba(201, 138, 46, 0.2), transparent 18rem);
    box-shadow: 0 30px 90px rgba(16, 35, 63, 0.13);
  }

  .product-stage img {
    position: relative;
    width: min(82%, 430px);
    border-radius: 28px;
    box-shadow: 0 26px 80px rgba(16, 35, 63, 0.18);
  }

  .floating-note {
    position: absolute;
    display: grid;
    gap: 0.2rem;
    min-width: 150px;
    border: 1px solid rgba(16, 35, 63, 0.1);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.84);
    padding: 1rem;
    box-shadow: 0 18px 45px rgba(16, 35, 63, 0.12);
    backdrop-filter: blur(14px);
  }

  .floating-note.top {
    top: 12%;
    right: 0;
  }

  .floating-note.bottom {
    left: 0;
    bottom: 12%;
  }

  .floating-note strong {
    font-size: 1.6rem;
  }

  .floating-note span {
    color: #64748b;
    font-size: 0.85rem;
  }

  .logo-strip {
    border-block: 1px solid rgba(16, 35, 63, 0.08);
    background: rgba(255, 255, 255, 0.66);
  }

  .strip-inner {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    overflow-x: auto;
    padding: 1rem 0;
    color: #64748b;
    font-size: 0.82rem;
    font-weight: 820;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .intro {
    padding-bottom: 3rem;
  }

  .story-section {
    padding: 2rem 0 6rem;
  }

  .story-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.7fr);
    gap: 3rem;
    align-items: center;
  }

  .story-image {
    overflow: hidden;
    border-radius: 34px;
    box-shadow: 0 30px 90px rgba(16, 35, 63, 0.13);
  }

  .story-image img {
    display: block;
    width: 100%;
    aspect-ratio: 1.35;
    object-fit: cover;
  }

  .story-copy {
    display: grid;
    gap: 1.1rem;
  }

  .story-copy h2 {
    margin: 0;
    font-size: clamp(2rem, 4.2vw, 4rem);
    line-height: 0.98;
  }

  .story-copy p {
    margin: 0;
    color: #64748b;
    line-height: 1.7;
  }

  .text-link {
    width: fit-content;
    color: var(--ink);
    font-weight: 840;
    border-bottom: 2px solid #c98a2e;
    padding-bottom: 0.25rem;
  }

  .numbers-section {
    padding: 0 0 6rem;
  }

  .number-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid rgba(16, 35, 63, 0.1);
    border-bottom: 1px solid rgba(16, 35, 63, 0.1);
  }

  .number-grid div {
    display: grid;
    gap: 0.35rem;
    border-right: 1px solid rgba(16, 35, 63, 0.1);
    padding: 1.6rem;
  }

  .number-grid div:last-child {
    border-right: 0;
  }

  .number-grid strong {
    font-size: clamp(2.3rem, 5vw, 4.4rem);
    line-height: 0.9;
  }

  .number-grid span {
    color: #64748b;
    font-size: 0.85rem;
    font-weight: 820;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .routes {
    padding-top: 2rem;
  }

  .quality-section {
    background: var(--dark);
    color: #ffffff;
    padding: 7rem 0;
  }

  .quality-grid {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 4rem;
    align-items: start;
  }

  .quality-list {
    display: grid;
    gap: 1rem;
  }

  .quality-list article {
    display: grid;
    gap: 0.45rem;
    border-top: 1px solid rgba(255, 255, 255, 0.18);
    padding-top: 1.2rem;
  }

  .quality-list strong {
    font-size: clamp(1.3rem, 2.4vw, 2rem);
  }

  .quality-list p {
    margin: 0;
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.65;
  }

  .standards-section {
    padding: 6rem 0;
    background: #f3f6ef;
  }

  .standards-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .standards-grid article {
    display: grid;
    min-height: 320px;
    align-content: space-between;
    border-radius: 30px;
    background: #fffdf7;
    padding: 1.35rem;
    box-shadow: 0 16px 50px rgba(16, 35, 63, 0.06);
  }

  .standards-grid span {
    color: #c98a2e;
    font-weight: 860;
  }

  .standards-grid h3 {
    margin: 4rem 0 0.75rem;
    font-size: clamp(1.35rem, 2.5vw, 2.1rem);
    line-height: 1.05;
  }

  .standards-grid p {
    margin: 0;
    color: #64748b;
    line-height: 1.55;
  }

  .facility-section {
    background: #fffdf7;
    padding: 6rem 0;
  }

  .facility-head {
    max-width: 820px;
    margin-bottom: 2rem;
  }

  .facility-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr 0.9fr;
    gap: 1rem;
  }

  .facility-grid figure {
    margin: 0;
    overflow: hidden;
    border-radius: 28px;
    background: #ffffff;
    box-shadow: 0 18px 55px rgba(16, 35, 63, 0.09);
  }

  .facility-grid img {
    display: block;
    width: 100%;
    aspect-ratio: 1.12;
    object-fit: cover;
  }

  .facility-grid figcaption {
    padding: 1rem;
    color: #253b55;
    font-weight: 760;
    line-height: 1.45;
  }

  .future-section {
    padding: 7rem 0;
    background: var(--dark);
    color: #ffffff;
  }

  .future-grid {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 4rem;
  }

  .future-tabs {
    display: grid;
    gap: 1rem;
  }

  .future-tabs article {
    border-top: 1px solid rgba(255, 255, 255, 0.18);
    padding-top: 1.15rem;
  }

  .future-tabs h3 {
    margin: 0 0 0.55rem;
    font-size: clamp(1.35rem, 2.5vw, 2.2rem);
  }

  .future-tabs p {
    margin: 0;
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.65;
  }

  .split-band {
    background: var(--dark);
    color: #ffffff;
  }

  .split-band .lead {
    color: rgba(255, 255, 255, 0.72);
  }

  .spec-panel {
    padding: 1.25rem;
    color: var(--ink);
  }

  .languages {
    background: #fffdf7;
  }

  .section-head {
    max-width: 760px;
    margin-bottom: 2rem;
  }

  .insights-band {
    background: #f3f6ef;
  }

  @media (max-width: 940px) {
    .hero-grid,
    .intro-grid,
    .split-grid,
    .story-grid,
    .quality-grid,
    .facility-grid,
    .future-grid,
    .standards-grid,
    .number-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .number-grid div {
      border-right: 0;
      border-bottom: 1px solid rgba(16, 35, 63, 0.1);
    }

    .product-stage {
      min-height: 460px;
    }
  }

  @media (max-width: 560px) {
    .hero {
      padding-top: 4rem;
    }

    .product-stage {
      min-height: 380px;
    }

    .floating-note {
      min-width: 126px;
    }
  }
</style>
