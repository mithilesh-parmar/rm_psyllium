---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Bulk Psyllium Import Checklist | RM Psyllium"
  description="Download a buyer checklist for bulk psyllium husk and powder imports, including specs, COA, documents, packing, and shipment questions."
>
  <section class="section playbook-hero">
    <div class="container playbook-grid">
      <div>
        <p class="eyebrow">Import Playbook</p>
        <h1>Check specs, documents, and packing before you request pricing.</h1>
        <p>
          Use this buyer checklist to prepare grade, mesh, COA, compliance, packing, destination port, and shipment questions for bulk psyllium imports.
        </p>
      </div>
      <img src="/assets/playbook-preview.svg" width="1200" height="720" alt="Bulk psyllium import checklist preview" loading="eager" decoding="async" />
    </div>
  </section>

  <section class="section">
    <div class="container form-grid">
      <div>
        <h2>Download the checklist</h2>
        <p>Share your details and receive the import checklist for procurement review.</p>
      </div>
      <form
        name="playbook-download"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        action="/thank-you?guide=playbook"
        class="panel gated-form"
      >
        <input type="hidden" name="form-name" value="playbook-download" />
        <p hidden><label>Bot: <input name="bot-field" /></label></p>
        <label>Name <input class="field-control" name="name" autocomplete="name" required /></label>
        <label>Company <input class="field-control" name="company" autocomplete="organization" required /></label>
        <label>Email <input class="field-control" type="email" name="email" autocomplete="email" required /></label>
        <label>Country <input class="field-control" name="country" autocomplete="country-name" required /></label>
        <label>
          Application
          <select class="field-control" name="application" required>
            <option value="">Select one</option>
            <option>Food formulation</option>
            <option>Nutraceutical</option>
            <option>Pharmaceutical excipient</option>
            <option>Distribution</option>
            <option>Other</option>
          </select>
        </label>
        <button class="btn btn-primary" type="submit">Download Import Playbook</button>
      </form>
    </div>
  </section>
  <script src="/scripts/playbook-form.js" defer></script>
</BaseLayout>

<style>
  h1,
  h2 {
    margin: 0.45rem 0 1rem;
    line-height: 1.05;
  }

  h1 {
    font-size: clamp(2.7rem, 7vw, 5rem);
  }

  h2 {
    font-size: clamp(2rem, 4vw, 3rem);
  }

  p {
    color: #54707e;
    line-height: 1.62;
  }

  .playbook-hero {
    background: #f6f8f4;
  }

  .playbook-grid,
  .form-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    align-items: center;
    gap: 3rem;
  }

  .playbook-grid img {
    border: 1px solid #dfe6dc;
    border-radius: 8px;
    background: #ffffff;
    box-shadow: 0 18px 50px rgba(20, 33, 61, 0.08);
  }

  .gated-form {
    display: grid;
    gap: 1rem;
    padding: 1.5rem;
  }

  label {
    display: grid;
    gap: 0.45rem;
    color: #31475a;
    font-size: 0.88rem;
    font-weight: 800;
  }

  button {
    border: 0;
    cursor: pointer;
  }

  @media (max-width: 860px) {
    .playbook-grid,
    .form-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
