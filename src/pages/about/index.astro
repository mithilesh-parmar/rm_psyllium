---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="About RM Psyllium"
  description="RM Psyllium supplies bulk psyllium husk, powder, seeds, khakha powder, and cattle feed from Gujarat, India for export buyers."
>
  <section class="section about-hero">
    <div class="container about-grid">
      <div>
        <p class="eyebrow">About</p>
        <h1>Bulk psyllium supply from Unjha, Gujarat.</h1>
        <p>
          RM Psyllium helps buyers qualify product fit quickly with grade, mesh, packing, COA, traceability, and export document review.
        </p>
      </div>
      <img src="/assets/factory-walkthrough.svg" width="1200" height="800" alt="RM Psyllium export facility walkthrough" loading="eager" decoding="async" />
    </div>
  </section>

  <section class="section">
    <div class="container values">
      <article>
        <h2>Traceable</h2>
        <p>Lot-level origin, processing, packing, and shipment records available for buyer review.</p>
      </article>
      <article>
        <h2>Spec-led</h2>
        <p>Grade, mesh, packaging, volume, and destination requirements captured before quote.</p>
      </article>
      <article>
        <h2>Export-ready</h2>
        <p>COA, packing list, origin, phyto, fumigation, and shipment paperwork discussed before order.</p>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  h1,
  h2 {
    margin: 0.45rem 0 1rem;
    line-height: 1.05;
  }

  h1 {
    font-size: clamp(2.7rem, 7vw, 5rem);
  }

  h2 {
    font-size: 1.35rem;
  }

  p {
    color: #54707e;
    line-height: 1.62;
  }

  .about-hero {
    background: #f6f8f4;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    align-items: center;
    gap: 3rem;
  }

  .about-grid img {
    border: 1px solid #dfe6dc;
    border-radius: 8px;
    background: #ffffff;
  }

  .values {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .values article {
    border: 1px solid #dfe6dc;
    border-radius: 8px;
    background: #ffffff;
    padding: 1.4rem;
  }

  @media (max-width: 860px) {
    .about-grid,
    .values {
      grid-template-columns: 1fr;
    }
  }
</style>
