---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Product Page Design Variants | RM Psyllium"
  description="Four distinct product detail page variants for Psyllium Husk. Compare design approaches."
  noindex={true}
>

<div class="dv">

  <section class="dv-hero">
    <div class="dv-c">
      <p class="dv-eyebrow">Design Exploration · Psyllium Husk Product Page</p>
      <h1>4 design variants.<br /><em>Pick the best.</em></h1>
      <p class="dv-hero-sub">Each variant uses the same product data — 4 grades (85%–99%), suitability matrix, spec table, application notes — presented through a completely different information architecture. Review each and decide which approach to build into the main product page.</p>
    </div>
  </section>

  <section class="dv-grid-section">
    <div class="dv-c">
      <div class="dv-variants">

        <!-- VARIANT A -->
        <a href="/design-variants/variant-a" class="dv-card">
          <div class="dv-card-preview dv-preview-a">
            <!-- Hero mockup -->
            <div class="dv-mock-hero">
              <div class="dv-mock-text">
                <div class="dv-mock-h"></div>
                <div class="dv-mock-line dv-mock-line--short"></div>
              </div>
              <div class="dv-mock-tiers">
                <div class="dv-mock-tier dv-mt--food">85%</div>
                <div class="dv-mock-tier dv-mt--nf">95%</div>
                <div class="dv-mock-tier dv-mt--usp">98%</div>
                <div class="dv-mock-tier dv-mt--ip">99%</div>
              </div>
            </div>
            <!-- Matrix mockup -->
            <div class="dv-mock-matrix">
              <div class="dv-mock-matrix-inner">
                <div class="dv-mock-cell dv-mc--no"></div>
                <div class="dv-mock-cell dv-mc--cond"></div>
                <div class="dv-mock-cell dv-mc--yes"></div>
                <div class="dv-mock-cell dv-mc--yes"></div>
                <div class="dv-mock-cell dv-mc--cond"></div>
                <div class="dv-mock-cell dv-mc--yes"></div>
                <div class="dv-mock-cell dv-mc--yes"></div>
                <div class="dv-mock-cell dv-mc--yes"></div>
                <div class="dv-mock-cell dv-mc--yes"></div>
                <div class="dv-mock-cell dv-mc--yes"></div>
                <div class="dv-mock-cell dv-mc--cond"></div>
                <div class="dv-mock-cell dv-mc--none"></div>
              </div>
            </div>
            <!-- Bar rows mockup -->
            <div class="dv-mock-bars">
              <div class="dv-mock-bar-row"><div class="dv-mock-bar dv-mbar--food" style="width:60%"></div></div>
              <div class="dv-mock-bar-row"><div class="dv-mock-bar dv-mbar--nf" style="width:80%"></div></div>
              <div class="dv-mock-bar-row"><div class="dv-mock-bar dv-mbar--usp" style="width:90%"></div></div>
              <div class="dv-mock-bar-row"><div class="dv-mock-bar dv-mbar--ip" style="width:100%"></div></div>
            </div>
          </div>
          <div class="dv-card-body">
            <div class="dv-card-label">Variant A</div>
            <h2 class="dv-card-title">The Scanner</h2>
            <p class="dv-card-tagline">Zero-reading required. Everything scannable in 10 seconds.</p>
            <ul class="dv-card-features">
              <li>Pharmacopoeia tier cards in the hero</li>
              <li>Full suitability matrix with colored cells</li>
              <li>Spec table with inline CSS bar charts</li>
              <li>2×2 grade card grid</li>
            </ul>
            <span class="dv-card-cta">View Variant A →</span>
          </div>
        </a>

        <!-- VARIANT B -->
        <a href="/design-variants/variant-b" class="dv-card">
          <div class="dv-card-preview dv-preview-b">
            <div class="dv-mock-explorer">
              <div class="dv-mock-sidebar">
                <div class="dv-mock-tab dv-mt-active">85%<span class="dv-mt-food">Food</span></div>
                <div class="dv-mock-tab">95%<span class="dv-mt-nf">NF</span></div>
                <div class="dv-mock-tab">98%<span class="dv-mt-usp">USP</span></div>
                <div class="dv-mock-tab">99%<span class="dv-mt-ip">IP</span></div>
              </div>
              <div class="dv-mock-panel">
                <div class="dv-mock-panel-pct">85%</div>
                <div class="dv-mock-panel-stats">
                  <div class="dv-mock-stat"></div>
                  <div class="dv-mock-stat"></div>
                  <div class="dv-mock-stat"></div>
                </div>
                <div class="dv-mock-panel-fits">
                  <div class="dv-mock-fit-row"><div class="dv-mock-fit-no"></div></div>
                  <div class="dv-mock-fit-row"><div class="dv-mock-fit-cond"></div></div>
                  <div class="dv-mock-fit-row"><div class="dv-mock-fit-yes"></div></div>
                  <div class="dv-mock-fit-row"><div class="dv-mock-fit-yes"></div></div>
                </div>
              </div>
            </div>
          </div>
          <div class="dv-card-body">
            <div class="dv-card-label">Variant B</div>
            <h2 class="dv-card-title">The Explorer</h2>
            <p class="dv-card-tagline">Two-panel layout — sticky grade tabs on the left, full content on the right.</p>
            <ul class="dv-card-features">
              <li>Dark sidebar with clickable grade tabs</li>
              <li>Per-grade content panel with stats + fit + FAQ</li>
              <li>JS-powered tab switching, no page reload</li>
              <li>Full spec table below the explorer</li>
            </ul>
            <span class="dv-card-cta">View Variant B →</span>
          </div>
        </a>

        <!-- VARIANT C -->
        <a href="/design-variants/variant-c" class="dv-card">
          <div class="dv-card-preview dv-preview-c">
            <div class="dv-mock-config">
              <div class="dv-mock-chips">
                <div class="dv-mock-chip dv-chip-active">
                  <div class="dv-chip-icon-mock"></div>
                  <div class="dv-chip-text-mock">Pharma</div>
                </div>
                <div class="dv-mock-chip">
                  <div class="dv-chip-icon-mock"></div>
                  <div class="dv-chip-text-mock">Nutra</div>
                </div>
                <div class="dv-mock-chip">
                  <div class="dv-chip-icon-mock"></div>
                  <div class="dv-chip-text-mock">Food</div>
                </div>
                <div class="dv-mock-chip">
                  <div class="dv-chip-icon-mock"></div>
                  <div class="dv-chip-text-mock">Feed</div>
                </div>
              </div>
              <div class="dv-mock-rec-card">
                <div class="dv-mock-rec-label">Recommended</div>
                <div class="dv-mock-rec-grades">
                  <span class="dv-rec-usp">98%</span>
                  <span class="dv-rec-ip">99%</span>
                </div>
              </div>
              <div class="dv-mock-table-preview">
                <div class="dv-mock-col dv-col-dim"></div>
                <div class="dv-mock-col dv-col-dim"></div>
                <div class="dv-mock-col dv-col-hl"></div>
                <div class="dv-mock-col dv-col-hl"></div>
              </div>
            </div>
          </div>
          <div class="dv-card-body">
            <div class="dv-card-label">Variant C</div>
            <h2 class="dv-card-title">The Configurator</h2>
            <p class="dv-card-tagline">Application-first. Buyer selects their use case, page highlights the matching grade.</p>
            <ul class="dv-card-features">
              <li>4 large application selector chips with icons</li>
              <li>Animated recommendation card on selection</li>
              <li>Spec table columns highlight / dim by fit</li>
              <li>Grade cards also animate to reflect selection</li>
            </ul>
            <span class="dv-card-cta">View Variant C →</span>
          </div>
        </a>

        <!-- VARIANT D -->
        <a href="/design-variants/variant-d" class="dv-card">
          <div class="dv-card-preview dv-preview-d">
            <div class="dv-mock-dashboard">
              <div class="dv-mock-dark-hero">
                <div class="dv-mock-grade-cards">
                  <div class="dv-mock-gcard dv-gcard--food"><span>85</span></div>
                  <div class="dv-mock-gcard dv-gcard--nf"><span>95</span></div>
                  <div class="dv-mock-gcard dv-gcard--usp"><span>98</span></div>
                  <div class="dv-mock-gcard dv-gcard--ip"><span>99</span></div>
                </div>
              </div>
              <div class="dv-mock-bars-section">
                <div class="dv-mock-hbar-row"><div class="dv-mock-hbar dv-hbar--food" style="width:60%"></div></div>
                <div class="dv-mock-hbar-row"><div class="dv-mock-hbar dv-hbar--nf" style="width:80%"></div></div>
                <div class="dv-mock-hbar-row"><div class="dv-mock-hbar dv-hbar--usp" style="width:90%"></div></div>
                <div class="dv-mock-hbar-row"><div class="dv-mock-hbar dv-hbar--ip" style="width:100%"></div></div>
              </div>
            </div>
          </div>
          <div class="dv-card-body">
            <div class="dv-card-label">Variant D</div>
            <h2 class="dv-card-title">The Dashboard</h2>
            <p class="dv-card-tagline">Data-forward. Treat it like a spec sheet meets a analytics dashboard.</p>
            <ul class="dv-card-features">
              <li>Dark hero with huge purity numbers + grade cards</li>
              <li>Visual horizontal bar charts for swell volume &amp; purity</li>
              <li>Fully-colored application matrix cells</li>
              <li>Horizontal scrolling grade carousel</li>
            </ul>
            <span class="dv-card-cta">View Variant D →</span>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- QUICK COMPARISON TABLE -->
  <section class="dv-compare-section">
    <div class="dv-c">
      <h2 class="dv-compare-title">At a glance</h2>
      <div class="dv-compare-scroll">
        <table class="dv-compare-table">
          <thead>
            <tr>
              <th>Criterion</th>
              <th>A · Scanner</th>
              <th>B · Explorer</th>
              <th>C · Configurator</th>
              <th>D · Dashboard</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="dv-ct-label">Buyer entry point</td>
              <td>Compliance tier</td>
              <td>Grade selection</td>
              <td>Use case / application</td>
              <td>Data / numbers</td>
            </tr>
            <tr>
              <td class="dv-ct-label">Info architecture</td>
              <td>Sequential scan</td>
              <td>Tab explore</td>
              <td>Filter + highlight</td>
              <td>Data dashboard</td>
            </tr>
            <tr>
              <td class="dv-ct-label">Interactivity</td>
              <td>None — pure CSS</td>
              <td>Tab switching (JS)</td>
              <td>Selection + filter (JS)</td>
              <td>None — pure CSS</td>
            </tr>
            <tr>
              <td class="dv-ct-label">Best for buyer type</td>
              <td>QA teams scanning compliance</td>
              <td>Technical buyers exploring grades</td>
              <td>First-time buyers unsure of grade</td>
              <td>Data-driven procurement teams</td>
            </tr>
            <tr>
              <td class="dv-ct-label">Mobile experience</td>
              <td>Full layout, stacks cleanly</td>
              <td>Horizontal tab strip</td>
              <td>Chips stack 2-col</td>
              <td>Horizontal scroll carousel</td>
            </tr>
            <tr>
              <td class="dv-ct-label">Dev complexity</td>
              <td class="dv-ct-low">Low</td>
              <td class="dv-ct-med">Medium</td>
              <td class="dv-ct-med">Medium</td>
              <td class="dv-ct-low">Low</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

</div>

<style>
  :root {
    --dv-ink: #1a1c18; --dv-soft: #484c43; --dv-mute: #6b6f65;
    --dv-rule: rgba(26,28,24,0.1); --dv-sage: #4a6630;
    --dv-cream: #f5f3ed; --dv-white: #ffffff;
    --food-c: #64748b; --food-lt: #f1f5f9;
    --nf-c: #2563eb;   --nf-lt: #eff6ff;
    --usp-c: #7c3aed;  --usp-lt: #f5f3ff;
    --ip-c: #b45309;   --ip-lt: #fef3c7;
  }

  .dv { font-family: 'Inter', system-ui, sans-serif; color: var(--dv-ink); }
  .dv *, .dv *::before, .dv *::after { box-sizing: border-box; }
  .dv-c { width: min(1160px, calc(100% - 80px)); margin-inline: auto; }

  /* hero */
  .dv-hero {
    background: var(--dv-ink); padding: clamp(4rem,7vw,7rem) 0 clamp(3rem,5vw,5rem);
    text-align: center;
  }
  .dv-eyebrow { font-size: 11px; font-weight: 600; letter-spacing: 0.07em; text-transform: uppercase; color: rgba(255,255,255,0.3); margin: 0 0 20px; }
  .dv-hero h1 {
    margin: 0; color: #fff; font-size: clamp(2.4rem,5vw,4.2rem);
    font-weight: 800; letter-spacing: -0.04em; line-height: 1.02;
  }
  .dv-hero h1 em { color: #7aad54; font-style: italic; font-weight: 300; }
  .dv-hero-sub { margin: 20px auto 0; color: rgba(255,255,255,0.5); font-size: 15px; line-height: 1.7; max-width: 640px; }

  /* variant grid */
  .dv-grid-section { padding: clamp(4rem,6vw,6rem) 0; }
  .dv-variants { display: grid; grid-template-columns: repeat(2,1fr); gap: 24px; }

  /* variant card */
  .dv-card {
    display: flex; flex-direction: column;
    border: 1.5px solid var(--dv-rule); border-radius: 16px; overflow: hidden;
    text-decoration: none; color: inherit;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
    background: var(--dv-white);
  }
  .dv-card:hover {
    border-color: var(--dv-sage); transform: translateY(-4px);
    box-shadow: 0 16px 48px -12px rgba(74,102,48,0.2);
  }

  /* card previews */
  .dv-card-preview {
    height: 220px; overflow: hidden; position: relative;
    border-bottom: 1.5px solid var(--dv-rule);
  }
  .dv-preview-a { background: var(--dv-cream); padding: 16px; display: flex; flex-direction: column; gap: 10px; }
  .dv-preview-b { background: #f8f6f0; display: flex; padding: 0; }
  .dv-preview-c { background: var(--dv-cream); padding: 16px; display: flex; flex-direction: column; gap: 10px; }
  .dv-preview-d { background: #0d1a09; padding: 0; display: flex; flex-direction: column; }

  /* A mockup */
  .dv-mock-hero { display: flex; justify-content: space-between; gap: 10px; }
  .dv-mock-text { display: flex; flex-direction: column; gap: 6px; flex: 1; padding-top: 4px; }
  .dv-mock-h { height: 14px; background: var(--dv-ink); border-radius: 3px; width: 70%; opacity: 0.8; }
  .dv-mock-line { height: 7px; background: var(--dv-rule); border-radius: 3px; }
  .dv-mock-line--short { width: 50%; }
  .dv-mock-tiers { display: flex; gap: 5px; }
  .dv-mock-tier {
    width: 44px; height: 56px; border-radius: 6px; display: flex; align-items: center;
    justify-content: center; font-size: 11px; font-weight: 700; color: #fff;
  }
  .dv-mt--food { background: var(--food-c); }
  .dv-mt--nf   { background: var(--nf-c); }
  .dv-mt--usp  { background: var(--usp-c); }
  .dv-mt--ip   { background: var(--ip-c); }
  .dv-mock-matrix { flex: 1; }
  .dv-mock-matrix-inner { display: grid; grid-template-columns: repeat(4,1fr); gap: 3px; }
  .dv-mock-cell { height: 20px; border-radius: 3px; }
  .dv-mc--yes  { background: #dcfce7; }
  .dv-mc--cond { background: #fef9c3; }
  .dv-mc--no   { background: #fee2e2; }
  .dv-mc--none { background: #f3f4f6; }
  .dv-mock-bars { display: flex; flex-direction: column; gap: 5px; }
  .dv-mock-bar-row { height: 12px; background: rgba(0,0,0,0.06); border-radius: 4px; overflow: hidden; }
  .dv-mock-bar { height: 100%; border-radius: 4px; }
  .dv-mbar--food { background: var(--food-c); } .dv-mbar--nf { background: var(--nf-c); }
  .dv-mbar--usp  { background: var(--usp-c); } .dv-mbar--ip { background: var(--ip-c); }

  /* B mockup */
  .dv-mock-explorer { display: flex; width: 100%; height: 100%; }
  .dv-mock-sidebar { background: #1e2a16; width: 90px; padding: 12px 8px; display: flex; flex-direction: column; gap: 6px; }
  .dv-mock-tab {
    padding: 8px 8px; border-radius: 6px; font-size: 11px; font-weight: 700;
    color: rgba(255,255,255,0.4); display: flex; flex-direction: column; gap: 3px;
    cursor: default;
  }
  .dv-mt-active { background: rgba(255,255,255,0.1); color: #fff; border: 1px solid rgba(255,255,255,0.2); }
  .dv-mock-tab span { font-size: 8px; font-weight: 600; border-radius: 999px; padding: 1px 5px; width: fit-content; }
  .dv-mt-food { background: var(--food-lt); color: var(--food-c); }
  .dv-mt-nf   { background: var(--nf-lt);   color: var(--nf-c); }
  .dv-mt-usp  { background: var(--usp-lt);  color: var(--usp-c); }
  .dv-mt-ip   { background: var(--ip-lt);   color: var(--ip-c); }
  .dv-mock-panel { flex: 1; padding: 14px; display: flex; flex-direction: column; gap: 10px; }
  .dv-mock-panel-pct { font-size: 28px; font-weight: 800; letter-spacing: -0.04em; color: var(--dv-ink); }
  .dv-mock-panel-stats { display: grid; grid-template-columns: repeat(3,1fr); gap: 6px; }
  .dv-mock-stat { height: 32px; background: var(--dv-cream); border-radius: 6px; }
  .dv-mock-panel-fits { display: flex; flex-direction: column; gap: 4px; }
  .dv-mock-fit-row { height: 12px; display: flex; gap: 6px; align-items: center; }
  .dv-mock-fit-row::before { content: ''; display: block; flex: 1; height: 6px; background: var(--dv-rule); border-radius: 3px; }
  .dv-mock-fit-yes, .dv-mock-fit-cond, .dv-mock-fit-no { width: 60px; height: 12px; border-radius: 999px; }
  .dv-mock-fit-yes  { background: #dcfce7; } .dv-mock-fit-cond { background: #fef9c3; } .dv-mock-fit-no { background: #fee2e2; }

  /* C mockup */
  .dv-mock-config { display: flex; flex-direction: column; gap: 10px; }
  .dv-mock-chips { display: grid; grid-template-columns: repeat(4,1fr); gap: 6px; }
  .dv-mock-chip {
    border: 1.5px solid var(--dv-rule); border-radius: 8px; padding: 8px 6px;
    display: flex; flex-direction: column; gap: 5px; align-items: center;
    background: var(--dv-white);
  }
  .dv-chip-active { border-color: var(--dv-sage); background: #f0f5e8; }
  .dv-chip-icon-mock { width: 18px; height: 18px; background: var(--dv-rule); border-radius: 4px; }
  .dv-chip-active .dv-chip-icon-mock { background: var(--dv-sage); opacity: 0.4; }
  .dv-chip-text-mock { font-size: 9px; font-weight: 600; color: var(--dv-mute); }
  .dv-mock-rec-card {
    border: 2px solid var(--dv-sage); border-radius: 8px; padding: 8px 12px;
    background: #f0f5e8; display: flex; align-items: center; gap: 12px;
  }
  .dv-mock-rec-label { font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--dv-sage); }
  .dv-mock-rec-grades { display: flex; gap: 6px; }
  .dv-rec-usp { background: var(--usp-lt); color: var(--usp-c); font-size: 11px; font-weight: 700; padding: 3px 8px; border-radius: 999px; }
  .dv-rec-ip  { background: var(--ip-lt);  color: var(--ip-c);  font-size: 11px; font-weight: 700; padding: 3px 8px; border-radius: 999px; }
  .dv-mock-table-preview { display: grid; grid-template-columns: repeat(4,1fr); gap: 4px; height: 40px; }
  .dv-mock-col { border-radius: 4px; }
  .dv-col-dim { background: var(--dv-rule); opacity: 0.4; }
  .dv-col-hl  { background: #d8e0c8; }

  /* D mockup */
  .dv-mock-dashboard { display: flex; flex-direction: column; height: 100%; }
  .dv-mock-dark-hero { background: #0d1a09; flex: 1; padding: 12px; }
  .dv-mock-grade-cards { display: grid; grid-template-columns: repeat(4,1fr); gap: 6px; height: 100%; }
  .dv-mock-gcard {
    border-radius: 6px; display: flex; align-items: center; justify-content: center;
    font-size: 22px; font-weight: 800; color: rgba(255,255,255,0.8);
    border-left: 3px solid transparent;
  }
  .dv-gcard--food { border-left-color: #94a3b8; background: rgba(255,255,255,0.04); }
  .dv-gcard--nf   { border-left-color: #60a5fa; background: rgba(37,99,235,0.1); }
  .dv-gcard--usp  { border-left-color: #a78bfa; background: rgba(124,58,237,0.1); }
  .dv-gcard--ip   { border-left-color: #fbbf24; background: rgba(180,83,9,0.1); }
  .dv-mock-bars-section { padding: 10px; display: flex; flex-direction: column; gap: 5px; }
  .dv-mock-hbar-row { height: 14px; background: rgba(0,0,0,0.06); border-radius: 4px; overflow: hidden; }
  .dv-mock-hbar { height: 100%; border-radius: 4px; }
  .dv-hbar--food { background: var(--food-c); } .dv-hbar--nf { background: var(--nf-c); }
  .dv-hbar--usp  { background: var(--usp-c); } .dv-hbar--ip { background: var(--ip-c); }

  /* card body */
  .dv-card-body { padding: 24px 28px; display: flex; flex-direction: column; gap: 10px; flex: 1; }
  .dv-card-label { font-size: 10px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--dv-sage); }
  .dv-card-title { margin: 0; font-size: 1.5rem; font-weight: 800; letter-spacing: -0.03em; color: var(--dv-ink); }
  .dv-card-tagline { margin: 0; color: var(--dv-soft); font-size: 13px; line-height: 1.55; }
  .dv-card-features { margin: 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 5px; }
  .dv-card-features li { font-size: 12px; color: var(--dv-mute); padding-left: 14px; position: relative; line-height: 1.4; }
  .dv-card-features li::before { content: '·'; position: absolute; left: 0; color: var(--dv-sage); font-weight: 700; }
  .dv-card-cta { margin-top: auto; font-size: 13px; font-weight: 700; color: var(--dv-sage); }

  /* comparison table */
  .dv-compare-section { padding: clamp(4rem,6vw,6rem) 0; background: var(--dv-cream); }
  .dv-compare-title { margin: 0 0 24px; font-size: clamp(1.4rem,2.5vw,2rem); font-weight: 800; letter-spacing: -0.025em; color: var(--dv-ink); }
  .dv-compare-scroll { overflow-x: auto; border: 1px solid var(--dv-rule); border-radius: 10px; background: var(--dv-white); }
  .dv-compare-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .dv-compare-table thead { background: #f9f8f5; border-bottom: 1.5px solid var(--dv-rule); }
