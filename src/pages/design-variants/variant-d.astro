---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Variant D: The Dashboard — Psyllium Husk | RM Psyllium"
  description="Design variant D: data-forward product dashboard with visual spec comparison."
  noindex={true}
>

<div class="vd">

  <!-- VARIANT NAV -->
  <nav class="vd-vnav">
    <a href="/design-variants/" class="vd-vnav-back">← All variants</a>
    <div class="vd-vnav-pills">
      <a href="/design-variants/variant-a" class="vd-vnav-pill">A · Scanner</a>
      <a href="/design-variants/variant-b" class="vd-vnav-pill">B · Explorer</a>
      <a href="/design-variants/variant-c" class="vd-vnav-pill">C · Configurator</a>
      <span class="vd-vnav-pill vd-vnav-pill--active">D · Dashboard</span>
    </div>
    <a href="/design-variants/" class="vd-vnav-next">All variants</a>
  </nav>

  <!-- HERO (dark, data-forward) -->
  <section class="vd-hero">
    <div class="vd-c">
      <div class="vd-hero-top">
        <div>
          <p class="vd-hero-eyebrow">Plantago ovata · Whole Husk · Unjha, Gujarat</p>
          <h1>Psyllium Husk</h1>
          <p class="vd-hero-sub">85% to 99% purity · 4 pharmacopoeia tiers · 500 kg MOQ FOB Mundra</p>
        </div>
        <a class="vd-btn vd-btn-light" href="#quote">Request Quote →</a>
      </div>

      <!-- GRADE CARDS (dark section, big numbers) -->
      <div class="vd-grade-dashboard">
        <div class="vd-gdash-card vd-gdash--food">
          <div class="vd-gdash-num">85</div>
          <div class="vd-gdash-unit">%</div>
          <div class="vd-gdash-info">
            <span class="vd-gdash-pharma">Food Grade</span>
            <span class="vd-gdash-swell">30 ml/g</span>
            <span class="vd-gdash-note">Animal feed · industrial fibre · cost-sensitive food</span>
          </div>
        </div>
        <div class="vd-gdash-card vd-gdash--nf">
          <div class="vd-gdash-num">95</div>
          <div class="vd-gdash-unit">%</div>
          <div class="vd-gdash-info">
            <span class="vd-gdash-pharma">Food / NF</span>
            <span class="vd-gdash-swell">40 ml/g</span>
            <span class="vd-gdash-note">Supplement sachets · NF food fibre · functional cereal</span>
          </div>
        </div>
        <div class="vd-gdash-card vd-gdash--usp">
          <div class="vd-gdash-num">98</div>
          <div class="vd-gdash-unit">%</div>
          <div class="vd-gdash-info">
            <span class="vd-gdash-pharma">USP / EP</span>
            <span class="vd-gdash-swell">45 ml/g</span>
            <span class="vd-gdash-note">Pharma capsule fills · laxative sachets · OTC supplement</span>
          </div>
        </div>
        <div class="vd-gdash-card vd-gdash--ip">
          <div class="vd-gdash-num">99</div>
          <div class="vd-gdash-unit">%</div>
          <div class="vd-gdash-info">
            <span class="vd-gdash-pharma">USP / EP / IP</span>
            <span class="vd-gdash-swell">50 ml/g</span>
            <span class="vd-gdash-note">USP/EP/IP laxative monographs · premium OTC brands</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SPEC EXPLORER (visual bar rows) -->
  <section class="vd-section">
    <div class="vd-c">
      <p class="vd-kicker">Spec Explorer</p>
      <h2 class="vd-h2">Key parameters by grade</h2>

      <!-- Swell Volume — bar chart -->
      <div class="vd-spec-block">
        <div class="vd-spec-block-header">
          <span class="vd-spec-name">Swell Volume</span>
          <span class="vd-spec-unit">ml/g minimum — higher is better</span>
        </div>
        <div class="vd-bars">
          <div class="vd-bar-row">
            <span class="vd-bar-grade vd-bar-grade--food">85%</span>
            <div class="vd-bar-track"><div class="vd-bar-fill vd-bar-fill--food" style="width:60%"><span class="vd-bar-val">30</span></div></div>
          </div>
          <div class="vd-bar-row">
            <span class="vd-bar-grade vd-bar-grade--nf">95%</span>
            <div class="vd-bar-track"><div class="vd-bar-fill vd-bar-fill--nf" style="width:80%"><span class="vd-bar-val">40</span></div></div>
          </div>
          <div class="vd-bar-row">
            <span class="vd-bar-grade vd-bar-grade--usp">98%</span>
            <div class="vd-bar-track"><div class="vd-bar-fill vd-bar-fill--usp" style="width:90%"><span class="vd-bar-val">45</span></div></div>
          </div>
          <div class="vd-bar-row">
            <span class="vd-bar-grade vd-bar-grade--ip">99%</span>
            <div class="vd-bar-track"><div class="vd-bar-fill vd-bar-fill--ip" style="width:100%"><span class="vd-bar-val">50</span></div></div>
          </div>
        </div>
      </div>

      <!-- Purity — bar chart -->
      <div class="vd-spec-block">
        <div class="vd-spec-block-header">
          <span class="vd-spec-name">Purity (Husk Content)</span>
          <span class="vd-spec-unit">% — higher is better</span>
        </div>
        <div class="vd-bars">
          <div class="vd-bar-row">
            <span class="vd-bar-grade vd-bar-grade--food">85%</span>
            <div class="vd-bar-track"><div class="vd-bar-fill vd-bar-fill--food" style="width:85%"><span class="vd-bar-val">≥85%</span></div></div>
          </div>
          <div class="vd-bar-row">
            <span class="vd-bar-grade vd-bar-grade--nf">95%</span>
            <div class="vd-bar-track"><div class="vd-bar-fill vd-bar-fill--nf" style="width:95%"><span class="vd-bar-val">≥95%</span></div></div>
          </div>
          <div class="vd-bar-row">
            <span class="vd-bar-grade vd-bar-grade--usp">98%</span>
            <div class="vd-bar-track"><div class="vd-bar-fill vd-bar-fill--usp" style="width:98%"><span class="vd-bar-val">≥98%</span></div></div>
          </div>
          <div class="vd-bar-row">
            <span class="vd-bar-grade vd-bar-grade--ip">99%</span>
            <div class="vd-bar-track"><div class="vd-bar-fill vd-bar-fill--ip" style="width:99%"><span class="vd-bar-val">≥99%</span></div></div>
          </div>
        </div>
      </div>

      <!-- Other params as pill grid -->
      <div class="vd-param-pills-grid">
        <div class="vd-param-group">
          <p class="vd-param-group-label">Total Ash (% max) — lower is better</p>
          <div class="vd-param-pills">
            <span class="vd-ppill vd-ppill--food">85% → 4.0</span>
            <span class="vd-ppill vd-ppill--nf">95% → 4.0</span>
            <span class="vd-ppill vd-ppill--usp">98% → 3.5</span>
            <span class="vd-ppill vd-ppill--ip">99% → 3.0</span>
          </div>
        </div>
        <div class="vd-param-group">
          <p class="vd-param-group-label">Acid-insoluble Ash (% max) — lower is better</p>
          <div class="vd-param-pills">
            <span class="vd-ppill vd-ppill--food">85% → 1.0</span>
            <span class="vd-ppill vd-ppill--nf">95% → 0.8</span>
            <span class="vd-ppill vd-ppill--usp">98% → 0.5</span>
            <span class="vd-ppill vd-ppill--ip">99% → 0.4</span>
          </div>
        </div>
        <div class="vd-param-group">
          <p class="vd-param-group-label">Moisture (% max)</p>
          <div class="vd-param-pills">
            <span class="vd-ppill vd-ppill--neutral">All grades → ≤12%</span>
          </div>
        </div>
        <div class="vd-param-group">
          <p class="vd-param-group-label">Microbiology</p>
          <div class="vd-param-pills">
            <span class="vd-ppill vd-ppill--pass">E. coli — Absent all grades</span>
            <span class="vd-ppill vd-ppill--pass">Salmonella — Absent all grades</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- APPLICATION FIT MATRIX (filled cells) -->
  <section class="vd-section vd-section-cream">
    <div class="vd-c">
      <p class="vd-kicker">Application Fit</p>
      <h2 class="vd-h2">Grade suitability by industry</h2>
      <div class="vd-matrix-wrap">
        <div class="vd-matrix-grid">
          <!-- header row -->
          <div class="vd-matrix-header vd-matrix-corner"></div>
          <div class="vd-matrix-header vd-matrix-col-food"><span>85%</span><small>Food</small></div>
          <div class="vd-matrix-header vd-matrix-col-nf"><span>95%</span><small>NF</small></div>
          <div class="vd-matrix-header vd-matrix-col-usp"><span>98%</span><small>USP/EP</small></div>
          <div class="vd-matrix-header vd-matrix-col-ip"><span>99%</span><small>USP/EP/IP</small></div>
          <!-- row 1 -->
          <div class="vd-matrix-app">Pharma / Laxative</div>
          <div class="vd-matrix-cell vd-cell-no"><span>✗</span><small>Not suitable</small></div>
          <div class="vd-matrix-cell vd-cell-cond"><span>◑</span><small>Conditional</small></div>
          <div class="vd-matrix-cell vd-cell-yes"><span>✓</span><small>Primary</small></div>
          <div class="vd-matrix-cell vd-cell-yes"><span>✓</span><small>Primary</small></div>
          <!-- row 2 -->
          <div class="vd-matrix-app">Nutraceutical</div>
          <div class="vd-matrix-cell vd-cell-cond"><span>◑</span><small>Conditional</small></div>
          <div class="vd-matrix-cell vd-cell-yes"><span>✓</span><small>Primary</small></div>
          <div class="vd-matrix-cell vd-cell-yes"><span>✓</span><small>Primary</small></div>
          <div class="vd-matrix-cell vd-cell-yes"><span>✓</span><small>Primary</small></div>
          <!-- row 3 -->
          <div class="vd-matrix-app">Food &amp; Bakery</div>
          <div class="vd-matrix-cell vd-cell-yes"><span>✓</span><small>Primary</small></div>
          <div class="vd-matrix-cell vd-cell-yes"><span>✓</span><small>Primary</small></div>
          <div class="vd-matrix-cell vd-cell-cond"><span>◑</span><small>Conditional</small></div>
          <div class="vd-matrix-cell vd-cell-none"><span>—</span><small>Not used</small></div>
          <!-- row 4 -->
          <div class="vd-matrix-app">Animal Feed</div>
          <div class="vd-matrix-cell vd-cell-yes"><span>✓</span><small>Primary</small></div>
          <div class="vd-matrix-cell vd-cell-cond"><span>◑</span><small>Conditional</small></div>
          <div class="vd-matrix-cell vd-cell-none"><span>—</span><small>Not used</small></div>
          <div class="vd-matrix-cell vd-cell-none"><span>—</span><small>Not used</small></div>
        </div>
      </div>
      <div class="vd-matrix-legend">
        <span class="vd-mleg vd-mleg-yes">✓ Primary fit</span>
        <span class="vd-mleg vd-mleg-cond">◑ Conditional</span>
        <span class="vd-mleg vd-mleg-no">✗ Not suitable</span>
        <span class="vd-mleg vd-mleg-none">— Not applicable</span>
      </div>
    </div>
  </section>

  <!-- KEY FACTS STRIP -->
  <section class="vd-facts-strip">
    <div class="vd-c">
      <div class="vd-facts-row">
        <div class="vd-fact">
          <span class="vd-fact-val">500 kg</span>
          <span class="vd-fact-label">Minimum order</span>
        </div>
        <div class="vd-fact-divider"></div>
        <div class="vd-fact">
          <span class="vd-fact-val">14–21 d</span>
          <span class="vd-fact-label">Lead time ex-Unjha</span>
        </div>
        <div class="vd-fact-divider"></div>
        <div class="vd-fact">
          <span class="vd-fact-val">FOB Mundra</span>
          <span class="vd-fact-label">Incoterm · COA included</span>
        </div>
        <div class="vd-fact-divider"></div>
        <div class="vd-fact">
          <span class="vd-fact-val">Gujarat, India</span>
          <span class="vd-fact-label">Country of origin</span>
        </div>
        <div class="vd-fact-divider"></div>
        <div class="vd-fact">
          <span class="vd-fact-val">USP · EP · NF · IP</span>
          <span class="vd-fact-label">Pharmacopoeias covered</span>
        </div>
      </div>
    </div>
  </section>

  <!-- GRADE CAROUSEL -->
  <section class="vd-section">
    <div class="vd-c">
      <p class="vd-kicker">Grade Details</p>
      <h2 class="vd-h2">Full spec per grade</h2>
    </div>
    <div class="vd-carousel-wrap">
      <div class="vd-carousel">

        <div class="vd-car-card vd-car--food">
          <div class="vd-car-pct">85%</div>
          <span class="vd-car-badge">Food Grade</span>
          <p class="vd-car-for">Animal feed · industrial fibre · cost-sensitive food. No pharmacopoeia annotation required.</p>
          <div class="vd-car-specs">
            <div class="vd-car-row"><span>Purity</span><span>≥85%</span></div>
            <div class="vd-car-row"><span>Swell vol</span><span>30 ml/g</span></div>
            <div class="vd-car-row"><span>Moisture</span><span>≤12%</span></div>
            <div class="vd-car-row"><span>Total Ash</span><span>≤4.0%</span></div>
            <div class="vd-car-row"><span>Mesh</span><span>20–40</span></div>
          </div>
          <div class="vd-car-apps">
            <span class="vd-car-app vd-car-app--yes">✓ Food</span>
            <span class="vd-car-app vd-car-app--yes">✓ Feed</span>
            <span class="vd-car-app vd-car-app--cond">◑ Nutri</span>
            <span class="vd-car-app vd-car-app--no">✗ Pharma</span>
          </div>
          <a class="vd-btn vd-btn-card" href="#quote">Request Quote</a>
        </div>

        <div class="vd-car-card vd-car--nf">
          <div class="vd-car-pct">95%</div>
          <span class="vd-car-badge">Food / NF</span>
          <p class="vd-car-for">Supplement sachets · NF food fibre · functional cereal. COA annotated to NF on request.</p>
          <div class="vd-car-specs">
            <div class="vd-car-row"><span>Purity</span><span>≥95%</span></div>
            <div class="vd-car-row"><span>Swell vol</span><span>40 ml/g</span></div>
            <div class="vd-car-row"><span>Moisture</span><span>≤12%</span></div>
            <div class="vd-car-row"><span>Total Ash</span><span>≤4.0%</span></div>
            <div class="vd-car-row"><span>Mesh</span><span>20–60</span></div>
          </div>
          <div class="vd-car-apps">
            <span class="vd-car-app vd-car-app--yes">✓ Food</span>
            <span class="vd-car-app vd-car-app--yes">✓ Nutri</span>
            <span class="vd-car-app vd-car-app--cond">◑ Pharma</span>
            <span class="vd-car-app vd-car-app--cond">◑ Feed</span>
          </div>
          <a class="vd-btn vd-btn-card" href="#quote">Request Quote</a>
        </div>

        <div class="vd-car-card vd-car--usp">
          <div class="vd-car-pct">98%</div>
          <span class="vd-car-badge">USP / EP</span>
          <p class="vd-car-for">Pharma capsule fills · laxative sachets · OTC supplement. NABL lab COA per shipment.</p>
          <div class="vd-car-specs">
            <div class="vd-car-row"><span>Purity</span><span>≥98%</span></div>
            <div class="vd-car-row"><span>Swell vol</span><span>45 ml/g</span></div>
            <div class="vd-car-row"><span>Moisture</span><span>≤12%</span></div>
            <div class="vd-car-row"><span>Total Ash</span><span>≤3.5%</span></div>
            <div class="vd-car-row"><span>Mesh</span><span>20–60</span></div>
          </div>
          <div class="vd-car-apps">
            <span class="vd-car-app vd-car-app--yes">✓ Pharma</span>
            <span class="vd-car-app vd-car-app--yes">✓ Nutri</span>
            <span class="vd-car-app vd-car-app--cond">◑ Food</span>
            <span class="vd-car-app vd-car-app--no">— Feed</span>
          </div>
          <a class="vd-btn vd-btn-card" href="#quote">Request Quote</a>
        </div>

        <div class="vd-car-card vd-car--ip">
          <div class="vd-car-pct">99%</div>
          <span class="vd-car-badge">USP / EP / IP</span>
          <p class="vd-car-for">USP/EP/IP laxative monographs · premium OTC digestive supplement. Highest swell volume.</p>
          <div class="vd-car-specs">
            <div class="vd-car-row"><span>Purity</span><span>≥99%</span></div>
            <div class="vd-car-row"><span>Swell vol</span><span>50 ml/g</span></div>
            <div class="vd-car-row"><span>Moisture</span><span>≤12%</span></div>
            <div class="vd-car-row"><span>Total Ash</span><span>≤3.0%</span></div>
            <div class="vd-car-row"><span>Mesh</span><span>20–60</span></div>
          </div>
          <div class="vd-car-apps">
            <span class="vd-car-app vd-car-app--yes">✓ Pharma</span>
            <span class="vd-car-app vd-car-app--yes">✓ Nutri</span>
            <span class="vd-car-app vd-car-app--no">— Food</span>
            <span class="vd-car-app vd-car-app--no">— Feed</span>
          </div>
          <a class="vd-btn vd-btn-card" href="#quote">Request Quote</a>
        </div>

      </div>
    </div>
  </section>

  <!-- QUOTE FORM -->
  <section class="vd-section vd-section-cream" id="quote">
    <div class="vd-c">
      <div class="vd-quote-grid">
        <div class="vd-quote-copy">
          <p class="vd-kicker">Request Quote</p>
          <h2 class="vd-h2">Get pricing and samples within 24 hours.</h2>
          <p class="vd-quote-sub">Share your grade, mesh, packing, destination, and monthly volume. Our export desk will respond within one business day with availability and next steps.</p>
        </div>
        <form class="vd-form">
          <div class="vd-ff">
            <label class="vd-fl">Product</label>
            <select class="vd-fi">
              <option>Psyllium Husk</option>
              <option>Psyllium Husk Powder</option>
              <option>Psyllium Seeds</option>
            </select>
          </div>
          <div class="vd-ff">
            <label class="vd-fl">Grade</label>
            <select class="vd-fi">
              <option>85% — Food Grade</option>
              <option>95% — Food / NF</option>
              <option>98% — USP / EP</option>
              <option>99% — USP / EP / IP</option>
            </select>
          </div>
          <div class="vd-ff-row">
            <div class="vd-ff">
              <label class="vd-fl">Monthly volume (kg)</label>
              <input class="vd-fi" type="text" placeholder="e.g. 2,000 kg" />
            </div>
            <div class="vd-ff">
              <label class="vd-fl">Destination</label>
              <input class="vd-fi" type="text" placeholder="Country / port" />
            </div>
          </div>
          <div class="vd-ff">
            <label class="vd-fl">Company email</label>
            <input class="vd-fi" type="email" placeholder="you@company.com" />
          </div>
          <button class="vd-btn vd-btn-submit" type="submit">Send Quote Request →</button>
        </form>
      </div>
    </div>
  </section>

</div>

<style>
  :root {
    --vd-ink: #1a1c18;
    --vd-soft: #484c43;
    --vd-mute: #6b6f65;
    --vd-rule: rgba(26,28,24,0.1);
    --vd-sage: #4a6630;
    --vd-cream: #f5f3ed;
    --vd-white: #ffffff;
    --vd-dark: #0d1a09;
    /* grade tier colors */
    --food-c: #64748b; --food-lt: #f1f5f9; --food-bdr: #94a3b8;
    --nf-c: #2563eb;   --nf-lt: #eff6ff;   --nf-bdr: #60a5fa;
    --usp-c: #7c3aed;  --usp-lt: #f5f3ff;  --usp-bdr: #a78bfa;
    --ip-c: #b45309;   --ip-lt: #fef3c7;   --ip-bdr: #fbbf24;
  }

  .vd { font-family: 'Inter', system-ui, sans-serif; color: var(--vd-ink); }
  .vd *, .vd *::before, .vd *::after { box-sizing: border-box; }
  .vd-c { width: min(1160px, calc(100% - 80px)); margin-inline: auto; }

  /* variant nav */
  .vd-vnav {
    background: #060d04; display: flex; align-items: center;
    gap: 16px; padding: 10px 40px; font-size: 12px;
  }
  .vd-vnav-back, .vd-vnav-next { color: rgba(255,255,255,0.35); text-decoration: none; white-space: nowrap; }
  .vd-vnav-back:hover, .vd-vnav-next:hover { color: #fff; }
  .vd-vnav-pills { display: flex; gap: 6px; flex: 1; justify-content: center; flex-wrap: wrap; }
  .vd-vnav-pill {
    padding: 4px 12px; border-radius: 999px; font-size: 11px; font-weight: 500;
    color: rgba(255,255,255,0.35); text-decoration: none;
    border: 1px solid rgba(255,255,255,0.1); white-space: nowrap;
  }
  .vd-vnav-pill--active { color: #fff; background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.25); }

  /* hero */
  .vd-hero { background: var(--vd-dark); padding: clamp(3rem,5vw,5rem) 0 0; }
  .vd-hero-top {
    display: flex; justify-content: space-between; align-items: flex-start;
    gap: 24px; margin-bottom: clamp(2.5rem,4vw,4rem);
  }
  .vd-hero-eyebrow {
    font-size: 11px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase;
    color: rgba(255,255,255,0.3); margin: 0 0 14px;
  }
  .vd-hero h1 {
    margin: 0; color: #fff;
    font-size: clamp(2.4rem,5vw,4.2rem); font-weight: 800; letter-spacing: -0.04em; line-height: 1;
  }
  .vd-hero-sub { margin: 14px 0 0; color: rgba(255,255,255,0.4); font-size: 13px; font-weight: 500; letter-spacing: 0.01em; }

  /* grade dashboard cards */
  .vd-grade-dashboard { display: grid; grid-template-columns: repeat(4,1fr); border-top: 1px solid rgba(255,255,255,0.08); }
  .vd-gdash-card {
    padding: clamp(1.5rem,3vw,2.5rem);
    border-right: 1px solid rgba(255,255,255,0.06);
    border-left: 4px solid transparent;
  }
  .vd-gdash-card:last-child { border-right: 0; }
  .vd-gdash--food { border-left-color: var(--food-bdr); }
  .vd-gdash--nf   { border-left-color: var(--nf-bdr); }
  .vd-gdash--usp  { border-left-color: var(--usp-bdr); }
  .vd-gdash--ip   { border-left-color: var(--ip-bdr); }
  .vd-gdash-num {
    font-size: clamp(3rem,5vw,5rem); font-weight: 800; letter-spacing: -0.05em;
