---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Variant C: The Configurator — Psyllium Husk | RM Psyllium"
  description="Design variant C: application-first grade selector. Choose your use case and find the right grade."
  noindex={true}
>

<div class="vc">

  <!-- VARIANT NAV -->
  <nav class="vc-vnav">
    <a href="/design-variants/" class="vc-vnav-back">← All variants</a>
    <div class="vc-vnav-pills">
      <a href="/design-variants/variant-a" class="vc-vnav-pill">A · Scanner</a>
      <a href="/design-variants/variant-b" class="vc-vnav-pill">B · Explorer</a>
      <span class="vc-vnav-pill vc-vnav-pill--active">C · Configurator</span>
      <a href="/design-variants/variant-d" class="vc-vnav-pill">D · Dashboard</a>
    </div>
    <a href="/design-variants/variant-d" class="vc-vnav-next">Next →</a>
  </nav>

  <!-- HERO -->
  <section class="vc-hero">
    <div class="vc-c">
      <p class="vc-kicker">Psyllium Husk · 4 grades · Gujarat, India</p>
      <h1>Find the right grade<br /><em>for your application.</em></h1>
      <p class="vc-hero-sub">Select what you're making below. We'll highlight the grade that fits — and explain why.</p>
    </div>
  </section>

  <!-- APPLICATION SELECTOR -->
  <section class="vc-selector">
    <div class="vc-c">
      <p class="vc-selector-label">What are you making?</p>
      <div class="vc-chips">

        <button class="vc-chip" data-app="pharma" type="button">
          <div class="vc-chip-icon">
            <svg width="28" height="28" viewBox="0 0 32 32" fill="none"><rect x="6" y="4" width="20" height="24" rx="3" stroke="currentColor" stroke-width="2"/><path d="M11 10h10M11 16h6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="22" cy="24" r="5" fill="currentColor" fill-opacity="0.15" stroke="currentColor" stroke-width="1.5"/><path d="M20 24h4M22 22v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </div>
          <div class="vc-chip-text">
            <span class="vc-chip-title">Pharma / Laxative</span>
            <span class="vc-chip-desc">OTC laxative, capsule fill, registered monograph product</span>
          </div>
        </button>

        <button class="vc-chip" data-app="nutraceutical" type="button">
          <div class="vc-chip-icon">
            <svg width="28" height="28" viewBox="0 0 32 32" fill="none"><ellipse cx="16" cy="16" rx="10" ry="7" stroke="currentColor" stroke-width="2"/><path d="M6 16c0 3.87 4.48 7 10 7s10-3.13 10-7" stroke="currentColor" stroke-width="2"/><path d="M16 9v14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </div>
          <div class="vc-chip-text">
            <span class="vc-chip-title">Supplement / Nutraceutical</span>
            <span class="vc-chip-desc">Dietary fibre capsule, sachet, fibre blend, supplement brand</span>
          </div>
        </button>

        <button class="vc-chip" data-app="food" type="button">
          <div class="vc-chip-icon">
            <svg width="28" height="28" viewBox="0 0 32 32" fill="none"><path d="M8 26V14a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M5 26h22" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M13 12V8a3 3 0 0 1 6 0v4" stroke="currentColor" stroke-width="2"/></svg>
          </div>
          <div class="vc-chip-text">
            <span class="vc-chip-title">Food &amp; Bakery</span>
            <span class="vc-chip-desc">Gluten-free bread, cereal, functional food fibre enrichment</span>
          </div>
        </button>

        <button class="vc-chip" data-app="feed" type="button">
          <div class="vc-chip-icon">
            <svg width="28" height="28" viewBox="0 0 32 32" fill="none"><path d="M6 20c0-5.52 4.48-10 10-10s10 4.48 10 10" stroke="currentColor" stroke-width="2"/><path d="M16 10V6M10 12.27l-2.83-2.83M22 12.27l2.83-2.83" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M8 24h16M10 28h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          </div>
          <div class="vc-chip-text">
            <span class="vc-chip-title">Animal Feed</span>
            <span class="vc-chip-desc">Cattle compound feed, feed fibre, khakha manufacturing</span>
          </div>
        </button>

      </div>

      <!-- RECOMMENDATION CARD (hidden until selection) -->
      <div class="vc-rec" id="vc-rec" hidden>
        <div class="vc-rec-inner">
          <div class="vc-rec-left">
            <p class="vc-rec-for">For <strong id="vc-rec-app"></strong>, we recommend:</p>
            <div class="vc-rec-grades" id="vc-rec-grades"></div>
          </div>
          <p class="vc-rec-reason" id="vc-rec-reason"></p>
        </div>
      </div>
    </div>
  </section>

  <!-- SPEC TABLE (columns highlight/dim based on selection) -->
  <section class="vc-section vc-section-cream">
    <div class="vc-c">
      <p class="vc-kicker">Specifications</p>
      <h2 class="vc-h2">Compare all grades</h2>
      <div class="vc-spec-scroll">
        <table class="vc-spec" id="vc-spec-table">
          <thead>
            <tr>
              <th class="vc-spec-param-th">Parameter</th>
              <th data-grade="85"><div class="vc-th-inner"><span class="vc-th-pct">85%</span><span class="vc-badge vc-badge-food">Food</span><span class="vc-rec-badge" id="vc-rb-85">Recommended</span></div></th>
              <th data-grade="95"><div class="vc-th-inner"><span class="vc-th-pct">95%</span><span class="vc-badge vc-badge-nf">NF</span><span class="vc-rec-badge" id="vc-rb-95">Recommended</span></div></th>
              <th data-grade="98"><div class="vc-th-inner"><span class="vc-th-pct">98%</span><span class="vc-badge vc-badge-usp">USP/EP</span><span class="vc-rec-badge" id="vc-rb-98">Recommended</span></div></th>
              <th data-grade="99"><div class="vc-th-inner"><span class="vc-th-pct">99%</span><span class="vc-badge vc-badge-ip">USP/EP/IP</span><span class="vc-rec-badge" id="vc-rb-99">Recommended</span></div></th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="vc-spec-param">Purity (husk %)</td>
              <td data-grade="85">≥85%</td><td data-grade="95">≥95%</td><td data-grade="98">≥98%</td><td data-grade="99">≥99%</td>
            </tr>
            <tr>
              <td class="vc-spec-param">Swell Volume (ml/g)</td>
              <td data-grade="85">30</td><td data-grade="95">40</td><td data-grade="98">45</td><td data-grade="99">50</td>
            </tr>
            <tr>
              <td class="vc-spec-param">Moisture (% max)</td>
              <td data-grade="85">≤12%</td><td data-grade="95">≤12%</td><td data-grade="98">≤12%</td><td data-grade="99">≤12%</td>
            </tr>
            <tr>
              <td class="vc-spec-param">Total Ash (% max)</td>
              <td data-grade="85">4.0</td><td data-grade="95">4.0</td><td data-grade="98">3.5</td><td data-grade="99">3.0</td>
            </tr>
            <tr>
              <td class="vc-spec-param">Acid-insoluble Ash</td>
              <td data-grade="85">1.0</td><td data-grade="95">0.8</td><td data-grade="98">0.5</td><td data-grade="99">0.4</td>
            </tr>
            <tr>
              <td class="vc-spec-param">Mesh (ASTM)</td>
              <td data-grade="85">20–40</td><td data-grade="95">20–60</td><td data-grade="98">20–60</td><td data-grade="99">20–60</td>
            </tr>
            <tr>
              <td class="vc-spec-param">E. coli / Salmonella</td>
              <td data-grade="85" class="vc-pass">Absent</td><td data-grade="95" class="vc-pass">Absent</td><td data-grade="98" class="vc-pass">Absent</td><td data-grade="99" class="vc-pass">Absent</td>
            </tr>
            <tr>
              <td class="vc-spec-param">Pharmacopoeia</td>
              <td data-grade="85"><span class="vc-badge vc-badge-food">Food grade</span></td>
              <td data-grade="95"><span class="vc-badge vc-badge-nf">Food / NF</span></td>
              <td data-grade="98"><span class="vc-badge vc-badge-usp">USP / EP</span></td>
              <td data-grade="99"><span class="vc-badge vc-badge-ip">USP / EP / IP</span></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- CONDENSED GRADE CARDS -->
  <section class="vc-section">
    <div class="vc-c">
      <p class="vc-kicker">All Grades</p>
      <h2 class="vc-h2">What's in each grade</h2>
      <div class="vc-grade-row">
        <div class="vc-gcard" data-grade-card="85">
          <span class="vc-gcard-pct">85%</span>
          <span class="vc-badge vc-badge-food">Food Grade</span>
          <p class="vc-gcard-for">Animal feed, industrial fibre, cost-sensitive food applications.</p>
          <a class="vc-btn vc-btn-outline" href="#quote">Request Quote</a>
        </div>
        <div class="vc-gcard" data-grade-card="95">
          <span class="vc-gcard-pct">95%</span>
          <span class="vc-badge vc-badge-nf">Food / NF</span>
          <p class="vc-gcard-for">Supplement sachets, NF food fibre, functional cereal blends.</p>
          <a class="vc-btn vc-btn-outline" href="#quote">Request Quote</a>
        </div>
        <div class="vc-gcard" data-grade-card="98">
          <span class="vc-gcard-pct">98%</span>
          <span class="vc-badge vc-badge-usp">USP / EP</span>
          <p class="vc-gcard-for">Pharma capsule fills, laxative sachets, OTC supplement brands.</p>
          <a class="vc-btn vc-btn-dark" href="#quote">Request Quote</a>
        </div>
        <div class="vc-gcard" data-grade-card="99">
          <span class="vc-gcard-pct">99%</span>
          <span class="vc-badge vc-badge-ip">USP / EP / IP</span>
          <p class="vc-gcard-for">USP/EP/IP laxative monographs, premium OTC supplement brands.</p>
          <a class="vc-btn vc-btn-outline" href="#quote">Request Quote</a>
        </div>
      </div>
    </div>
  </section>

  <!-- QUOTE FORM -->
  <section class="vc-section vc-section-dark" id="quote">
    <div class="vc-c">
      <div class="vc-quote-grid">
        <div class="vc-quote-copy">
          <p class="vc-kicker vc-kicker-light">Request Quote</p>
          <h2 class="vc-h2 vc-h2-light">Get pricing and COA<br />within 24 hours.</h2>
          <p class="vc-quote-sub">Share your grade, mesh, packing, destination, and monthly volume. Our export desk will reply with availability and next steps.</p>
          <div class="vc-quote-facts">
            <div><strong>No minimum</strong><span>From 1 KG</span></div>
            <div><strong>14–21 d</strong><span>Lead time</span></div>
            <div><strong>FOB</strong><span>Mundra</span></div>
          </div>
        </div>
        <form class="vc-form">
          <div class="vc-ff">
            <label class="vc-fl">Product</label>
            <select class="vc-fi">
              <option>Psyllium Husk</option>
              <option>Psyllium Husk Powder</option>
              <option>Psyllium Seeds</option>
            </select>
          </div>
          <div class="vc-ff">
            <label class="vc-fl">Grade</label>
            <select class="vc-fi" id="vc-form-grade">
              <option value="85">85% — Food Grade</option>
              <option value="95">95% — Food / NF</option>
              <option value="98">98% — USP / EP</option>
              <option value="99">99% — USP / EP / IP</option>
            </select>
          </div>
          <div class="vc-ff-row">
            <div class="vc-ff">
              <label class="vc-fl">Monthly volume (kg)</label>
              <input class="vc-fi" type="text" placeholder="e.g. 2,000 kg" />
            </div>
            <div class="vc-ff">
              <label class="vc-fl">Destination</label>
              <input class="vc-fi" type="text" placeholder="Country / port" />
            </div>
          </div>
          <div class="vc-ff">
            <label class="vc-fl">Company email</label>
            <input class="vc-fi" type="email" placeholder="you@company.com" />
          </div>
          <button class="vc-btn vc-btn-submit" type="submit">Send Quote Request →</button>
        </form>
      </div>
    </div>
  </section>

</div>

<script>
  const appData = {
    pharma: {
      label: 'Pharma / Laxative',
      grades: ['98', '99'],
      reason: 'Both 98% and 99% grades meet USP and EP pharmacopoeia monograph requirements for laxative and OTC pharma products. COA annotated to USP, EP, or IP per lot from NABL-accredited lab.'
    },
    nutraceutical: {
      label: 'Supplement / Nutraceutical',
      grades: ['95', '98', '99'],
      reason: 'Choose based on your label annotation: 95% for NF-cited products, 98% for USP/EP, 99% for full USP/EP/IP. All three include COA per shipment. 95% is the most common choice for US supplement brands.'
    },
    food: {
      label: 'Food & Bakery',
      grades: ['85', '95'],
      reason: '85% grade is food-grade for animal feed and cost-sensitive applications. 95% NF is the standard choice for regulated food markets — dietary fibre labeling, functional cereals, and bakery enrichment.'
    },
    feed: {
      label: 'Animal Feed',
      grades: ['85'],
      reason: '85% grade is the primary and most cost-effective grade for cattle and compound animal feed. Supplied in 25 kg, 50 kg, and 1,000 kg jumbo bags FOB Mundra.'
    }
  };

  const badgeMap = {
    '85': { label: '85%', cls: 'food' },
    '95': { label: '95%', cls: 'nf' },
    '98': { label: '98%', cls: 'usp' },
    '99': { label: '99%', cls: 'ip' }
  };

  function vcSelect(appKey) {
    const app = appData[appKey];
    if (!app) return;

    // Update chip states
    document.querySelectorAll('.vc-chip').forEach(c => c.classList.remove('vc-chip--active'));
    const activeChip = document.querySelector(`[data-app="${appKey}"]`);
    if (activeChip) activeChip.classList.add('vc-chip--active');

    // Show recommendation card
    const rec = document.getElementById('vc-rec');
    rec.hidden = false;
    document.getElementById('vc-rec-app').textContent = app.label;
    document.getElementById('vc-rec-reason').textContent = app.reason;

    // Build grade pills
    const gradesEl = document.getElementById('vc-rec-grades');
    gradesEl.innerHTML = app.grades.map(g => {
      const b = badgeMap[g];
      return `<span class="vc-rec-grade-pill vc-rec-grade-pill--${b.cls}">${b.label}</span>`;
    }).join('');

    // Highlight/dim table columns
    const allGrades = ['85', '95', '98', '99'];
    allGrades.forEach(g => {
      const cells = document.querySelectorAll(`[data-grade="${g}"]`);
      const recBadge = document.getElementById(`vc-rb-${g}`);
      if (app.grades.includes(g)) {
        cells.forEach(c => { c.classList.add('vc-col-highlight'); c.classList.remove('vc-col-dim'); });
        if (recBadge) recBadge.style.display = 'inline-block';
      } else {
        cells.forEach(c => { c.classList.add('vc-col-dim'); c.classList.remove('vc-col-highlight'); });
        if (recBadge) recBadge.style.display = 'none';
      }
    });

    // Also highlight grade cards
    document.querySelectorAll('[data-grade-card]').forEach(c => {
      const g = c.getAttribute('data-grade-card');
      if (app.grades.includes(g)) {
        c.classList.add('vc-gcard--highlight');
        c.classList.remove('vc-gcard--dim');
      } else {
        c.classList.add('vc-gcard--dim');
        c.classList.remove('vc-gcard--highlight');
      }
    });

    // Pre-select recommended grade in form
    const formGrade = document.getElementById('vc-form-grade');
    if (formGrade && app.grades.length > 0) {
      formGrade.value = app.grades[0];
    }
  }

  // Attach to buttons
  document.querySelectorAll('.vc-chip').forEach(chip => {
    chip.addEventListener('click', () => vcSelect(chip.getAttribute('data-app')));
  });
</script>

<style>
  :root {
    --vc-ink: #1a1c18;
    --vc-soft: #484c43;
    --vc-mute: #6b6f65;
    --vc-rule: rgba(26,28,24,0.1);
    --vc-sage: #4a6630;
    --vc-pale: #d8e0c8;
    --vc-cream: #f5f3ed;
    --vc-white: #ffffff;
    --food-bg: #f1f5f9; --food-txt: #475569; --food-brd: #cbd5e1;
    --nf-bg: #eff6ff;   --nf-txt: #2563eb;   --nf-brd: #bfdbfe;
    --usp-bg: #f5f3ff;  --usp-txt: #7c3aed;  --usp-brd: #ddd6fe;
    --ip-bg: #fef3c7;   --ip-txt: #b45309;   --ip-brd: #fde68a;
  }

  .vc { font-family: 'Inter', system-ui, sans-serif; color: var(--vc-ink); }
  .vc *, .vc *::before, .vc *::after { box-sizing: border-box; }
  .vc-c { width: min(1100px, calc(100% - 96px)); margin-inline: auto; }

  /* variant nav */
  .vc-vnav {
    background: #2d1d3d; display: flex; align-items: center;
    gap: 16px; padding: 10px 48px; font-size: 12px;
  }
  .vc-vnav-back, .vc-vnav-next { color: rgba(255,255,255,0.4); text-decoration: none; white-space: nowrap; }
  .vc-vnav-back:hover, .vc-vnav-next:hover { color: #fff; }
  .vc-vnav-pills { display: flex; gap: 6px; flex: 1; justify-content: center; flex-wrap: wrap; }
  .vc-vnav-pill {
    padding: 4px 12px; border-radius: 999px; font-size: 11px; font-weight: 500;
    color: rgba(255,255,255,0.4); text-decoration: none;
    border: 1px solid rgba(255,255,255,0.12); white-space: nowrap;
  }
  .vc-vnav-pill--active { color: #fff; background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.25); }

  /* hero */
  .vc-hero {
    padding: clamp(4rem,7vw,7rem) 0 clamp(3rem,5vw,5rem);
    background: var(--vc-cream);
    border-bottom: 1px solid var(--vc-rule);
    text-align: center;
  }
  .vc-kicker {
    font-size: 11px; font-weight: 600; letter-spacing: 0.06em;
    text-transform: uppercase; color: var(--vc-sage); margin: 0 0 16px;
  }
  .vc-kicker-light { color: rgba(255,255,255,0.4); }
  .vc-hero h1 {
    margin: 0; font-size: clamp(2.4rem,5vw,4rem);
    font-weight: 800; letter-spacing: -0.035em; line-height: 1.02; color: var(--vc-ink);
  }
  .vc-hero h1 em { color: var(--vc-sage); font-style: italic; font-weight: 300; }
  .vc-hero-sub { margin: 20px auto 0; color: var(--vc-soft); font-size: 16px; line-height: 1.65; max-width: 500px; }

  /* application selector */
  .vc-selector { padding: clamp(3rem,5vw,5rem) 0; }
  .vc-selector-label {
    font-size: 12px; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase;
    color: var(--vc-mute); margin: 0 0 20px; text-align: center;
  }
  .vc-chips {
    display: grid; grid-template-columns: repeat(4,1fr); gap: 16px;
  }
  .vc-chip {
    display: flex; flex-direction: column; gap: 14px; padding: 24px 20px;
    background: var(--vc-white); border: 2px solid var(--vc-rule); border-radius: 14px;
    text-align: left; cursor: pointer; font-family: inherit;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }
  .vc-chip:hover {
    border-color: var(--vc-pale); transform: translateY(-3px);
    box-shadow: 0 12px 32px -8px rgba(74,102,48,0.15);
  }
  .vc-chip--active {
    border-color: var(--vc-sage) !important;
    background: linear-gradient(135deg, #f0f5e8 0%, #fff 100%);
    box-shadow: 0 8px 24px -6px rgba(74,102,48,0.25);
  }
  .vc-chip-icon { color: var(--vc-sage); opacity: 0.8; }
  .vc-chip--active .vc-chip-icon { opacity: 1; }
  .vc-chip-text { display: flex; flex-direction: column; gap: 5px; }
  .vc-chip-title { font-size: 14px; font-weight: 700; color: var(--vc-ink); line-height: 1.3; }
  .vc-chip-desc { font-size: 12px; color: var(--vc-mute); line-height: 1.5; }

  /* recommendation card */
  .vc-rec {
    margin-top: 24px;
    border: 2px solid var(--vc-sage);
    border-radius: 14px;
    background: linear-gradient(135deg, #f0f5e8 0%, #fff 100%);
    padding: 24px 28px;
    animation: vcFadeIn 0.25s ease;
  }
  @keyframes vcFadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
  .vc-rec-inner { display: grid; grid-template-columns: auto 1fr; gap: 28px; align-items: start; }
  .vc-rec-for { margin: 0 0 12px; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; color: var(--vc-mute); }
  .vc-rec-grades { display: flex; flex-wrap: wrap; gap: 8px; }
  .vc-rec-grade-pill {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 8px 18px; border-radius: 999px;
    font-size: 15px; font-weight: 800; letter-spacing: -0.02em;
    border: 2px solid transparent;
  }
  .vc-rec-grade-pill--food { background: var(--food-bg); color: var(--food-txt); border-color: var(--food-brd); }
  .vc-rec-grade-pill--nf   { background: var(--nf-bg);   color: var(--nf-txt);   border-color: var(--nf-brd); }
  .vc-rec-grade-pill--usp  { background: var(--usp-bg);  color: var(--usp-txt);  border-color: var(--usp-brd); }
  .vc-rec-grade-pill--ip   { background: var(--ip-bg);   color: var(--ip-txt);   border-color: var(--ip-brd); }
  .vc-rec-reason { margin: 0; color: var(--vc-soft); font-size: 13px; line-height: 1.7; }

  /* spec table */
  .vc-section { padding: clamp(4rem,6vw,6rem) 0; }
  .vc-section-cream { background: var(--vc-cream); }
  .vc-section-dark { background: var(--vc-ink); }
  .vc-h2 { margin: 0 0 28px; font-size: clamp(1.6rem,3vw,2.2rem); font-weight: 800; letter-spacing: -0.025em; color: var(--vc-ink); }
  .vc-h2-light { color: #fff; }
  .vc-spec-scroll { overflow-x: auto; border: 1px solid var(--vc-rule); border-radius: 10px; background: var(--vc-white); }
  .vc-spec { width: 100%; border-collapse: collapse; font-size: 13px; }
  .vc-spec thead { border-bottom: 1.5px solid var(--vc-rule); }
  .vc-spec th { padding: 16px 20px; text-align: left; white-space: nowrap; transition: background 0.2s; }
