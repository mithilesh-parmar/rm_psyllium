---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SpecBuilder from '../../components/SpecBuilder.astro';
---
<BaseLayout
  title="Psyllium Husk Supplier India | RM Psyllium"
  description="Bulk psyllium husk in 95%, 98%, and 99% purity grades with mesh, packaging, COA, and export documentation."
>
  <section class="section product-hero">
    <div class="container product-grid">
      <div>
        <p class="eyebrow">Product</p>
        <h1>Bulk psyllium husk for food, supplement, and pharma buyers.</h1>
        <p>
          Share your target purity, mesh, packaging, monthly volume, and destination port. We will match the lot, documents, and quote path.
        </p>
        <a class="btn btn-primary" href="/#talk" data-track="product_book_click">Request Husk Quote</a>
      </div>
      <img src="/assets/generated/psyllium-husk-export-bag.webp" width="1254" height="1254" alt="Open psyllium husk export bag with loose husk flakes in a Gujarat packing area" loading="eager" decoding="async" />
    </div>
  </section>

  <section class="section">
    <div class="container specs">
      <article>
        <h2>Available Grades</h2>
        <p>95%, 98%, and 99% purity options for buyer-specific formulation and labeling needs.</p>
      </article>
      <article>
        <h2>Mesh Range</h2>
        <p>20 to 100 mesh options captured before quote so samples and COA review match the buyer application.</p>
      </article>
      <article>
        <h2>Packaging</h2>
        <p>10kg bags, 25kg bags, 50kg bags, and 500kg jumbo bags available by buyer requirement.</p>
      </article>
    </div>
  </section>

  <section class="section form-band">
    <div class="container form-grid">
      <div>
        <p class="eyebrow">Request specs</p>
        <h2>Get quote, sample, and COA options.</h2>
        <p>Submit product, grade, mesh, packing, monthly volume, and destination market. Our export desk will reply with next steps.</p>
      </div>
      <div class="panel form-panel">
        <SpecBuilder />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  h1,
  h2 {
    margin: 0.45rem 0 1rem;
    line-height: 1.05;
  }

  h1 {
    font-size: clamp(2.7rem, 7vw, 5.2rem);
  }

  h2 {
    font-size: clamp(1.6rem, 3vw, 2.4rem);
  }

  p {
    color: #54707e;
    line-height: 1.62;
  }

  .product-hero {
    background: #f6f8f4;
  }

  .product-grid,
  .form-grid {
    display: grid;
    grid-template-columns: 1fr 0.85fr;
    align-items: center;
    gap: 3rem;
  }

  .product-grid img {
    border-radius: 8px;
    background: #ffffff;
    box-shadow: 0 18px 50px rgba(20, 33, 61, 0.08);
  }

  .specs {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .specs article,
  .form-panel {
    border: 1px solid #dfe6dc;
    border-radius: 8px;
    background: #ffffff;
    padding: 1.4rem;
  }

  .form-band {
    background: #f6f8f4;
  }

  @media (max-width: 860px) {
    h1 {
      font-size: clamp(2.25rem, 10vw, 3rem);
      overflow-wrap: anywhere;
    }

    .product-grid,
    .form-grid,
    .specs {
      grid-template-columns: 1fr;
    }
  }
</style>
