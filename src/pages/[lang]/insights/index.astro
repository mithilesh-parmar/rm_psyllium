---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { copy, getLanguage, insights, languages, insightTranslations } from '../../../data/site';

export function getStaticPaths() {
  return languages.map((language) => ({
    params: { lang: language.code }
  }));
}

const lang = getLanguage(Astro.params.lang);
const t = copy[lang];

const formattedInsights = insights.map((post) => {
  const localizedPost = {
    ...post,
    ...(insightTranslations[lang]?.[post.slug] || {})
  };
  return {
    ...localizedPost,
    formattedDate: new Date(post.date).toLocaleDateString(lang === 'en' ? 'en-GB' : lang, { day: 'numeric', month: 'long', year: 'numeric' })
  };
});

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Psyllium Buyer Guides — RM Psyllium',
  itemListElement: insights.map((post, i) => {
    const localizedPost = {
      ...post,
      ...(insightTranslations[lang]?.[post.slug] || {})
    };
    return {
      '@type': 'ListItem',
      position: i + 1,
      name: localizedPost.title,
      description: localizedPost.summary,
      url: `https://www.rmpsyllium.com/${lang}/insights/${post.slug}/`
    };
  })
};
---
<BaseLayout
  lang={lang}
  title={`Psyllium Buyer Guides & Insights | RM Psyllium`}
  description={t.insightsListTitle}
  structuredData={itemListSchema}
>
  <div class="ig-wrap">
    <!-- HEADER -->
    <header class="ig-header">
      <div class="ig-header-inner">
        <p class="ig-kicker">{t.insightsKicker}</p>
        <h1>{t.insightsListTitle}<br /><em>{t.insightsTitleSuffix}</em></h1>
        <p class="ig-lead">{t.insightsLead}</p>
      </div>
    </header>

    <!-- ARTICLE LIST + SIDEBAR -->
    <section class="ig-section">
      <div class="ig-inner">
        <div class="ig-list">
          {formattedInsights.map((post) => (
            <article class="ig-article">
              <div class="ig-article-meta">
                <span class="ig-audience">{post.audience}</span>
                <time datetime={post.date}>{post.formattedDate}</time>
              </div>
              <h2>
                <a href={`/${lang}/insights/${post.slug}/`}>{post.title}</a>
              </h2>
              <p>{post.summary}</p>
              <a class="ig-read-link" href={`/${lang}/insights/${post.slug}/`}>
                {t.insightsReadMore}
              </a>
            </article>
          ))}
        </div>

        <aside class="ig-sidebar">
          <div class="ig-cta-card">
            <p class="ig-cta-label">{t.readyToSource}</p>
            <h3>{t.sampleCoaTitle}</h3>
            <p>{t.sampleCoaBody}</p>
            <a class="ig-btn ig-btn-primary" href={`/${lang}/contact/`}>{t.navContact}</a>
            <a class="ig-btn ig-btn-wa" href="https://wa.me/918949817791" target="_blank" rel="noopener">{t.heroCtaWhatsApp}</a>
          </div>
          <div class="ig-topics-card">
            <p class="ig-cta-label">{t.topicsCovered}</p>
            <ul>
              <li>Grade selection (85%–99%)</li>
              <li>Mesh and particle size</li>
              <li>USP / EP / IP compliance</li>
              <li>Organic certification</li>
              <li>Export documentation</li>
              <li>Animal feed applications</li>
            </ul>
          </div>
          <div class="ig-nav-card">
            <p class="ig-cta-label">{t.moreResources}</p>
            <a href={`/${lang}/faq/`}>{t.navFaq} →</a>
            <a href={`/${lang}/quality/`}>{t.navQuality} →</a>
            <a href={`/${lang}/products/`}>{t.navProducts} →</a>
            <a href={`/${lang}/blog/`}>{t.navBlog} →</a>
          </div>
        </aside>
      </div>
    </section>

    <!-- BOTTOM CTA BAND -->
    <section class="ig-cta-band">
      <div class="ig-container">
        <div class="ig-cta-inner">
          <div>
            <h2>{t.sourcingQuestion}</h2>
            <p>{t.sourcingQuestionBody}</p>
          </div>
          <div class="ig-cta-btns">
            <a class="ig-btn ig-btn-light" href={`/${lang}/contact/`}>{t.navContact}</a>
            <a class="ig-btn ig-btn-wa" href="https://wa.me/918949817791" target="_blank" rel="noopener">WhatsApp</a>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .ig-wrap {
    --f: 'Inter', system-ui, -apple-system, sans-serif;
    --ink: #1a1c18;
    --soft: #484c43;
    --mute: #6b6f65;
    --rule: rgba(26, 28, 24, 0.1);
    --sage: #4a6630;
    --cream: #f5f3ed;
    --white: #ffffff;
  }

  .ig-header {
    background: var(--cream);
    border-bottom: 1px solid var(--rule);
    padding: clamp(4rem, 7vw, 7rem) 0 clamp(3rem, 5vw, 5rem);
  }

  .ig-header-inner {
    width: min(1140px, calc(100% - 128px));
    margin-inline: auto;
  }

  .ig-kicker {
    margin: 0 0 20px;
    color: var(--sage);
    font-family: var(--f);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .ig-header-inner h1 {
    margin: 0;
    font-family: var(--f);
    font-size: clamp(2.4rem, 5vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.02;
    color: var(--ink);
    max-width: 720px;
  }

  .ig-header-inner h1 em {
    color: var(--sage);
    font-style: italic;
    font-weight: 300;
  }

  .ig-lead {
    margin: 20px 0 0;
    color: var(--soft);
    font-family: var(--f);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
    max-width: 600px;
  }

  .ig-section {
    padding: clamp(4rem, 7vw, 7rem) 0;
  }

  .ig-inner {
    width: min(1100px, calc(100% - 128px));
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: clamp(3rem, 5vw, 5rem);
    align-items: start;
  }

  /* ---- article list ---- */
  .ig-list {
    display: grid;
    gap: 0;
    border-top: 1px solid var(--rule);
  }

  .ig-article {
    padding: 32px 0;
    border-bottom: 1px solid var(--rule);
    display: grid;
    gap: 10px;
  }

  .ig-article-meta {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .ig-audience {
    display: inline-block;
    border: 1px solid rgba(74,102,48,0.3);
    border-radius: 999px;
    padding: 3px 10px;
    color: var(--sage);
    font-family: var(--f);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .ig-article-meta time {
    color: var(--mute);
    font-family: var(--f);
    font-size: 12px;
    font-weight: 400;
  }

  .ig-article h2 {
    margin: 0;
    font-family: var(--f);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    font-weight: 700;
    letter-spacing: -0.015em;
    line-height: 1.25;
    color: var(--ink);
  }

  .ig-article h2 a {
    color: inherit;
    text-decoration: none;
  }

  .ig-article h2 a:hover { color: var(--sage); }

  .ig-article > p {
    margin: 0;
    font-family: var(--f);
    font-size: 14px;
    font-weight: 400;
    color: var(--soft);
    line-height: 1.65;
    max-width: 600px;
  }

  .ig-read-link {
    display: inline-block;
    color: var(--sage);
    font-family: var(--f);
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
  }

  .ig-read-link:hover { opacity: 0.75; }

  /* ---- sidebar ---- */
  .ig-sidebar {
    position: sticky;
    top: 104px;
    display: grid;
    gap: 16px;
  }

  .ig-cta-card {
    border: 1px solid var(--rule);
    border-radius: 8px;
    background: var(--white);
    padding: 24px;
    box-shadow: 0 8px 24px -12px rgba(26,28,24,0.12);
    display: grid;
    gap: 8px;
  }

  .ig-cta-label {
    margin: 0;
    color: var(--sage);
    font-family: var(--f);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .ig-cta-card h3 {
    margin: 0;
    font-family: var(--f);
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--ink);
    line-height: 1.15;
  }

  .ig-cta-card > p {
    margin: 4px 0 8px;
    font-family: var(--f);
    font-size: 13px;
    font-weight: 400;
    color: var(--soft);
    line-height: 1.6;
  }

  .ig-topics-card {
    border: 1px solid var(--rule);
    border-radius: 8px;
    background: var(--cream);
    padding: 20px 24px;
  }

  .ig-topics-card ul {
    margin: 12px 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 8px;
  }

  .ig-topics-card li {
    padding-left: 14px;
    position: relative;
    font-family: var(--f);
    font-size: 13px;
    color: var(--soft);
    line-height: 1.4;
  }

  .ig-topics-card li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: var(--sage);
    font-weight: 700;
  }

  .ig-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 12px 20px;
    font-family: var(--f);
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .ig-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px -8px rgba(26,28,24,0.2);
  }

  .ig-btn-primary { background: var(--ink); color: #fff; }
  .ig-btn-wa { background: #25d366; color: #fff; }
  .ig-btn-light { background: #fff; color: var(--ink); }

  .ig-nav-card {
    border: 1px solid var(--rule);
    border-radius: 8px;
    background: var(--white);
    padding: 20px 24px;
    display: grid;
    gap: 10px;
  }

  .ig-nav-card a {
    color: var(--ink);
    font-family: var(--f);
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
  }

  .ig-nav-card a:hover { color: var(--sage); }

  /* ---- bottom CTA band ---- */
  .ig-container {
    width: min(1140px, calc(100% - 128px));
    margin-inline: auto;
  }

  .ig-cta-band {
    background: var(--ink);
    padding: clamp(4rem, 7vw, 7rem) 0;
  }

  .ig-cta-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: center;
  }

  .ig-cta-inner h2 {
    margin: 0 0 12px;
    font-family: var(--f);
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: #fff;
  }

  .ig-cta-inner > div > p {
    margin: 0;
    color: rgba(255,255,255,0.65);
    font-family: var(--f);
    font-size: 15px;
    line-height: 1.65;
    max-width: 480px;
  }

  .ig-cta-btns { display: flex; gap: 12px; flex-wrap: wrap; }

  @media (max-width: 1100px) {
    .ig-header-inner, .ig-inner, .ig-container { width: calc(100% - 80px); }
  }

  @media (max-width: 860px) {
    .ig-header-inner, .ig-inner, .ig-container { width: calc(100% - 48px); }
    .ig-header-inner h1, .ig-lead { max-width: 100%; }
    .ig-inner { grid-template-columns: 1fr; }
    .ig-sidebar { position: static; grid-template-columns: repeat(2, 1fr); }
    .ig-cta-inner { grid-template-columns: 1fr; }
  }

  @media (max-width: 540px) {
    .ig-header-inner, .ig-inner, .ig-container { width: calc(100% - 32px); }
    .ig-sidebar { grid-template-columns: 1fr; }
  }
</style>
