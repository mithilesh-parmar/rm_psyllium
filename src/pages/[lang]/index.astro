---
import BaseLayout from '../../layouts/BaseLayout.astro';
import InsightGrid from '../../components/InsightGrid.astro';
import LanguageGateway from '../../components/LanguageGateway.astro';
import RouteCards from '../../components/RouteCards.astro';
import SpecBuilder from '../../components/SpecBuilder.astro';
import { copy, getLanguage, languages } from '../../data/site';

export function getStaticPaths() {
  return languages.map((language) => ({ params: { lang: language.code } }));
}

const lang = getLanguage(Astro.params.lang);
const c = copy[lang];
---
<BaseLayout
  lang={lang}
  title={`RM Psyllium | ${c.homeTitle}`}
  description={c.homeSub}
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="kicker">RM Psyllium</span>
        <h1 class="display">{c.homeTitle}</h1>
        <p class="lead">{c.homeSub}</p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="#spec">{c.cta}</a>
          <a class="btn btn-secondary" href={`/${lang}/products/psyllium-husk-powder/`}>{c.navProducts}</a>
        </div>
      </div>
      <div class="product-stage">
        <div class="stage-bg"></div>
        <img src="/assets/product-bag.svg" width="900" height="900" alt="RM Psyllium product packaging placeholder" />
      </div>
    </div>
  </section>

  <section class="section routes">
    <div class="container">
      <RouteCards />
    </div>
  </section>

  <section class="section quote" id="spec">
    <div class="container quote-grid">
      <div>
        <span class="kicker">{c.cta}</span>
        <h2 class="title-lg">{c.specTitle}</h2>
        <p class="lead">Share product, application, region, grade, mesh, and packaging.</p>
      </div>
      <div class="panel spec-panel">
        <SpecBuilder />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container section-head">
      <span class="kicker">{c.navInsights}</span>
      <h2 class="title-lg">Practical sourcing notes.</h2>
    </div>
    <div class="container">
      <InsightGrid />
    </div>
  </section>

  <section class="section languages">
    <div class="container">
      <LanguageGateway />
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 5.5rem 0 4rem;
  }

  .hero-grid,
  .quote-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(330px, 0.78fr);
    align-items: center;
    gap: 4rem;
  }

  .hero-copy {
    display: grid;
    gap: 1.35rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .product-stage {
    position: relative;
    min-height: 520px;
    display: grid;
    place-items: center;
  }

  .stage-bg {
    position: absolute;
    inset: 10% 4% 4%;
    border-radius: 42px;
    background: linear-gradient(135deg, rgba(223, 241, 230, 0.95), rgba(255, 253, 247, 0.76));
    box-shadow: 0 30px 90px rgba(16, 35, 63, 0.13);
  }

  .product-stage img {
    position: relative;
    width: min(82%, 420px);
    border-radius: 28px;
    box-shadow: 0 26px 80px rgba(16, 35, 63, 0.18);
  }

  .quote {
    background: var(--dark);
    color: #ffffff;
  }

  .quote .lead {
    color: rgba(255, 255, 255, 0.72);
  }

  .spec-panel {
    padding: 1.25rem;
    color: var(--ink);
  }

  .languages {
    background: #fffdf7;
  }

  .section-head {
    margin-bottom: 2rem;
  }

  @media (max-width: 920px) {
    .hero-grid,
    .quote-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
