---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { blogPosts, copy, getLanguage, languages } from '../../../data/site';

export function getStaticPaths() {
  return languages.map((language) => ({
    params: { lang: language.code }
  }));
}

const lang = getLanguage(Astro.params.lang);
const t = copy[lang];

const categories = [...new Set(blogPosts.map((p) => p.category))];

const formattedPosts = blogPosts.map((post) => ({
  ...post,
  formattedDate: new Date(post.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })
}));

const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'RM Psyllium Blog',
  description: t.blogLead,
  url: `https://www.rmpsyllium.com/${lang}/blog/`,
  publisher: {
    '@type': 'Organization',
    name: 'RM Psyllium',
    url: 'https://www.rmpsyllium.com'
  },
  blogPost: blogPosts.map((post) => ({
    '@type': 'BlogPosting',
    headline: post.title,
    description: post.summary,
    datePublished: post.date,
    url: `https://www.rmpsyllium.com/${lang}/blog/${post.slug}/`,
    author: { '@type': 'Organization', name: 'RM Psyllium' }
  }))
};
---
<BaseLayout
  lang={lang}
  title={`${t.blogTitle} | RM Psyllium`}
  description={t.blogLead}
  structuredData={blogSchema}
>
  <div class="bl-wrap">
    <!-- HEADER -->
    <header class="bl-header">
      <div class="bl-header-inner">
        <p class="bl-kicker">{t.navBlog}</p>
        <h1>{t.blogTitle}</h1>
        <p class="bl-lead">{t.blogLead}</p>
      </div>
    </header>

    <!-- CATEGORY FILTER -->
    <div class="bl-filter-bar">
      <div class="bl-filter-inner">
        <span class="bl-filter-label">{t.blogTopicsLabel}</span>
        <div class="bl-filter-tags">
          <a class="bl-tag bl-tag--active" href={`/${lang}/blog/`}>{t.blogAllLabel}</a>
          {categories.map((cat) => (
            <a class="bl-tag" href={`#${cat.toLowerCase()}`}>{cat}</a>
          ))}
        </div>
      </div>
    </div>

    <!-- POSTS GRID -->
    <section class="bl-section">
      <div class="bl-container">
        <div class="bl-grid">
          {formattedPosts.map((post) => (
            <a class="bl-card" href={`/${lang}/blog/${post.slug}/`}>
              <div class="bl-card-top">
                <span class="bl-card-cat">{post.category}</span>
                <time datetime={post.date}>{post.formattedDate}</time>
              </div>
              <h2>{post.title}</h2>
              <p>{post.summary}</p>
              <span class="bl-card-read">Read article →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA BAND -->
    <section class="bl-cta-band">
      <div class="bl-container">
        <div class="bl-cta-inner">
          <div>
            <h2>Have a sourcing question?</h2>
            <p>Our export team answers technical and commercial questions about psyllium grades, mesh, certifications, and export documentation.</p>
          </div>
          <div class="bl-cta-btns">
            <a class="bl-btn bl-btn-primary" href={`/${lang}/faq/`}>{t.navFaq}</a>
            <a class="bl-btn bl-btn-wa" href="https://wa.me/918949817791" target="_blank" rel="noopener">WhatsApp</a>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .bl-wrap {
    --f: 'Inter', system-ui, -apple-system, sans-serif;
    --ink: #1a1c18;
    --soft: #484c43;
    --mute: #6b6f65;
    --rule: rgba(26, 28, 24, 0.1);
    --sage: #4a6630;
    --cream: #f5f3ed;
    --white: #ffffff;
    --dark: #1a1c18;
  }

  .bl-header {
    background: var(--cream);
    border-bottom: 1px solid var(--rule);
    padding: clamp(4rem, 7vw, 7rem) 0 clamp(3rem, 5vw, 5rem);
  }

  .bl-header-inner {
    width: min(1140px, calc(100% - 128px));
    margin-inline: auto;
  }

  .bl-header h1,
  .bl-lead {
    max-width: 720px;
  }

  .bl-kicker {
    margin: 0 0 20px;
    color: var(--sage);
    font-family: var(--f);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .bl-header h1 {
    margin: 0;
    font-family: var(--f);
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--ink);
  }

  .bl-lead {
    margin: 20px 0 0;
    color: var(--soft);
    font-family: var(--f);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
  }

  /* filter bar */
  .bl-filter-bar {
    border-bottom: 1px solid var(--rule);
    padding: 16px 0;
    background: var(--white);
  }

  .bl-filter-inner {
    width: min(1140px, calc(100% - 128px));
    margin-inline: auto;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .bl-filter-label {
    font-family: var(--f);
    font-size: 11px;
    font-weight: 600;
    color: var(--mute);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .bl-filter-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .bl-tag {
    border: 1px solid var(--rule);
    border-radius: 999px;
    padding: 5px 14px;
    font-family: var(--f);
    font-size: 12px;
    font-weight: 500;
    color: var(--mute);
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
  }

  .bl-tag:hover, .bl-tag--active {
    border-color: var(--sage);
    color: var(--sage);
  }

  /* section */
  .bl-section {
    padding: clamp(4rem, 7vw, 7rem) 0;
  }

  .bl-container {
    width: min(1140px, calc(100% - 128px));
    margin-inline: auto;
  }

  /* grid */
  .bl-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .bl-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    border: 1px solid var(--rule);
    border-radius: 8px;
    background: var(--white);
    padding: 24px;
    text-decoration: none;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .bl-card:hover {
    box-shadow: 0 8px 32px -12px rgba(26,28,24,0.15);
    transform: translateY(-2px);
  }

  .bl-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .bl-card-cat {
    border: 1px solid rgba(74,102,48,0.25);
    border-radius: 999px;
    padding: 2px 8px;
    color: var(--sage);
    font-family: var(--f);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .bl-card-top time {
    color: var(--mute);
    font-family: var(--f);
    font-size: 11px;
    font-weight: 400;
  }

  .bl-card h2 {
    margin: 0;
    font-family: var(--f);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.3;
    color: var(--ink);
  }

  .bl-card > p {
    margin: 0;
    font-family: var(--f);
    font-size: 13px;
    font-weight: 400;
    color: var(--soft);
    line-height: 1.6;
    flex: 1;
  }

  .bl-card-read {
    font-family: var(--f);
    font-size: 12px;
    font-weight: 600;
    color: var(--sage);
    margin-top: auto;
  }

  /* CTA */
  .bl-cta-band {
    background: var(--dark);
    padding: clamp(4rem, 7vw, 7rem) 0;
  }

  .bl-cta-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: center;
  }

  .bl-cta-inner h2 {
    margin: 0 0 12px;
    font-family: var(--f);
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: #fff;
  }

  .bl-cta-inner > div > p {
    margin: 0;
    color: rgba(255,255,255,0.65);
    font-family: var(--f);
    font-size: 15px;
    line-height: 1.65;
    max-width: 480px;
  }

  .bl-cta-btns { display: flex; gap: 12px; flex-wrap: wrap; }

  .bl-btn {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 12px 22px;
    font-family: var(--f);
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .bl-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px -8px rgba(26,28,24,0.2);
  }

  .bl-btn-primary { background: #fff; color: var(--dark); }
  .bl-btn-wa { background: #25d366; color: #fff; }

  @media (max-width: 1100px) {
    .bl-header-inner, .bl-filter-inner, .bl-container { width: calc(100% - 80px); }
    .bl-header h1, .bl-lead { max-width: 100%; }
  }

  @media (max-width: 860px) {
    .bl-header-inner, .bl-filter-inner, .bl-container { width: calc(100% - 48px); }
    .bl-grid { grid-template-columns: repeat(2, 1fr); }
    .bl-cta-inner { grid-template-columns: 1fr; }
  }

  @media (max-width: 540px) {
    .bl-header-inner, .bl-filter-inner, .bl-container { width: calc(100% - 32px); }
    .bl-grid { grid-template-columns: 1fr; }
  }
</style>
