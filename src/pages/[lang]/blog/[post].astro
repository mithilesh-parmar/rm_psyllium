---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { blogPosts, blogPostTranslations, copy, getLanguage, languages } from '../../../data/site';

export function getStaticPaths() {
  return languages.flatMap((language) =>
    blogPosts.map((post) => ({
      params: { lang: language.code, post: post.slug },
      props: { post }
    }))
  );
}

const lang = getLanguage(Astro.params.lang);
const t = copy[lang];
const { post } = Astro.props;

const localizedPost = {
  ...post,
  ...(blogPostTranslations[lang]?.[post.slug] || {})
};

const formattedDate = new Date(post.date).toLocaleDateString('en-GB', {
  day: 'numeric', month: 'long', year: 'numeric'
});

const relatedPosts = blogPosts
  .filter((p) => p.slug !== post.slug && p.category === post.category)
  .slice(0, 3);

const blogPostSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: localizedPost.title,
  description: localizedPost.summary,
  datePublished: post.date,
  dateModified: post.date,
  inLanguage: lang,
  author: {
    '@type': 'Organization',
    name: 'RM Psyllium',
    url: 'https://rmpsyllium.com'
  },
  publisher: {
    '@type': 'Organization',
    name: 'RM Psyllium',
    url: 'https://rmpsyllium.com'
  },
  url: `https://rmpsyllium.com/${lang}/blog/${post.slug}/`,
  keywords: `psyllium, ${post.category.toLowerCase()}, psyllium supplier India, Siddhpur Gujarat`
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `https://rmpsyllium.com/${lang}/` },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `https://rmpsyllium.com/${lang}/blog/` },
    { '@type': 'ListItem', position: 3, name: post.title, item: `https://rmpsyllium.com/${lang}/blog/${post.slug}/` }
  ]
};
---
<BaseLayout
  lang={lang}
  title={`${localizedPost.title} | RM Psyllium`}
  description={localizedPost.summary}
  structuredData={[blogPostSchema, breadcrumbSchema]}
>
  <article class="bp-wrap">
    <!-- HEADER -->
    <header class="bp-header">
      <div class="bp-header-inner">
        <div class="bp-header-copy">
          <nav class="bp-breadcrumb" aria-label="Breadcrumb">
            <a href={`/${lang}/`}>{t.pdBreadcrumbHome}</a>
            <span aria-hidden="true">›</span>
            <a href={`/${lang}/blog/`}>{t.navBlog}</a>
            <span aria-hidden="true">›</span>
            <span>{t.blogCategories[post.category] ?? post.category}</span>
          </nav>
          <p class="bp-kicker">{t.blogCategories[post.category] ?? post.category}</p>
          <h1>{localizedPost.title}<br /><em>{t.blogCategories[post.category] ?? post.category}.</em></h1>
          <p class="bp-lead">{localizedPost.summary}</p>
          <time datetime={post.date}>{formattedDate}</time>
        </div>
        <div class="bp-header-stats">
          <div class="bp-hstat"><strong>{t.blogCategories[post.category] ?? post.category}</strong><span>{t.blogTopicLabel}</span></div>
          <div class="bp-hstat"><strong>{formattedDate}</strong><span>{t.insightsPublishedLabel}</span></div>
          <div class="bp-hstat"><strong>RM Psyllium</strong><span>{t.blogAuthorLabel}</span></div>
        </div>
      </div>
    </header>

    <!-- BODY + SIDEBAR -->
    <div class="bp-body-wrap">
      <div class="bp-body-inner">
        <div class="bp-content">
          {localizedPost.aiSnapshot && (
            <div class="bp-ai-snapshot">
              <p class="bp-ai-snapshot-label">AI Answer Snapshot</p>
              <p>{localizedPost.aiSnapshot}</p>
            </div>
          )}

          {localizedPost.body.map((para: string) => <p>{para}</p>)}

          {localizedPost.specTable && localizedPost.specTable.length > 0 && (
            <div class="bp-spec-section">
              <h2>Specification Reference</h2>
              <div class="bp-table-wrap">
                <table>
                  <thead>
                    <tr><th>Parameter</th><th>Range / Limit</th><th>Method</th></tr>
                  </thead>
                  <tbody>
                    {localizedPost.specTable.map((row: any) => (
                      <tr>
                        <td>{row.parameter}</td>
                        <td>{row.range}</td>
                        <td>{row.method}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          )}

          {localizedPost.faqs && localizedPost.faqs.length > 0 && (
            <div class="bp-faqs">
              <h2>Frequently Asked Questions</h2>
              {localizedPost.faqs.map((faqItem: any) => (
                <details class="bp-faq-item">
                  <summary class="bp-faq-q">{faqItem.q}</summary>
                  <p class="bp-faq-a">{faqItem.a}</p>
                </details>
              ))}
            </div>
          )}

          {localizedPost.sections?.map((section: any) => (
            <div class="bp-section">
              <h2>{section.heading}</h2>
              <p>{section.body}</p>
              {section.table && (
                <div class="bp-table-wrap">
                  <table>
                    <thead>
                      <tr>{section.table.headers.map((h: string) => <th>{h}</th>)}</tr>
                    </thead>
                    <tbody>
                      {section.table.rows.map((row: string[]) => (
                        <tr>{row.map((cell: string) => <td>{cell}</td>)}</tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              )}
            </div>
          ))}

          {localizedPost.internalLinks && localizedPost.internalLinks.length > 0 && (
            <div class="bp-internal-links">
              <p class="bp-related-label">{t.relatedArticles}</p>
              {localizedPost.internalLinks.map((link: any) => (
                <a class="bp-related-link" href={`/${lang}${link.path}`}>{link.text} →</a>
              ))}
            </div>
          )}

          {localizedPost.cta === 'sample' && (
            <div class="bp-inline-cta">
              <a href={`/${lang}/contact/`}>{t.ctaSampleRequest} →</a>
            </div>
          )}
          {localizedPost.cta === 'spec-sheet' && (
            <div class="bp-inline-cta">
              <a href={`/${lang}/contact/`}>{t.ctaSpecSheet} →</a>
            </div>
          )}

          {relatedPosts.length > 0 && (
            <div class="bp-related">
              <p class="bp-related-label">{t.relatedArticles}</p>
              {relatedPosts.map((rel) => (
                <a class="bp-related-link" href={`/${lang}/blog/${rel.slug}/`}>
                  {(blogPostTranslations[lang]?.[rel.slug] as any)?.title ?? rel.title} →
                </a>
              ))}
            </div>
          )}
        </div>

        <aside class="bp-sidebar">
          <div class="bp-cta-card">
            <p class="bp-cta-label">{t.readyToSource}</p>
            <h3>{t.sampleCoaTitle}</h3>
            <p>{t.sampleCoaBody}</p>
            <a class="bp-btn bp-btn-primary" href={`/${lang}/contact/`}>{t.navContact}</a>
            <a class="bp-btn bp-btn-wa" href="https://wa.me/918949817791" target="_blank" rel="noopener">{t.heroCtaWhatsApp}</a>
          </div>

          <div class="bp-meta-card">
            <div class="bp-meta-row"><strong>{t.blogCategoryLabel}</strong><span>{t.blogCategories[post.category] ?? post.category}</span></div>
            <div class="bp-meta-row"><strong>{t.insightsPublishedLabel}</strong><span>{formattedDate}</span></div>
            <div class="bp-meta-row"><strong>{t.blogAuthorLabel}</strong><span>RM Psyllium Export Team</span></div>
            <div class="bp-meta-row"><strong>{t.insightsSourceLabel}</strong><span>{t.sourceLocation}</span></div>
          </div>

          <div class="bp-nav-card">
            <p class="bp-cta-label">{t.moreResources}</p>
            <a href={`/${lang}/faq/`}>{t.navFaq} →</a>
            <a href={`/${lang}/quality/`}>{t.navQuality} →</a>
            <a href={`/${lang}/products/`}>{t.navProducts} →</a>
            <a href={`/${lang}/blog/`}>{t.navBlog} →</a>
          </div>
        </aside>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .bp-wrap {
    --f: 'Inter', system-ui, -apple-system, sans-serif;
    --ink: #1a1c18;
    --soft: #484c43;
    --mute: #6b6f65;
    --rule: rgba(26, 28, 24, 0.1);
    --sage: #4a6630;
    --cream: #f5f3ed;
    --white: #ffffff;
  }

  /* breadcrumb */
  .bp-breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 24px;
    font-family: var(--f);
    font-size: 12px;
    color: var(--mute);
  }

  .bp-breadcrumb a {
    color: var(--mute);
    text-decoration: none;
  }

  .bp-breadcrumb a:hover { color: var(--sage); }

  /* header */
  .bp-header {
    background: var(--cream);
    border-bottom: 1px solid var(--rule);
    padding: clamp(3rem, 6vw, 6rem) 0 clamp(2.5rem, 4vw, 4.5rem);
  }

  .bp-header-inner {
    width: min(1140px, calc(100% - 128px));
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(3rem, 5vw, 5rem);
    align-items: center;
  }

  .bp-kicker {
    margin: 0 0 16px;
    color: var(--sage);
    font-family: var(--f);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .bp-header-copy h1 {
    margin: 0;
    font-family: var(--f);
    font-size: clamp(2rem, 4.5vw, 3.6rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--ink);
  }

  .bp-header-copy h1 em {
    color: var(--sage);
    font-style: italic;
    font-weight: 300;
  }

  .bp-lead {
    margin: 16px 0 0;
    color: var(--soft);
    font-family: var(--f);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
    max-width: 520px;
  }

  time {
    display: inline-block;
    margin-top: 16px;
    color: var(--mute);
    font-family: var(--f);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  .bp-header-stats { display: grid; gap: 16px; }

  .bp-hstat {
    border: 1px solid var(--rule);
    border-radius: 8px;
    background: var(--white);
    padding: 20px 24px;
  }

  .bp-hstat strong {
    display: block;
    font-family: var(--f);
    font-size: clamp(1rem, 2vw, 1.4rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--ink);
    line-height: 1.2;
  }

  .bp-hstat span {
    display: block;
    margin-top: 6px;
    font-family: var(--f);
    font-size: 12px;
    font-weight: 500;
    color: var(--mute);
  }

  /* body */
  .bp-body-wrap {
    padding: clamp(4rem, 7vw, 7rem) 0;
  }

  .bp-body-inner {
    width: min(1100px, calc(100% - 128px));
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: clamp(3rem, 5vw, 5rem);
    align-items: start;
  }

  /* content */
  .bp-content p {
    margin: 0 0 24px;
    font-family: var(--f);
    font-size: 16px;
    font-weight: 400;
    color: var(--soft);
    line-height: 1.75;
    max-width: 660px;
  }

  .bp-content p:last-child { margin-bottom: 0; }

  .bp-related {
    margin-top: 40px;
    padding-top: 32px;
    border-top: 1px solid var(--rule);
    display: grid;
    gap: 10px;
  }

  .bp-related-label {
    margin: 0;
    color: var(--mute);
    font-family: var(--f);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bp-related-link {
    color: var(--ink);
    font-family: var(--f);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    line-height: 1.4;
  }

  .bp-related-link:hover { color: var(--sage); }

  /* sidebar */
  .bp-sidebar {
    position: sticky;
    top: 104px;
    display: grid;
    gap: 16px;
  }

  .bp-cta-card {
    border: 1px solid var(--rule);
    border-radius: 8px;
    background: var(--white);
    padding: 24px;
    box-shadow: 0 8px 24px -12px rgba(26,28,24,0.12);
    display: grid;
    gap: 8px;
  }

  .bp-cta-label {
    margin: 0;
    color: var(--sage);
    font-family: var(--f);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .bp-cta-card h3 {
    margin: 0;
    font-family: var(--f);
    font-size: 17px;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--ink);
    line-height: 1.15;
  }

  .bp-cta-card > p {
    margin: 4px 0 8px;
    font-family: var(--f);
    font-size: 13px;
    color: var(--soft);
    line-height: 1.6;
  }

  .bp-meta-card {
    border: 1px solid var(--rule);
    border-radius: 8px;
    background: var(--cream);
    padding: 20px 24px;
    display: grid;
    gap: 12px;
  }

  .bp-meta-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
  }

  .bp-meta-row strong {
    font-family: var(--f);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--mute);
    white-space: nowrap;
  }

  .bp-meta-row span {
    font-family: var(--f);
    font-size: 12px;
    font-weight: 500;
    color: var(--ink);
    text-align: right;
  }

  .bp-nav-card {
    border: 1px solid var(--rule);
    border-radius: 8px;
    background: var(--white);
    padding: 20px 24px;
    display: grid;
    gap: 10px;
  }

  .bp-nav-card a {
    color: var(--ink);
    font-family: var(--f);
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
  }

  .bp-nav-card a:hover { color: var(--sage); }

  .bp-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 12px 20px;
    font-family: var(--f);
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .bp-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px -8px rgba(26,28,24,0.2);
  }

  .bp-btn-primary { background: var(--ink); color: #fff; }
  .bp-btn-wa { background: #25d366; color: #fff; }

  @media (max-width: 1100px) {
    .bp-header-inner, .bp-body-inner { width: calc(100% - 80px); }
  }

  @media (max-width: 860px) {
    .bp-header-inner, .bp-body-inner { width: calc(100% - 48px); }
    .bp-header-inner { grid-template-columns: 1fr; }
    .bp-header-stats { grid-template-columns: repeat(3, 1fr); gap: 12px; }
    .bp-lead { max-width: 100%; }
    .bp-body-inner { grid-template-columns: 1fr; }
    .bp-sidebar { position: static; grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 540px) {
    .bp-header-inner, .bp-body-inner { width: calc(100% - 32px); }
    .bp-header-stats { grid-template-columns: 1fr; }
    .bp-sidebar { grid-template-columns: 1fr; }
  }

  /* sections */
  .bp-section {
    margin-top: 40px;
    padding-top: 32px;
    border-top: 1px solid var(--rule);
    max-width: 660px;
  }

  .bp-section h2 {
    margin: 0 0 12px;
    font-family: var(--f);
    font-size: clamp(1.15rem, 2.2vw, 1.45rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--sage);
    line-height: 1.2;
  }

  .bp-section > p {
    margin: 0 0 16px;
    font-family: var(--f);
    font-size: 16px;
    color: var(--soft);
    line-height: 1.75;
  }

  /* spec tables */
  .bp-table-wrap {
    overflow-x: auto;
    border-radius: 8px;
    border: 1px solid var(--rule);
    margin-top: 16px;
  }

  .bp-table-wrap table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--f);
    font-size: 14px;
  }

  .bp-table-wrap th {
    background: var(--sage);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 10px 14px;
    text-align: left;
    white-space: nowrap;
  }

  .bp-table-wrap td {
    padding: 10px 14px;
    border-top: 1px solid var(--rule);
    color: var(--soft);
    line-height: 1.5;
    vertical-align: top;
  }

  .bp-table-wrap tr:nth-child(even) td {
    background: var(--cream);
  }

  /* internal links */
  .bp-internal-links {
    margin-top: 40px;
    padding-top: 32px;
    border-top: 1px solid var(--rule);
    display: grid;
    gap: 10px;
    max-width: 660px;
  }

  /* inline CTA */
  .bp-inline-cta {
    margin-top: 40px;
    padding-top: 32px;
    border-top: 2px solid var(--sage);
    max-width: 660px;
  }

  .bp-inline-cta a {
    font-family: var(--f);
    font-size: 16px;
    font-weight: 700;
    color: var(--sage);
    text-decoration: none;
    letter-spacing: -0.01em;
  }

  .bp-inline-cta a:hover {
    text-decoration: underline;
  }

  /* ai snapshot */
  .bp-ai-snapshot {
    margin-bottom: 32px;
    padding: 20px 24px;
    border-left: 3px solid var(--sage);
    background: color-mix(in srgb, var(--sage) 6%, transparent);
    border-radius: 0 8px 8px 0;
    max-width: 660px;
  }

  .bp-ai-snapshot-label {
    margin: 0 0 8px;
    color: var(--sage);
    font-family: var(--f);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bp-ai-snapshot > p:last-child {
    margin: 0;
    font-family: var(--f);
    font-size: 15px;
    color: var(--soft);
    line-height: 1.7;
  }

  /* spec table section */
  .bp-spec-section {
    margin-top: 40px;
    padding-top: 32px;
    border-top: 1px solid var(--rule);
    max-width: 660px;
  }

  .bp-spec-section h2 {
    margin: 0 0 16px;
    font-family: var(--f);
    font-size: clamp(1.15rem, 2.2vw, 1.45rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--sage);
    line-height: 1.2;
  }

  /* faqs */
  .bp-faqs {
    margin-top: 40px;
    padding-top: 32px;
    border-top: 1px solid var(--rule);
    max-width: 660px;
  }

  .bp-faqs h2 {
    margin: 0 0 20px;
    font-family: var(--f);
    font-size: clamp(1.15rem, 2.2vw, 1.45rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--sage);
    line-height: 1.2;
  }

  .bp-faq-item {
    border-top: 1px solid var(--rule);
  }

  .bp-faq-item:last-child {
    border-bottom: 1px solid var(--rule);
  }

  .bp-faq-q {
    cursor: pointer;
    padding: 16px 0;
    font-family: var(--f);
    font-size: 15px;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.4;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }

  .bp-faq-q::after {
    content: '+';
    font-size: 20px;
    font-weight: 300;
    color: var(--sage);
    flex-shrink: 0;
  }

  details[open] .bp-faq-q::after { content: '−'; }

  .bp-faq-a {
    margin: 0 0 20px;
    font-family: var(--f);
    font-size: 15px;
    color: var(--soft);
    line-height: 1.75;
  }
</style>
