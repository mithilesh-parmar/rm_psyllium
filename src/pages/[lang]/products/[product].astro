---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SpecBuilder from '../../../components/SpecBuilder.astro';
import { copy, getLanguage, languages, products } from '../../../data/site';

export function getStaticPaths() {
  return languages.flatMap((language) =>
    products.map((product) => ({
      params: { lang: language.code, product: product.slug },
      props: { product }
    }))
  );
}

const lang = getLanguage(Astro.params.lang);
const t = copy[lang];
const { product } = Astro.props;

type GradeNote = { app: string; note: string };
type GradeFaqItem = { q: string; a: string };
type GradeCopy = { lead?: string; bestFor?: string; applicationNotes?: GradeNote[] };
type SpecRow = { parameter: string; values: Record<string, string> };
type PharmaTier = 'food' | 'nf' | 'usp' | 'ip';
type SuitLevel = 'yes' | 'cond' | 'no' | 'none';

const gradeLabels: string[] = (product as any).gradeLabels ?? [];
const specTable: SpecRow[] = (product as any).specTable ?? [];

// Per-grade data
const gradeData = product.gradeslugs.map((slug, i) => {
  const label = gradeLabels[i] ?? '';
  const gCopy: GradeCopy = (product as any).gradeCopy?.[label] ?? {};
  const gFaq: GradeFaqItem[] = (product as any).gradeFaq?.[label] ?? [];
  const gNotes: GradeNote[] = gCopy.applicationNotes ?? [];
  return { slug, label, gCopy, gFaq, gNotes };
});

// Deduplicated FAQs across all grades
const seenQs = new Set<string>();
const uniqueFaqs: GradeFaqItem[] = gradeData.flatMap((g) => g.gFaq).filter((f) => {
  if (seenQs.has(f.q)) return false;
  seenQs.add(f.q);
  return true;
});

// Helper: map pharmacopoeia text to a color tier
function getPharmaTier(pharma: string): PharmaTier {
  if (!pharma || pharma === '—') return 'food';
  if (pharma.includes('IP')) return 'ip';
  if (pharma.includes('USP') || pharma.includes('EP')) return 'usp';
  if (pharma.includes('NF')) return 'nf';
  return 'food';
}

// Helper: derive suitability level from note text + bestFor field
function getSuit(app: string, note: string, bestFor: string): SuitLevel {
  const lower = note.toLowerCase().trimStart();
  const bfl = (bestFor || '').toLowerCase();
  // Explicit unsuitability
  if (lower.startsWith('not suitable') || lower.startsWith('not recommended') || lower.startsWith('sortex premium is not')) return 'no';
  // Not applicable
  if (lower.startsWith('not used') || lower.includes('not justified for') || lower.startsWith('not specified for animal feed')) return 'none';
  // Primary fit — check bestFor contains app-related keywords
  const appKeywords: Record<string, string[]> = {
    'Pharma': ['pharma', 'laxative', 'capsule fill', 'otc'],
    'Nutraceutical': ['nutraceutical', 'supplement', 'sachet'],
    'Food and bakery': ['food', 'bakery', 'cereal'],
    'Animal feed': ['animal feed', 'cattle', 'feed'],
    'Animal Feed': ['animal feed', 'cattle', 'feed'],
    'Capsule filling': ['capsule'],
    'Gluten-free bakery': ['bakery', 'bread', 'gluten'],
    'Health drinks & drink mixes': ['drink', 'mix'],
    'Cosmetics & personal care': ['cosmetic', 'personal care'],
    'Functional food blends': ['food blend', 'supplement', 'functional'],
  };
  const kws = appKeywords[app] ?? [app.toLowerCase().split(/[\s/&]/)[0]];
  if (kws.some(kw => bfl.includes(kw))) return 'yes';
  // Note starts with a clear primary description
  if (lower.startsWith('primary use')) return 'yes';
  const first40 = lower.slice(0, 40);
  if (first40.includes('primary')) return 'yes';
  return 'cond';
}

// Extract pharma and swell volume rows from specTable
const pharmaRow = specTable.find(r => r.parameter.toLowerCase().includes('pharmacopoeia'));
const swellRow  = specTable.find(r => r.parameter.toLowerCase().includes('swell'));
const purityRow = specTable.find(r => r.parameter.toLowerCase().includes('purity') || r.parameter.toLowerCase().startsWith('purity'));

// Per-grade tier info (for hero compliance cards)
const gradeTiers = gradeData.map(g => ({
  ...g,
  pharma: pharmaRow?.values[g.label] ?? '—',
  swell:  swellRow?.values[g.label]  ?? '—',
  purity: purityRow?.values[g.label] ?? g.label,
  pharmaTier: getPharmaTier(pharmaRow?.values[g.label] ?? ''),
}));

// Suitability matrix: apps from first grade's notes
const matrixApps = gradeData[0]?.gNotes.map(n => n.app) ?? [];
const suitMatrix = matrixApps.map(app => ({
  app,
  suits: gradeData.map(g => {
    const n = g.gNotes.find(note => note.app === app);
    if (!n) return 'none' as SuitLevel;
    return getSuit(app, n.note, g.gCopy.bestFor ?? '');
  })
}));
const hasMatrix = suitMatrix.length > 0;

// Spec table: compute bar widths for quantitative rows
const swellValues  = gradeData.map(g => parseFloat(swellRow?.values[g.label]  ?? '0'));
const purityValues = gradeData.map(g => parseFloat((purityRow?.values[g.label] ?? '0').replace(/[^0-9.]/g, '')));
const maxSwell  = Math.max(...swellValues,  1);
const maxPurity = Math.max(...purityValues, 1);

// Structured data
const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: product.hero,
  material: 'Plantago ovata',
  countryOfOrigin: 'India',
  category: product.label,
  brand: { '@type': 'Brand', name: 'RM Psyllium' },
  offers: product.gradeslugs.map((slug, i) => ({
    '@type': 'Offer',
    name: `${product.name} — ${gradeLabels[i] ?? product.grades[i]}`,
    url: `https://www.rmpsyllium.com/${lang}/products/${product.slug}/#${slug}`,
    priceCurrency: 'USD',
    availability: 'https://schema.org/InStock',
    seller: { '@type': 'Organization', name: 'RM Psyllium' }
  }))
};

const faqSchema = uniqueFaqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: uniqueFaqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a }
  }))
} : null;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home',     item: `https://www.rmpsyllium.com/${lang}/` },
    { '@type': 'ListItem', position: 2, name: 'Products', item: `https://www.rmpsyllium.com/${lang}/products/` },
    { '@type': 'ListItem', position: 3, name: product.name, item: `https://www.rmpsyllium.com/${lang}/products/${product.slug}/` }
  ]
};

const schemas = [productSchema, breadcrumbSchema, ...(faqSchema ? [faqSchema] : [])];
---
<BaseLayout
  lang={lang}
  title={`${product.name} Supplier India | RM Psyllium`}
  description={product.hero}
  structuredData={schemas}
>
<div class="pd-wrap">

  <!-- ═══════════════════════════════════════
       HERO — copy left · grade pills right
  ══════════════════════════════════════════ -->
  <section class="pd-intro">
    <div class="pd-container">
      <div class="pd-intro-grid">

        <!-- LEFT: copy -->
        <div class="pd-intro-copy">
          <nav class="pd-breadcrumb" aria-label="Breadcrumb">
            <a href={`/${lang}/`}>{t.pdBreadcrumbHome}</a>
            <span aria-hidden="true">›</span>
            <a href={`/${lang}/products/`}>{t.navProducts}</a>
            <span aria-hidden="true">›</span>
            <span>{product.name}</span>
          </nav>
          <p class="pd-kicker">{product.label}</p>
          <h1>{product.name}<br /><em>{t.pdFromGujarat}</em></h1>
          <p class="pd-lead">{product.hero}</p>
          <p class="pd-summary">{product.summary}</p>
          <div class="pd-actions">
            <a class="pd-btn pd-btn-primary" href="#spec">{t.requestQuoteCta}</a>
            {hasMatrix && (
              <a class="pd-btn pd-btn-ghost" href="#matrix">{t.pdFindMyGrade}</a>
            )}
          </div>
        </div>

        <!-- RIGHT: grade pills + meta panel -->
        <div class="pd-pills-panel">
          <p class="pd-pills-heading">{t.pdAvailableGrades}</p>
          <div class="pd-grade-pills" role="list" aria-label={t.pdAvailableGrades}>
            {gradeTiers.map((g) => (
              <a class="pd-grade-pill" href={`#${g.slug}`} role="listitem">
                <span class="pd-pill-label">{g.label}</span>
                <span class="pd-pill-meta">
                  {g.pharma !== '—' && (
                    <span class={`pd-ph-badge pd-ph-${g.pharmaTier}`}>{g.pharma}</span>
                  )}
                  {g.swell !== '—' && (
                    <span class="pd-pill-swell">{g.swell} ml/g</span>
                  )}
                </span>
              </a>
            ))}
          </div>

          <div class="pd-panel-meta">
            <div class="pd-panel-meta-block">
              <p class="pd-pills-heading">{t.pdPackagingOptions}</p>
              <ul class="pd-panel-meta-list">
                {product.packaging.map((p) => <li>{p}</li>)}
              </ul>
            </div>
            <div class="pd-panel-meta-block">
              <p class="pd-pills-heading">{t.pdApplicationsLabel}</p>
              <ul class="pd-panel-meta-list">
                {product.applications.map((a) => <li>{a}</li>)}
              </ul>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       SUITABILITY MATRIX
  ══════════════════════════════════════════ -->
  {hasMatrix && (
    <section class="pd-section" id="matrix">
      <div class="pd-container">
        <p class="pd-section-kicker">{t.pdApplicationFit}</p>
        <h2 class="pd-section-title">{t.pdWhichGrade}</h2>
        <div class="pd-matrix-scroll">
          <table class="pd-matrix">
            <thead>
              <tr>
                <th class="pd-matrix-th-app">{t.pdApplicationsLabel}</th>
                {gradeTiers.map(g => (
                  <th>
                    <div class="pd-matrix-th-inner">
                      <span class="pd-matrix-th-pct">{g.label}</span>
                      {g.pharma !== '—' && (
                        <span class={`pd-ph-badge pd-ph-${g.pharmaTier} pd-ph-xs`}>{g.pharma}</span>
                      )}
                    </div>
                  </th>
                ))}
              </tr>
            </thead>
            <tbody>
              {suitMatrix.map(row => (
                <tr>
                  <td class="pd-matrix-app-label">{row.app}</td>
                  {row.suits.map(suit => (
                    <td class={`pd-suit-cell pd-suit-${suit}`}>
                      <span class="pd-suit-icon">
                        {suit === 'yes' ? '✓' : suit === 'cond' ? '◑' : suit === 'no' ? '✗' : '—'}
                      </span>
                      <span class="pd-suit-text">
                        {suit === 'yes' ? t.pdPrimary : suit === 'cond' ? t.pdConditional : suit === 'no' ? t.pdNotSuitable : t.pdNotUsed}
                      </span>
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <div class="pd-matrix-legend">
          <span class="pd-leg pd-leg-yes"><span>✓</span> {t.pdLegendPrimary}</span>
          <span class="pd-leg pd-leg-cond"><span>◑</span> {t.pdLegendConditional}</span>
          <span class="pd-leg pd-leg-no"><span>✗</span> {t.pdLegendNotSuitable}</span>
          <span class="pd-leg pd-leg-none"><span>—</span> {t.pdLegendNotApplicable}</span>
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════
       SPEC COMPARISON TABLE (with bar charts)
  ══════════════════════════════════════════ -->
  {specTable.length > 0 && (
    <section class="pd-section pd-section--cream">
      <div class="pd-container">
        <p class="pd-section-kicker">{t.pdSpecifications}</p>
        <h2 class="pd-section-title">{t.pdCompareGradesTitle.replace('{name}', product.name)}</h2>
        <div class="pd-table-wrap">
          <table class="pd-spec-table">
            <thead>
              <tr>
                <th class="pd-spec-th-param">{t.pdParameter}</th>
                {gradeLabels.map((label) => <th>{label}</th>)}
              </tr>
            </thead>
            <tbody>
              {specTable.map((row, _ri) => {
                const isSwell  = row.parameter.toLowerCase().includes('swell');
                const isPurity = row.parameter.toLowerCase().startsWith('purity') || row.parameter.toLowerCase().includes('husk content') || row.parameter.toLowerCase().includes('husk %');
                const isBar = isSwell || isPurity;
                const maxVal = isSwell ? maxSwell : maxPurity;
                return (
                  <tr class={isBar ? 'pd-bar-row' : ''}>
                    <td class="pd-spec-param">{row.parameter}</td>
                    {gradeLabels.map((label, _gi) => {
                      const raw = row.values[label] ?? '—';
                      const num = parseFloat(raw.replace(/[^0-9.]/g, ''));
                      const pct = isBar && !isNaN(num) ? Math.round((num / maxVal) * 100) : 0;
                      if (isBar && !isNaN(num)) {
                        return (
                          <td>
                            <div class="pd-bc">
                              <strong>{raw}</strong>
                              <div class="pd-bt"><div class="pd-bf" style={`width:${pct}%`}></div></div>
                            </div>
                          </td>
                        );
                      }
                      if (row.parameter.toLowerCase().includes('pharmacopoeia') && raw !== '—') {
                        const tier = getPharmaTier(raw);
                        return <td><span class={`pd-ph-badge pd-ph-${tier}`}>{raw}</span></td>;
                      }
                      if (raw === 'Absent') {
                        return <td class="pd-cell-pass">{raw}</td>;
                      }
                      return <td>{raw}</td>;
                    })}
                  </tr>
                );
              })}
              {gradeData.some((g) => g.gCopy.bestFor) && (
                <tr class="pd-spec-bestfor-row">
                  <td class="pd-spec-param">{t.pdBestFor}</td>
                  {gradeData.map((g) => (
                    <td class="pd-spec-bestfor-cell">{g.gCopy.bestFor ?? ''}</td>
                  ))}
                </tr>
              )}
            </tbody>
          </table>
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════
       GRADE CARDS — 2-column grid
  ══════════════════════════════════════════ -->
  <section class="pd-section" id="grades">
    <div class="pd-container">
      <p class="pd-section-kicker">{t.pdGradeDetails}</p>
      <h2 class="pd-section-title">{t.pdSelectGrade}</h2>
      <div class="pd-grade-grid">
        {gradeTiers.map((g, _i) => {
          const threeSpecs = specTable.slice(0, 3).map(row => ({
            param: row.parameter,
            val: row.values[g.label] ?? '—'
          }));
          return (
            <div class="pd-grade-card" id={g.slug}>
              <div class="pd-grade-card-top">
                <span class="pd-grade-card-pct">{g.label}</span>
                {g.pharma !== '—' && (
                  <span class={`pd-ph-badge pd-ph-${g.pharmaTier}`}>{g.pharma}</span>
                )}
              </div>
              {g.gCopy.bestFor && (
                <p class="pd-grade-card-for">{g.gCopy.bestFor}</p>
              )}
              {g.gCopy.lead && (
                <p class="pd-grade-card-lead">{g.gCopy.lead}</p>
              )}
              {threeSpecs.length > 0 && (
                <ul class="pd-grade-specs">
                  {threeSpecs.map(s => (
                    <li>
                      <span class="pd-gs-param">{s.param.replace(/\s*\(.*\)/, '')}</span>
                      <span class="pd-gs-val">{s.val}</span>
                    </li>
                  ))}
                </ul>
              )}
              {g.gNotes.length > 0 && (
                <div class="pd-grade-apps">
                  <p class="pd-grade-apps-label">{t.pdByApplication}</p>
                  <div class="pd-grade-apps-grid">
                    {g.gNotes.map(n => {
                      const suit = getSuit(n.app, n.note, g.gCopy.bestFor ?? '');
                      return (
                        <div class={`pd-app-chip pd-app-chip--${suit}`}>
                          <span class="pd-app-chip-name">{n.app}</span>
                        </div>
                      );
                    })}
                  </div>
                </div>
              )}
              <a class="pd-btn pd-btn-ghost pd-btn-sm" href="#spec">{t.requestQuoteCta}</a>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       FAQ (deduplicated across grades)
  ══════════════════════════════════════════ -->
  {uniqueFaqs.length > 0 && (
    <section class="pd-section pd-section--cream">
      <div class="pd-container">
        <div class="pd-faq-grid">
          <div class="pd-faq-copy">
            <p class="pd-section-kicker">{t.pdCommonQuestions}</p>
            <h2 class="pd-section-title">{t.pdFaqIntro}<br /><em>{t.pdFaqIntroSuffix}</em></h2>
            <p class="pd-faq-desc">{t.pdFaqDesc}</p>
          </div>
          <div class="pd-faq-list">
            {uniqueFaqs.map(item => (
              <details class="pd-faq-item">
                <summary>
                  <span>{item.q}</span>
                  <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                    <path d="M5 8l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </summary>
                <p>{item.a}</p>
              </details>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════
       QUOTE FORM
  ══════════════════════════════════════════ -->
  <section class="pd-quote" id="spec">
    <div class="pd-container">
      <div class="pd-contact-grid">
        <div class="pd-contact-copy">
          <div class="pd-contact-label"><span>{t.pdRequestQuoteLabel}</span><i></i></div>
          <h2>{t.requestQuoteBandTitle}<br /><em>{t.pdWithin24h}</em></h2>
          <p>{t.requestQuoteBandLead}</p>
        </div>
        <SpecBuilder productSlug={product.slug} />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       DARK CTA BAND
  ══════════════════════════════════════════ -->
  <section class="pd-cta-band">
    <div class="pd-container">
      <div class="pd-cta-inner">
        <div>
          <h2>{t.pdReadyToSource.replace('{name}', product.name)}</h2>
          <p>{t.pdCtaBody}</p>
        </div>
        <div class="pd-cta-btns">
          <a class="pd-btn pd-btn-light" href="#spec">{t.requestQuoteCta}</a>
          <a class="pd-btn pd-btn-wa" href="https://wa.me/918949817791" target="_blank" rel="noopener">{t.contactWaBtn}</a>
        </div>
      </div>
    </div>
  </section>

</div>
</BaseLayout>

<style>
  /* variables on the wrapper so Astro scoping doesn't break them */
  .pd-wrap {
    --pd-ink: #1a1c18;
    --pd-soft: #484c43;
    --pd-mute: #6b6f65;
    --pd-rule: rgba(26, 28, 24, 0.1);
    --pd-sage: #4a6630;
    --pd-sage-pale: #d8e0c8;
    --pd-cream: #f5f3ed;
    --pd-white: #ffffff;
    --pd-dark: #1a1c18;
    --pd-f: 'Inter', system-ui, -apple-system, sans-serif;
    --ph-food-bg: #f1f5f9; --ph-food-txt: #475569;
    --ph-nf-bg:   #eff6ff; --ph-nf-txt:   #2563eb;
    --ph-usp-bg:  #f5f3ff; --ph-usp-txt:  #7c3aed;
    --ph-ip-bg:   #fef3c7; --ph-ip-txt:   #b45309;
    --suit-yes-bg:  #dcfce7; --suit-yes-txt:  #166534;
    --suit-cond-bg: #fef9c3; --suit-cond-txt: #92400e;
    --suit-no-bg:   #fee2e2; --suit-no-txt:   #991b1b;
    --suit-none-bg: #f3f4f6; --suit-none-txt: #9ca3af;
  }

  /* ── container ── */
  .pd-container {
    width: min(1140px, calc(100% - 128px));
    margin-inline: auto;
  }

  /* ── breadcrumb ── */
  .pd-breadcrumb {
    display: flex; align-items: center; gap: 8px; margin-bottom: 28px;
    font-family: var(--pd-f); font-size: 12px; color: var(--pd-mute);
  }
  .pd-breadcrumb a { color: var(--pd-mute); text-decoration: none; }
  .pd-breadcrumb a:hover { color: var(--pd-sage); }

  /* ── hero intro ── */
  .pd-intro {
    background: var(--pd-cream);
    border-bottom: 1px solid var(--pd-rule);
    padding: clamp(4rem, 7vw, 7rem) 0 clamp(3rem, 5vw, 5rem);
  }
  .pd-intro-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: clamp(3rem, 5vw, 5rem);
    align-items: center;
  }
  .pd-intro-copy { min-width: 0; }

  /* ── grade pills panel (hero right) ── */
  .pd-pills-panel {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .pd-pills-heading {
    margin: 0;
    font-family: var(--pd-f);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--pd-mute);
  }
  .pd-grade-pills {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .pd-grade-pill {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--pd-white);
    border: 1px solid var(--pd-rule);
    border-radius: 10px;
    padding: 12px 16px;
    text-decoration: none;
    transition: border-color 0.18s, box-shadow 0.18s;
  }
  .pd-grade-pill:hover {
    border-color: var(--pd-sage);
    box-shadow: 0 2px 12px rgba(74,102,48,0.1);
  }
  .pd-pill-label {
    font-family: var(--pd-f);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--pd-ink);
  }
  .pd-pill-meta {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .pd-pill-swell {
    font-family: var(--pd-f);
    font-size: 12px;
    color: var(--pd-mute);
    font-weight: 500;
    white-space: nowrap;
  }

  .pd-kicker {
    margin: 0 0 20px; color: var(--pd-sage); font-family: var(--pd-f);
    font-size: 11px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase;
  }
  .pd-intro h1 {
    margin: 0; font-family: var(--pd-f);
    font-size: clamp(2.4rem, 5vw, 4rem); font-weight: 800;
    letter-spacing: -0.03em; line-height: 1.02; color: var(--pd-ink);
    max-width: 680px;
  }
  .pd-intro h1 em { color: var(--pd-sage); font-style: italic; font-weight: 300; }
  .pd-lead {
    margin: 20px 0 0; color: var(--pd-soft); font-family: var(--pd-f);
    font-size: 17px; font-weight: 400; line-height: 1.65; max-width: 520px;
  }
  .pd-summary {
