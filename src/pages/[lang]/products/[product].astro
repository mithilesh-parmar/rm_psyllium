---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SpecBuilder from '../../../components/SpecBuilder.astro';
import { getLanguage, languages, products } from '../../../data/site';

export function getStaticPaths() {
  return languages.flatMap((language) =>
    products.map((product) => ({
      params: { lang: language.code, product: product.slug },
      props: { product }
    }))
  );
}

const lang = getLanguage(Astro.params.lang);
const { product } = Astro.props;
---
<BaseLayout
  lang={lang}
  title={`${product.name} Supplier | RM Psyllium`}
  description={product.hero}
>
  <section class="section product-hero">
    <div class="container product-grid">
      <div>
        <span class="kicker">{product.label}</span>
        <h1 class="title-xl">{product.name}</h1>
        <p class="lead">{product.hero}</p>
        <div class="actions">
          <a class="btn btn-primary" href="#spec">Request Product Quote</a>
          <a class="btn btn-secondary" href={`/${lang}/industries/pharma-nutraceutical/`}>View Applications</a>
        </div>
      </div>
      <div class="product-visual">
        <div class="visual-bg"></div>
        <img src="/assets/product-bag.svg" width="900" height="900" alt={`${product.name} packaging placeholder`} />
      </div>
    </div>
  </section>

  <section class="section-tight intro">
    <div class="container intro-line">
      <span>Supply fit</span>
      <div>
        <p>{product.summary}</p>
        <small>Final specifications, certificates, and claims should be replaced with verified RM Psyllium documentation before launch.</small>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container detail-grid">
      <article>
        <h2>Grades</h2>
        {product.grades.map((item) => <p>{item}</p>)}
      </article>
      <article>
        <h2>Specifications</h2>
        {product.specs.map((item) => <p>{item}</p>)}
      </article>
      <article>
        <h2>Applications</h2>
        {product.applications.map((item) => <p>{item}</p>)}
      </article>
      <article>
        <h2>Packaging</h2>
        {product.packaging.map((item) => <p>{item}</p>)}
      </article>
    </div>
  </section>

  <section class="section band" id="spec">
    <div class="container quote-grid">
      <div>
        <span class="kicker">Quote path</span>
        <h2 class="title-lg">Turn this product page into a sales-qualified brief.</h2>
        <p class="lead">The same form works across every product, language, ICP, and region.</p>
      </div>
      <div class="panel spec-panel">
        <SpecBuilder />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .product-hero {
    padding-top: 5.5rem;
  }

  .product-grid,
  .quote-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.7fr);
    align-items: center;
    gap: 3rem;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .product-visual {
    position: relative;
    display: grid;
    min-height: 480px;
    place-items: center;
  }

  .visual-bg {
    position: absolute;
    inset: 10% 4% 4%;
    border-radius: 42px;
    background: linear-gradient(135deg, rgba(223, 241, 230, 0.95), rgba(255, 253, 247, 0.76));
    box-shadow: 0 30px 90px rgba(16, 35, 63, 0.13);
  }

  .product-visual img {
    position: relative;
    width: min(82%, 400px);
    border-radius: 28px;
    box-shadow: 0 26px 80px rgba(16, 35, 63, 0.18);
  }

  .intro {
    padding-top: 0;
  }

  .intro-line {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 2rem;
    border-block: 1px solid rgba(16, 35, 63, 0.1);
    padding-block: 2rem;
  }

  .intro-line span {
    color: #2d6a4f;
    font-weight: 840;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .intro-line p {
    margin: 0;
    color: #253b55;
    font-size: clamp(1.4rem, 3vw, 2.2rem);
    line-height: 1.28;
  }

  .intro-line small {
    display: block;
    margin-top: 0.9rem;
    color: #64748b;
    line-height: 1.5;
  }

  .detail-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .detail-grid article {
    border: 1px solid rgba(16, 35, 63, 0.1);
    border-radius: 18px;
    background: #fffdf7;
    padding: 1.3rem;
  }

  h2 {
    margin: 0 0 1rem;
    font-size: 1.2rem;
  }

  .detail-grid p {
    margin: 0.55rem 0;
    color: #64748b;
    line-height: 1.45;
  }

  .spec-panel {
    padding: 1.25rem;
    color: var(--ink);
  }

  @media (max-width: 960px) {
    .product-grid,
    .quote-grid,
    .detail-grid,
    .intro-line {
      grid-template-columns: 1fr;
    }
  }
</style>
