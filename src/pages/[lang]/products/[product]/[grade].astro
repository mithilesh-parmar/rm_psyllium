---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import SpecBuilder from '../../../../components/SpecBuilder.astro';
import { copy, getLanguage, languages, products } from '../../../../data/site';

export function getStaticPaths() {
  return languages.flatMap((language) =>
    products.flatMap((product) =>
      product.gradeslugs.map((gradeSlug) => ({
        params: { lang: language.code, product: product.slug, grade: gradeSlug },
        props: { product, gradeSlug }
      }))
    )
  );
}

const lang = getLanguage(Astro.params.lang);
const t = copy[lang];
const { product, gradeSlug } = Astro.props;

// Map gradeSlug to display label and find matching column in specTable
const gradeSlugToLabel: Record<string, string> = {
  // Psyllium Seeds
  'standard': 'Standard',
  'sortex': 'Sortex',
  // Psyllium Husk (whole)
  'grade-85': '85%',
  'grade-95': '95%',
  'grade-98': '98%',
  'grade-99': '99%',
  // Psyllium Husk Powder (purity + mesh)
  'grade-85-40m': '85% / 40–60m',
  'grade-95-80m': '95% / 80m',
  'grade-98-100m': '98% / 100m',
  'grade-99-200m': '99% / 200m',
  // Psyllium Khakha Powder
  'feed-grade-a': 'Feed Grade A',
  'feed-grade-b': 'Feed Grade B',
  // Industrial Grade Psyllium
  'standard-industrial': 'Standard Industrial',
  'premium-industrial': 'Premium Industrial',
  'pet-food-grade': 'Pet Food Grade',
  // Organic Psyllium
  'nop-certified': 'NOP',
  'eu-nop-certified': 'EU-NOP',
  // Psyllium Cattle Feed
  'sagar-gola': 'Sagar Gola',
  'sagar-lali': 'Sagar Lali',
};

const gradeLabel = gradeSlugToLabel[gradeSlug] ?? gradeSlug;

// Get only this grade's column from specTable
const specRows = product.specTable.map((row) => ({
  parameter: row.parameter,
  value: row.values[gradeLabel] ?? '—'
}));

// Build SEO strings based on product and grade
const seoTitle = `${product.name} ${gradeLabel} Grade Supplier India | RM Psyllium`;
const seoDescription = `Bulk ${product.name.toLowerCase()} ${gradeLabel} grade from Unjha, Gujarat. ${product.specs[0]}. FOB Mundra. COA and export documents per order.`;

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: `${product.name} — ${gradeLabel} Grade`,
  description: seoDescription,
  brand: {
    '@type': 'Brand',
    name: 'RM Psyllium'
  },
  manufacturer: {
    '@type': 'Organization',
    name: 'RM Psyllium',
    url: 'https://www.rmpsyllium.com',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Unjha',
      addressRegion: 'Gujarat',
      addressCountry: 'IN'
    }
  },
  offers: {
    '@type': 'Offer',
    availability: 'https://schema.org/InStock',
    seller: { '@type': 'Organization', name: 'RM Psyllium' },
    priceSpecification: {
      '@type': 'PriceSpecification',
      description: 'Price on request — share grade, volume, and destination'
    }
  },
  additionalProperty: specRows.map((row) => ({
    '@type': 'PropertyValue',
    name: row.parameter,
    value: row.value
  }))
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `https://www.rmpsyllium.com/${lang}/` },
    { '@type': 'ListItem', position: 2, name: 'Products', item: `https://www.rmpsyllium.com/${lang}/products/` },
    { '@type': 'ListItem', position: 3, name: product.name, item: `https://www.rmpsyllium.com/${lang}/products/${product.slug}/` },
    { '@type': 'ListItem', position: 4, name: `${gradeLabel} Grade`, item: `https://www.rmpsyllium.com/${lang}/products/${product.slug}/${gradeSlug}/` }
  ]
};
---
<BaseLayout
  lang={lang}
  title={seoTitle}
  description={seoDescription}
  structuredData={[productSchema, breadcrumbSchema]}
>
  <div class="gr-wrap">
    <!-- BREADCRUMB -->
    <div class="gr-breadcrumb-bar">
      <div class="gr-breadcrumb-inner">
        <nav aria-label="Breadcrumb">
          <a href={`/${lang}/`}>Home</a>
          <span aria-hidden="true">›</span>
          <a href={`/${lang}/products/`}>Products</a>
          <span aria-hidden="true">›</span>
          <a href={`/${lang}/products/${product.slug}/`}>{product.name}</a>
          <span aria-hidden="true">›</span>
          <span>{gradeLabel} Grade</span>
        </nav>
      </div>
    </div>

    <!-- HERO -->
    <section class="gr-hero">
      <div class="gr-hero-grid">
        <div class="gr-hero-copy">
          <p class="gr-kicker">{product.label} · {gradeLabel} Grade</p>
          <h1>{product.name}<br /><em>{gradeLabel} Grade</em></h1>
          <p class="gr-lead">{product.hero}</p>
          <div class="gr-actions">
            <a class="gr-btn gr-btn-primary" href="#spec">Request COA for this grade</a>
            <a class="gr-btn gr-btn-secondary" href={`/${lang}/products/${product.slug}/`}>All grades →</a>
          </div>
        </div>
        <div class="gr-visual">
          <div class="gr-placeholder">
            <span class="gr-mark">RM</span>
            <span class="gr-caption">{product.name} · {gradeLabel} · export packing</span>
          </div>
        </div>
      </div>
    </section>

    <!-- SPEC TABLE -->
    <section class="gr-section">
      <div class="gr-container">
        <p class="gr-section-kicker">Specifications</p>
        <h2 class="gr-section-title">{product.name} — {gradeLabel} Grade COA parameters</h2>
        <div class="gr-table-wrap">
          <table class="gr-table">
            <thead>
              <tr>
                <th>Parameter</th>
                <th>{gradeLabel} Grade</th>
              </tr>
            </thead>
            <tbody>
              {specRows.map((row) => (
                <tr>
                  <td>{row.parameter}</td>
                  <td>{row.value}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="gr-table-note">
          Full COA from NABL-accredited laboratory included with each shipment.
          <a href={`/${lang}/quality/`}>View quality documents →</a>
        </p>
      </div>
    </section>

    <!-- APPLICATIONS -->
    <section class="gr-section gr-section--cream">
      <div class="gr-container">
        <p class="gr-section-kicker">Applications</p>
        <h2 class="gr-section-title">Where {gradeLabel} grade is used</h2>
        <div class="gr-apps-grid">
          {product.applications.map((app) => (
            <div class="gr-app-card">
              <span class="gr-app-dot"></span>
              <span>{app}</span>
            </div>
          ))}
        </div>
        <p class="gr-all-grades">
          Need a different grade? <a href={`/${lang}/products/${product.slug}/`}>Compare all {product.name} grades →</a>
        </p>
      </div>
    </section>

    <!-- PACKAGING -->
    <section class="gr-section">
      <div class="gr-container">
        <p class="gr-section-kicker">Packaging options</p>
        <div class="gr-pack-grid">
          {product.packaging.map((pack) => (
            <div class="gr-pack-card">
              <strong>{pack}</strong>
              <span>bags / jumbo</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- QUOTE FORM -->
    <section class="gr-section gr-section--cream" id="spec">
      <div class="gr-quote-grid">
        <div class="gr-quote-copy">
          <p class="gr-kicker">Request COA &amp; quote</p>
          <h2>{t.requestQuoteBandTitle}</h2>
          <p class="gr-lead">{t.requestQuoteBandLead}</p>
        </div>
        <div class="gr-form-wrap">
          <SpecBuilder />
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .gr-wrap {
    --f: 'Inter', system-ui, -apple-system, sans-serif;
    --ink: #1a1c18;
    --soft: #484c43;
    --mute: #6b6f65;
    --rule: rgba(26, 28, 24, 0.1);
    --sage: #4a6630;
    --sage-pale: #d8e0c8;
    --cream: #f5f3ed;
    --white: #ffffff;
  }

  /* breadcrumb */
  .gr-breadcrumb-bar {
    border-bottom: 1px solid var(--rule);
    background: var(--white);
    padding: 14px 0;
  }

  .gr-breadcrumb-inner {
    width: min(1100px, calc(100% - 128px));
    margin-inline: auto;
  }

  nav[aria-label="Breadcrumb"] {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--f);
    font-size: 12px;
    color: var(--mute);
  }

  nav[aria-label="Breadcrumb"] a {
    color: var(--mute);
    text-decoration: none;
  }

  nav[aria-label="Breadcrumb"] a:hover { color: var(--sage); }

  /* hero */
  .gr-hero {
    padding: 64px 64px 80px;
    background: var(--white);
  }

  .gr-hero-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(3rem, 5vw, 5rem);
    align-items: center;
  }

  .gr-kicker {
    margin: 0 0 16px;
    color: var(--sage);
    font-family: var(--f);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .gr-hero-copy h1 {
    margin: 0;
    font-family: var(--f);
    font-size: clamp(2.4rem, 5vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.02;
    color: var(--ink);
  }

  .gr-hero-copy h1 em {
    color: var(--sage);
    font-style: italic;
    font-weight: 300;
  }

  .gr-lead {
    margin: 20px 0 0;
    color: var(--soft);
    font-family: var(--f);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
  }

  .gr-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 32px;
  }

  .gr-btn {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 13px 24px;
    font-family: var(--f);
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.25s cubic-bezier(.2,.7,.3,1), box-shadow 0.25s;
  }

  .gr-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 28px -12px rgba(26,28,24,0.2);
  }

  .gr-btn-primary { background: var(--ink); color: #fff; }
  .gr-btn-secondary { background: transparent; color: var(--ink); border: 1px solid rgba(26,28,24,0.2); }

  .gr-visual { display: flex; }

  .gr-placeholder {
    width: 100%;
    aspect-ratio: 4 / 5;
    background: var(--sage-pale);
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    text-align: center;
  }

  .gr-mark {
    font-family: var(--f);
    font-size: clamp(4rem, 10vw, 8rem);
    font-weight: 800;
    font-style: italic;
    letter-spacing: -0.05em;
    color: var(--sage);
    opacity: 0.25;
    line-height: 1;
  }

  .gr-caption {
    color: var(--sage);
    font-family: var(--f);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    opacity: 0.6;
  }

  /* sections */
  .gr-section {
    padding: clamp(4rem, 7vw, 7rem) 64px;
  }

  .gr-section--cream { background: var(--cream); }

  .gr-container {
    max-width: 1000px;
    margin-inline: auto;
  }

  .gr-section-kicker {
    margin: 0 0 16px;
    color: var(--sage);
    font-family: var(--f);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .gr-section-title {
    margin: 0 0 28px;
    font-family: var(--f);
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: var(--ink);
  }

  /* spec table */
  .gr-table-wrap {
    overflow-x: auto;
    border: 1px solid var(--rule);
    border-radius: 8px;
    background: var(--white);
    max-width: 560px;
  }

  .gr-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--f);
    font-size: 14px;
  }

  .gr-table th {
    padding: 14px 20px;
    text-align: left;
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--mute);
    background: var(--cream);
    border-bottom: 1px solid var(--rule);
  }

  .gr-table td {
    padding: 12px 20px;
    color: var(--soft);
    border-bottom: 1px solid var(--rule);
  }

  .gr-table tr:last-child td { border-bottom: 0; }

  .gr-table td:first-child { font-weight: 500; color: var(--ink); }

  .gr-table-note {
    margin: 16px 0 0;
    font-family: var(--f);
    font-size: 13px;
    color: var(--mute);
  }

  .gr-table-note a { color: var(--sage); text-decoration: none; font-weight: 500; }

  /* applications */
  .gr-apps-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    max-width: 560px;
    margin-bottom: 24px;
  }

  .gr-app-card {
    display: flex;
    align-items: center;
    gap: 12px;
    border: 1px solid var(--rule);
    border-radius: 8px;
    background: var(--white);
    padding: 16px 20px;
    font-family: var(--f);
    font-size: 14px;
    font-weight: 500;
    color: var(--ink);
  }

  .gr-app-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--sage);
    flex-shrink: 0;
  }

  .gr-all-grades {
    margin: 0;
    font-family: var(--f);
    font-size: 13px;
    color: var(--mute);
  }

  .gr-all-grades a { color: var(--sage); text-decoration: none; font-weight: 500; }

  /* packaging */
  .gr-pack-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .gr-pack-card {
    border: 1px solid var(--rule);
    border-radius: 8px;
    background: var(--cream);
    padding: 16px 24px;
    text-align: center;
  }

  .gr-pack-card strong {
    display: block;
    font-family: var(--f);
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--ink);
  }

  .gr-pack-card span {
    display: block;
    margin-top: 4px;
    font-family: var(--f);
    font-size: 11px;
    font-weight: 500;
    color: var(--mute);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  /* quote */
  .gr-quote-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: clamp(3rem, 5vw, 5rem);
    align-items: start;
    max-width: 1000px;
    margin-inline: auto;
  }

  .gr-quote-copy h2 {
    margin: 16px 0 0;
    font-family: var(--f);
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: var(--ink);
  }

  .gr-form-wrap {
    background: var(--white);
    border: 1px solid var(--rule);
    border-radius: 12px;
    padding: 28px;
  }

  /* responsive */
  @media (max-width: 1100px) {
    .gr-hero, .gr-section { padding-inline: 40px; }
    .gr-breadcrumb-inner { width: calc(100% - 80px); }
  }

  @media (max-width: 860px) {
    .gr-hero { padding: 40px 24px 56px; }
    .gr-hero-grid { grid-template-columns: 1fr; }
    .gr-visual { display: none; }
    .gr-section { padding: clamp(3rem, 5vw, 5rem) 24px; }
    .gr-quote-grid { grid-template-columns: 1fr; }
    .gr-apps-grid { grid-template-columns: 1fr; }
    .gr-breadcrumb-inner { width: calc(100% - 48px); }
  }

  @media (max-width: 540px) {
    .gr-breadcrumb-inner { width: calc(100% - 32px); }
  }
</style>
