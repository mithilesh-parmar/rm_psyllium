---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ComplianceGrid from '../../../components/ComplianceGrid.astro';
import { copy, getLanguage, languages } from '../../../data/site';

export function getStaticPaths() {
  return languages.map((language) => ({
    params: { lang: language.code }
  }));
}

const lang = getLanguage(Astro.params.lang);
const t = copy[lang];

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'RM Psyllium',
  url: 'https://www.rmpsyllium.com',
  hasCredential: [
    { '@type': 'EducationalOccupationalCredential', credentialCategory: 'FSSAI Registration', recognizedBy: { '@type': 'Organization', name: 'Food Safety and Standards Authority of India' } }
  ],
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Survey 412/3, GIDC Phase II',
    addressLocality: 'Unjha',
    addressRegion: 'Gujarat',
    postalCode: '384170',
    addressCountry: 'IN'
  }
};
---
<BaseLayout
  lang={lang}
  title={`Quality & Compliance — COA, Traceability, Export Documents | RM Psyllium`}
  description={t.complianceLead}
  structuredData={orgSchema}
>
  <!-- INTRO -->
  <section class="cl-intro">
    <div class="cl-intro-inner">
      <div class="cl-intro-copy">
        <p class="cl-kicker">{t.navQuality} &amp; Compliance</p>
        <h1>{t.complianceTitle}</h1>
        <p>{t.complianceLead}</p>
      </div>
      <div class="cl-intro-stats">
        <div class="cl-stat">
          <strong>47</strong>
          <span>{t.qualityCoaStatLabel}</span>
        </div>
        <div class="cl-stat">
          <strong>FSSAI</strong>
          <span>{t.qualityFssaiStatLabel}</span>
        </div>
        <div class="cl-stat">
          <strong>APEDA</strong>
          <span>{t.qualityApedaStatLabel}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- COMPLIANCE GRID -->
  <section class="cl-section">
    <div class="cl-container">
      <div class="cl-section-label"><span>{t.qualityDocTypesLabel}</span><i></i></div>
      <ComplianceGrid />
    </div>
  </section>

  <!-- CERTIFICATIONS -->
  <section class="cl-section cl-section--cream">
    <div class="cl-container">
      <div class="cl-section-label"><span>{t.labelCredentials}</span><i></i></div>
      <h2>{t.qualityCredTitle}</h2>
      <p class="cl-cert-lead">{t.qualityCredLead}</p>
      <div class="cl-cert-grid">
        <div class="cl-cert-card">
          <div class="cl-cert-header">
            <h3>FSSAI</h3>
            <span class="cl-badge cl-badge--green">{t.qualityBadgeRegistered}</span>
          </div>
          <p>{t.qualityFssaiDesc}</p>
        </div>
        <div class="cl-cert-card">
          <div class="cl-cert-header">
            <h3>APEDA</h3>
            <span class="cl-badge cl-badge--green">{t.qualityBadgeRegistered}</span>
          </div>
          <p>{t.qualityApedaDesc}</p>
        </div>
        <div class="cl-cert-card">
          <div class="cl-cert-header">
            <h3>Spices Board</h3>
            <span class="cl-badge cl-badge--green">{t.qualityBadgeRegistered}</span>
          </div>
          <p>{t.qualitySpicesBoardDesc}</p>
        </div>
        <div class="cl-cert-card">
          <div class="cl-cert-header">
            <h3>IEC 0124007841</h3>
            <span class="cl-badge cl-badge--green">{t.qualityBadgeActive}</span>
          </div>
          <p>{t.qualityIecDesc}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT CTA -->
  <section class="cl-section">
    <div class="cl-container cl-cta">
      <div>
        <h2>{t.qualityCtaTitle}</h2>
        <p>{t.qualityCtaBody}</p>
      </div>
      <div class="cl-cta-buttons">
        <a class="cl-btn cl-btn-primary" href="mailto:export@rmpsyllium.com">{t.qualityCtaEmailBtn}</a>
        <a class="cl-btn cl-btn-secondary" href="https://wa.me/918949817791" target="_blank" rel="noopener">WhatsApp</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  :root {
    --cl-ink: #1a1c18;
    --cl-soft: #484c43;
    --cl-mute: #6b6f65;
    --cl-rule: rgba(26, 28, 24, 0.1);
    --cl-sage: #4a6630;
    --cl-sage-pale: #d8e0c8;
    --cl-warm: #b8753a;
    --cl-cream: #f5f3ed;
    --cl-paper: #fafaf8;
    --cl-dark: #1a1c18;
    --cl-f: 'Inter', system-ui, -apple-system, sans-serif;
  }

  .cl-container {
    width: min(1140px, calc(100% - 128px));
    margin-inline: auto;
  }

  .cl-section {
    padding: clamp(4rem, 7vw, 7rem) 0;
  }

  .cl-section--cream { background: var(--cl-cream); }
  .cl-section--dark { background: var(--cl-dark); }

  .cl-section-label {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 32px;
    color: var(--cl-sage);
    font-family: var(--cl-f);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .cl-section-label i {
    flex: 1;
    max-width: 400px;
    height: 1px;
    background: var(--cl-rule);
  }

  .cl-intro {
    background: var(--cl-cream);
    padding: clamp(4rem, 7vw, 7rem) 0 clamp(3rem, 5vw, 5rem);
    border-bottom: 1px solid var(--cl-rule);
  }

  .cl-intro-inner {
    width: min(1140px, calc(100% - 128px));
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(3rem, 5vw, 5rem);
    align-items: center;
  }

  .cl-kicker {
    margin: 0 0 20px;
    color: var(--cl-sage);
    font-family: var(--cl-f);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .cl-kicker--light {
    color: rgba(255,255,255,0.5);
    margin-bottom: 16px;
  }

  .cl-intro-copy h1 {
    margin: 0;
    font-family: var(--cl-f);
    font-size: clamp(2.4rem, 5vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.02;
    color: var(--cl-ink);
  }

  .cl-intro-copy h1 em {
    color: var(--cl-sage);
    font-style: italic;
    font-weight: 300;
  }

  .cl-intro-copy p {
    margin: 20px 0 0;
    color: var(--cl-soft);
    font-family: var(--cl-f);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
    max-width: 520px;
  }

  .cl-intro-stats { display: grid; gap: 16px; }

  .cl-stat {
    border: 1px solid var(--cl-rule);
    border-radius: 8px;
    background: #fff;
    padding: 20px 24px;
  }

  .cl-stat strong {
    display: block;
    font-family: var(--cl-f);
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--cl-ink);
    line-height: 1;
  }

  .cl-stat span {
    display: block;
    margin-top: 6px;
    font-family: var(--cl-f);
    font-size: 12px;
    font-weight: 500;
    color: var(--cl-mute);
  }

  .cl-section h2 {
    margin: 0 0 40px;
    font-family: var(--cl-f);
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.05;
    color: var(--cl-ink);
  }

  .cl-section h2 em {
    color: var(--cl-sage);
    font-style: italic;
    font-weight: 300;
  }

  .cl-cert-lead {
    margin: 0 0 32px;
    color: var(--cl-soft);
    font-family: var(--cl-f);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.65;
    max-width: 680px;
  }

  .cl-cert-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    max-width: 760px;
  }

  .cl-cert-card {
    border: 1px solid var(--cl-rule);
    border-radius: 8px;
    background: #fff;
    padding: 24px;
  }

  .cl-cert-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 10px;
  }

  .cl-cert-card h3 {
    margin: 0;
    font-family: var(--cl-f);
    font-size: 17px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--cl-ink);
  }

  .cl-cert-card p {
    margin: 0;
    font-family: var(--cl-f);
    font-size: 12px;
    font-weight: 400;
    color: var(--cl-mute);
    line-height: 1.5;
  }

  .cl-badge {
    flex-shrink: 0;
    border-radius: 999px;
    padding: 4px 10px;
    font-family: var(--cl-f);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .cl-badge--green { background: rgba(74,102,48,0.12); color: #354d20; }
  .cl-badge--amber { background: rgba(184,117,58,0.12); color: #b8753a; }

  .cl-cta {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: center;
  }

  .cl-cta h2 {
    margin: 0 0 12px;
    font-family: var(--cl-f);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: var(--cl-ink);
  }

  .cl-cta > div > p {
    margin: 0;
    color: var(--cl-soft);
    font-family: var(--cl-f);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    max-width: 560px;
  }

  .cl-cta-buttons { display: flex; gap: 12px; flex-wrap: wrap; }

  .cl-btn {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 13px 24px;
    font-family: var(--cl-f);
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition: transform 0.25s cubic-bezier(.2,.7,.3,1), box-shadow 0.25s;
  }

  .cl-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 28px -12px rgba(26,28,24,0.2);
  }

  .cl-btn-primary { background: var(--cl-ink); color: #fff; }
  .cl-btn-secondary { background: #25d366; color: #fff; }

  @media (max-width: 1100px) {
    .cl-container, .cl-intro-inner { width: calc(100% - 80px); }
  }

  @media (max-width: 860px) {
    .cl-container, .cl-intro-inner { width: calc(100% - 48px); }
    .cl-intro-inner { grid-template-columns: 1fr; }
    .cl-intro-stats { grid-template-columns: repeat(3, 1fr); }
    .cl-cert-grid { grid-template-columns: 1fr; }
.cl-cta { grid-template-columns: 1fr; }
  }

  @media (max-width: 540px) {
    .cl-container, .cl-intro-inner { width: calc(100% - 32px); }
    .cl-intro-stats { grid-template-columns: 1fr; }
  }
</style>
