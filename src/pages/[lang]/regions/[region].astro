---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SpecBuilder from '../../../components/SpecBuilder.astro';
import { getLanguage, languages, products, regions } from '../../../data/site';

export function getStaticPaths() {
  return languages.flatMap((language) =>
    regions.map((region) => ({
      params: { lang: language.code, region: region.slug },
      props: { region }
    }))
  );
}

const lang = getLanguage(Astro.params.lang);
const { region } = Astro.props;
---
<BaseLayout
  lang={lang}
  title={`${region.name} Psyllium Import Microsite | RM Psyllium`}
  description={region.headline}
>
  <section class="section">
    <div class="container hero">
      <div>
        <span class="kicker">Regional microsite</span>
        <h1 class="title-xl">{region.name}</h1>
        <p class="lead">{region.headline}</p>
      </div>
      <div class="panel checklist">
        {region.focus.map((item) => <span>{item}</span>)}
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container product-strip">
      {products.slice(0, 4).map((product) => (
        <a href={`/${lang}/products/${product.slug}/`}>
          <strong>{product.name}</strong>
          <span>{product.label}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="section band">
    <div class="container quote-grid">
      <div>
        <span class="kicker">Market fit</span>
        <h2 class="title-lg">Capture regional requirements before the first email chain.</h2>
      </div>
      <div class="panel spec-panel">
        <SpecBuilder />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero,
  .quote-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.72fr);
    gap: 3rem;
    align-items: center;
  }

  .checklist {
    display: grid;
    gap: 0.75rem;
    padding: 1.35rem;
  }

  .checklist span,
  .product-strip a {
    border-radius: 14px;
    background: #dff1e6;
    padding: 1rem;
    font-weight: 820;
  }

  .product-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .product-strip a {
    display: grid;
    gap: 0.3rem;
    background: #fffdf7;
    border: 1px solid rgba(16, 35, 63, 0.1);
  }

  .product-strip span {
    color: #64748b;
    font-size: 0.86rem;
  }

  .spec-panel {
    padding: 1.25rem;
    color: var(--ink);
  }

  @media (max-width: 920px) {
    .hero,
    .quote-grid,
    .product-strip {
      grid-template-columns: 1fr;
    }
  }
</style>
